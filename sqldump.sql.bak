  `currency` varchar(10) COLLATE utf8mb4_general_ci NOT NULL DEFAULT 'NGN',
  `payment_status` varchar(50) COLLATE utf8mb4_general_ci NOT NULL DEFAULT 'pending',
  `customer_email` varchar(255) COLLATE utf8mb4_general_ci DEFAULT NULL,
  `customer_name` varchar(255) COLLATE utf8mb4_general_ci DEFAULT NULL,
  `customer_phone` varchar(50) COLLATE utf8mb4_general_ci DEFAULT NULL,
  `customer_address` text COLLATE utf8mb4_general_ci,
  `products_json` longtext CHARACTER SET utf8mb4 COLLATE utf8mb4_bin,
