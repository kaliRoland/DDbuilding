INSERT INTO `products` (`id`, `name`, `category`, `category_id`, `price`, `image_main`, `description`, `created_at`, `image_1`, `image_2`, `image_3`, `is_featured`, `brand`, `tags`, `specifications`, `sub_category_id`) VALUES
(11, '11kva 48v TAICO Veil.Max GD11048MH Hybrid Solar Inverter – High-Performance Off-Grid Power Solution', '11kva Inverter', 124, 500000.00, 'uploads/image_main_69368b506326b8.31462691.jpg', 'The TAICO Veil.Max GD11048MH is a powerful 11kW hybrid solar inverter designed for residential, commercial, and industrial use. With support for up to 11,000W, 150A charging, and a wide solar input range (90–500VDC), it delivers reliable off-grid or backup power with high efficiency and smart AC/solar integration.', '2026-02-28 16:50:02', 'uploads/image_1_69368b506455d6.99673659.jpg', NULL, NULL, 0, '', '', '[]', NULL),
(12, 'Minimum Solar Protection Set ; Essential Safety. Maximum Peace of Mind.', 'Minimum Solar Protection Set1', 123, 35000.00, 'uploads/image_main_6937fb1f784f86.33826136.png', 'Protect your solar investment with our Minimum Solar Protection Set, designed to keep your system running safely and efficiently.\r\n\r\nThis all-in-one safety solution guards against electrical faults, overloads, and voltage surges—so your power stays clean, reliable, and uninterrupted.\r\n\r\n \r\n\r\n📦 Package Includes:\r\n– 4-Way Enclosure Box – Compact, durable, and ready to house all protective gear with ease.\r\n– 32A AC Input Breaker (1P)– Provides overload and short-circuit protection on the AC side.\r\n– Volt and Amp Protector – Monitors and defends against harmful voltage/current fluctuations.\r\n– 60A DC Breaker (1P)– Protects the DC side from overcurrent and electrical hazards.\r\n\r\n—\r\n\r\nWhy It Matters:\r\n– Shields your solar inverter and batteries from damage\r\n– Ensures longer lifespan for your entire solar system\r\n– Easy to install and integrate into existing setups\r\n– Ideal for homes, small businesses, and off-grid installations\r\n\r\n—\r\n\r\nPrice: ₦35,000\r\n\r\n📍 Installation support available on request\r\n\r\n—\r\n\r\nStay safe. Stay solar-powered.\r\n\r\n📞 Call us today or visit [www.ddbuildingtech.com](http://www.ddbuildingtech.com)\r\n\r\n#SolarSafetyFirst #DDTechProtects #SmartPowerSolutions\r\n\r\n—', '2026-02-28 16:47:39', NULL, NULL, NULL, 0, '', '', '[]', NULL),
(13, 'Medium Solar Protection Set ;Shield Your Solar System with Confidence', 'Medium Solar Protection Set 1', 122, 50000.00, 'uploads/image_main_6937fac98f2960.70116911.png', 'Ensure the safety and longevity of your solar investment with the Medium Solar Protection Set—a robust assembly of essential components engineered to deliver maximum protection and peace of mind. Designed for medium-scale solar installations, this set balances performance, affordability, and ease of integration.\r\n\r\n—\r\n\r\nPackage Includes:\r\n– 6-Way Enclosure Box– Neatly organizes and secures all internal protective devices\r\n– 32A AC Input Breaker (1P)– Protects AC line from overload and short circuit\r\n– 60A DC Breaker (1P) – Secures DC circuits against overcurrent\r\n– Volt & Amp Protector (2P)– Monitors and guards your system from unstable voltage or current\r\n– DC SPD (Surge Protection Device)– Absorbs and deflects damaging voltage spikes from lightning and power surges\r\n\r\n—\r\n\r\n✅ Why It’s a Must-Have:\r\n– Prevents fire hazards and equipment damage\r\n– Extends the lifespan of inverters, batteries, and panels\r\n– Ensures safer energy distribution for homes and small businesses\r\n– Easy to install—compatible with most inverter systems\r\n\r\n—\r\n\r\n💰 Price: ₦50,000\r\n🛠️ Professional installation and guidance available from DD Building Tech Solutions\r\n\r\n—\r\n\r\nReady to secure your solar system?\r\n📞 Call: 08066113394 | 09161212301\r\n🌐 Visit: [www.ddbuildingtech.com](http://www.ddbuildingtech.com)\r\n\r\n#MediumProtectionSet #SolarDefense #DDTechSecures #SmartPowerNG', '2026-02-28 16:46:57', NULL, NULL, NULL, 0, '', '', '[]', NULL),
(14, 'FAMILY PRIDE PACKAGE–Your Home. Fully Powered. Stress-Free.', 'Complete Solar System', 14, 3080000.00, 'uploads/image_main_6937fb12003908.29680312.png', 'Take control of your energy with the Family Pride Package—a complete solar power solution designed for comfort, reliability, and affordability.\r\n\r\nWhether you’re powering a busy household or a growing small business, this system is designed to handle it all while reducing electricity costs and promoting a greener environment.\r\n\r\n🌞 What You Get\r\n– 6 Mono Crystalline Solar Panels\r\nHigh-efficiency panels built to harness more energy, even in low-light conditions, maximizing your power generation all year round.\r\n\r\n– 4 Durable Tubular Batteries\r\nEngineered for deep cycles and extended life, these batteries store enough energy to keep your appliances running when you need them most.\r\n\r\n– 5KVA Inverter\r\nDelivers stable, clean electricity to support multiple high-power appliances at once, protecting your home and electronics from power surges or grid failure.\r\n\r\n🔌 Powering Your Everyday Life\r\nRun all your essentials without stress, including:\r\n– Solar fan & lighting systems\r\n– Laptops & smartphones\r\n– Televisions & refrigerators\r\n– Washing machine\r\n– 1HP Air Conditioner\r\n– Microwave or blender\r\n\r\nNo noise. No fuel. Just uninterrupted power.\r\n\r\n🎉 Special Offer – 30% Off!\r\n– Old Price: ₦4,400,000\r\n– Now: ₦3,080,000\r\n\r\nGet premium components, expert installation, and lifetime value—all at a huge discount.\r\n\r\nEvery package is installed and supported by certified professionals from DD Building Technology Solutions, ensuring the safety and performance you can trust.\r\n\r\nWhy Choose Us?\r\nDD Tech stands at the forefront of Nigeria’s clean energy transition—bringing you smart, reliable, and customer-focused solar solutions that last.\r\n\r\n📞 Call Now: 08066113394 | 09161212301\r\n🌐 Visit: [www.ddbuildingtech.com](http://www.ddbuildingtech.com)', '2026-02-28 16:45:22', NULL, NULL, NULL, 1, '', '', '[]', NULL),
(15, 'Complete 1hp Solar Borehole Installation Kit', '1hp', 43, 956000.00, 'uploads/image_main_6937fa473d4105.27484660.jpeg', 'Complete 1hp Solar Borehole Installation Kit \r\nPower your water needs sustainably with our Complete 1hp Solar Borehole Installation Kit, a fully integrated solar water pumping solution ideal for homes, farms, schools, estates, and remote areas without access to reliable electricity.\r\n\r\nPackage Includes:\r\n✅ 1hp DC Submersible Pump – Efficient and durable, ideal for deep well water extraction.\r\n\r\n✅ 6 × 250W Solar Panels – High-efficiency monocrystalline panels to power your pump throughout the day.\r\n\r\n✅ Borehole Charge Controller – Intelligent MPPT controller for safe and optimized solar power usage.\r\n\r\n✅ 10 yards (1.5mm) 3-Core Solar Borehole Cable – Designed for deep installations, resistant to water and corrosion.\r\n\r\n✅ 20 yards (4mm) 2-Core PV Cable – Connects your solar panels to the controller for seamless power transmission.\r\n\r\nKey Features:\r\n💧 Reliable water pumping with no monthly electricity bills\r\n\r\n🌞 Operates entirely on solar energy – perfect for off-grid locations\r\n\r\n🔧 Easy to install and maintain\r\n\r\n🛡️ 1-Year Warranty on all components\r\n\r\n💰 Cost-effective and environmentally friendly solution\r\n\r\nWhether you need it for irrigation, domestic water supply, or livestock watering, this kit provides a dependable and long-term water solution using clean solar energy.', '2026-02-28 16:36:49', NULL, NULL, NULL, 0, '', '', '[]', NULL),
(16, 'SOLAR BENEFIT PACKAGE-Empowering Homes & Businesses with Clean, Reliable Energy', 'Complete Solar System', 14, 1880000.00, 'uploads/image_main_6937fab328fe81.65145668.png', 'Say goodbye to power outages and rising electricity bills with our Solar Benefits Package—a complete, expertly engineered solution by DD Building Technology Solutions.\r\n\r\nWhether you’re looking to secure energy independence for your home or elevate your business with sustainable power, this package delivers unmatched efficiency, durability, and performance.\r\n\r\nWhat’s Inside the Package\r\n– 4 Mono Crystalline Solar Panels\r\n\r\nHarness the sun with high-efficiency mono panels built to convert maximum sunlight into clean, usable energy—even in low-light conditions.\r\n\r\n– 2 Tubular Batteries\r\nGet powerful, long-lasting energy storage designed for deep cycles and minimal maintenance, ensuring power when you need it most.\r\n\r\n– 5KVA Inverter\r\nOur premium inverter offers stable power conversion, protecting your appliances and supporting seamless electricity delivery throughout the day.\r\n\r\nPower Capacity\r\nThis robust package is capable of running:\r\n– ✅ Solar fan\r\n– ✅ Lighting systems\r\n– ✅ Laptop & mobile phone charging\r\n– ✅ Television\r\n– ✅ Refrigerator\r\n– ✅ Washing machine\r\n– ✅ 1HP air conditioner\r\n\r\nIdeal for households and small businesses looking to run daily essentials and more, with peace of mind and zero noise.\r\n\r\nLimited Time Offer – 30% Discount!\r\n– Original Price: ₦2,685,800\r\n– Now: ₦1,880,000\r\n\r\nInstallation handled by our certified professionals ensures safety, reliability, and optimal system performance—no hassle, just clean energy.\r\n\r\n \r\n\r\nWhy Choose DD Tech?\r\nWith  a proven track record, we deliver tailored energy solutions backed by quality components, professional installations, and ongoing support.\r\n\r\nOur clients trust us because we don’t just sell solar—we build energy independence.\r\n\r\n📞 Call Now: 08066113394 | 09161212301\r\n🌐 Visit: [www.ddbuildingtechnology.com](http://www.ddbuildingtech.com)', '2026-02-28 16:44:13', NULL, NULL, NULL, 0, '', '', '[]', NULL),
(17, 'Motorola 399 walkie talkie', 'intercomm system', 2, 50000.00, 'uploads/image_main_6937faf77b7dd0.59697784.png', '', '2026-01-14 09:16:52', NULL, NULL, NULL, 1, '', NULL, NULL, NULL),
(18, 'AiSolar Camera + Lighting: Illuminate, Observe, and Secure – All in One!', 'cctv solution', 3, 150000.00, 'uploads/image_main_6937fae058bea4.53082104.png', '', '2026-01-14 09:16:52', NULL, NULL, NULL, 1, '', NULL, NULL, NULL),
(23, '1.5kva Solar Inverter Package with 1 Battery & 2 Solar Panels', 'Complete Solar System', 14, 1000000.00, 'uploads/image_main_6967c6ee087123.13562487.jpg', '1.5KVA Solar Inverter Power System – Complete Solar Package\r\n\r\nThis 1.5kVA solar inverter setup is designed to provide reliable backup power for light to medium household use. It is ideal for homes that need stable electricity for essential appliances without noise, fuel, or frequent maintenance.\r\n\r\nPackage Includes:\r\n* 1 unit of 1.5kVA inverter\r\n* 1 unit of 220Ah tubular battery\r\n* 2 units of 450W solar panels\r\n\r\nPower Capacity:\r\n* Charges mobile phones and other small devices\r\n* Powers LED lights and ceiling/standing fans\r\n* Runs laptops, TV, and decoder comfortably\r\n* Can support a freezer \r\n\r\nKey Advantages:\r\n* Tubular battery ensures longer lifespan and better performance\r\n* Solar-powered for cost savings and cleaner energy\r\n* Suitable for daily household electricity needs\r\n\r\nRecommended For:\r\nSelf-contained apartment or 2-bedroom apartment\r\n\r\nPrice: ₦1m', '2026-01-14 17:45:39', 'uploads/image_1_6967ba03763cb9.65287155.jpg', 'uploads/image_2_6967ba03764fd9.70161671.jpg', 'uploads/image_3_6967ba037659c0.95517606.jpg', 0, 'Other', 'solar energy, inverter, 1.5kva, power, solar, solar panel, 1.5kva inverter', '[{\"title\":\"Tubular Battery\",\"detail\":\"220Ah\"},{\"title\":\"Solar Panel\",\"detail\":\"450W\"},{\"title\":\"Inverter\",\"detail\":\"1.5kva\"}]', NULL),
(24, '1.7kva Solar Inverter Package with 2 Batteries & 3 Solar Panels', 'Complete Solar System', 14, 1430000.00, 'uploads/image_main_6967c76f4157c7.50776859.jpg', '1.7KVA Solar Inverter Power System – Complete Solar Package\r\n\r\nA dependable solar power solution designed to provide stable, clean electricity for everyday household needs. This system is perfect for homes, small offices, and apartments that want reliable solar power without stress. Ready to install and enjoy uninterrupted electricity.\r\n\r\nPackage Includes:\r\n* 1 unit 1.7kVA Solar Inverter \r\n* 2 units of 220Ah Batteries\r\n* 3 units of 450W Solar Panels\r\n\r\nWhat It Can Power:\r\n* Phone charging and small electronics\r\n* LED lights and ceiling/standing fans\r\n* Laptop and desktop systems\r\n* TV and decoder\r\n* Refrigerator and freezer\r\n\r\nKey Benefits:\r\n* Provides steady power during outages\r\n* Batteries store power for night use and cloudy days\r\n* System is expandable for higher power needs in the future\r\n\r\nRecommended Usage:\r\n* 1 bedroom — 3 bedroom apartments', '2026-01-14 17:46:02', 'uploads/image_1_6967c26cc65ba0.50244915.jpg', 'uploads/image_2_6967c26cc66c04.80603193.jpg', 'uploads/image_3_6967c26cc67a95.66920568.jpg', 0, 'Other', 'solar energy, inverter, 1.7kva, power, solar, solar panel, 1.7kva inverter', '[{\"title\":\"Tubular Battery\",\"detail\":\"220Ah\"},{\"title\":\"Solar Panel\",\"detail\":\"450W\"},{\"title\":\"Solar Inverter\",\"detail\":\"1.7kva\"}]', NULL),
(25, '2.5kva Solar Inverter Package with 2 Batteries & 4 Solar Panels', 'Complete Solar System', 14, 1620000.00, 'uploads/image_main_6967c60ed72151.55669446.jpg', '2.5KVA Solar Inverter Power System – Complete Solar Package\r\n\r\nA powerful solar energy solution built to handle higher household loads with ease. This system is an excellent choice for homes seeking strong, long-lasting solar power capable of running essential and semi-heavy appliances without interruption.\r\n\r\nPackage Includes:\r\n* 1 unit 2.5kVA Solar Inverter \r\n* 2 units of 220Ah Tubular Batteries \r\n* 4 units of 450W Solar Panels\r\n\r\nWhat It Can Power:\r\n* Phone charging and small electronics\r\n* LED lights and multiple fans\r\n* Laptops and desktop computers\r\n* TV and decoder\r\n* Refrigerator and freezer\r\n* Washing machine\r\n* 1HP – 1.5HP water pump (Sumo)\r\n\r\nKey Benefits:\r\n* Supports heavier appliances compared to smaller systems\r\n* High-capacity tubular batteries for better durability\r\n\r\nRecommended Usage:\r\nSuitable for 2 bedroom — 3 bedroom apartments', '2026-01-14 17:46:24', 'uploads/image_1_6967c60ed73c18.16593526.jpg', 'uploads/image_2_6967c60ed74a07.16303335.jpg', 'uploads/image_3_6967c60ed755c6.38954494.jpg', 0, 'Other', 'solar energy, inverter, 2.5kva, power, solar, solar panel, 2.5kva inverter', '[{\"title\":\"Tubular Battery\",\"detail\":\"220Ah\"},{\"title\":\"Solar Panel\",\"detail\":\"450W\"},{\"title\":\"Inverter\",\"detail\":\"2.5kva\"}]', NULL),
(26, '3kva Solar Inverter Package with 1 Lithium Battery & 4 Solar Panels', 'Complete Solar System', 14, 2250000.00, 'uploads/image_main_6967c9cfdbf9c8.93405286.jpg', '3KVA Solar Inverter Power System – Complete Solar Package\r\n\r\nA high-performance solar power solution designed for homes that require stronger, more reliable energy storage and faster charging. This setup delivers consistent power, longer battery life, and better efficiency for modern households.\r\n\r\nPackage Includes:\r\n* 1 unit 3kVA Solar Inverter \r\n* 1 unit 5kWh Lithium Battery \r\n* 4 units of 600W Solar Panels\r\n\r\nWhat It Can Power:\r\n* Phone charging and small electronics\r\n* LED lights and multiple fans\r\n* Laptops and desktop systems\r\n* TV and decoder\r\n* Refrigerator and freezer\r\n* Washing machine\r\n* 1HP – 1.5HP water pump (Sumo)\r\n* 1HP Air Conditioner \r\n\r\nKey Benefits:\r\n* Lithium battery offers longer lifespan \r\n* Faster charging and better performance\r\n* Stable power output for heavy appliances\r\n\r\nRecommended:\r\nIdeal for 2 bedroom — 4 bedroom apartments', '2026-01-14 17:46:42', 'uploads/image_1_6967c9cfdc1d27.80869482.jpg', 'uploads/image_2_6967c9cfdc2dc7.68439421.jpg', 'uploads/image_3_6967c9cfdc3a95.13032834.jpg', 0, 'Other', 'solar energy, inverter, 3kva, power, solar, solar panel, 3kva inverter', '[{\"title\":\"Lithium Battery\",\"detail\":\"5kwh\"},{\"title\":\"Solar Panel\",\"detail\":\"600W\"},{\"title\":\"Solar Inverter\",\"detail\":\"3kva\"}]', NULL),
(27, '5kva Solar Inverter Package with 1 Lithium Battery & 6 Solar Panels', 'Complete Solar System', 14, 2600000.00, 'uploads/image_main_6967cc9b0ed293.24521108.jpg', '5KVA Solar Inverter Power System – Complete Solar Package\r\nThis system is an excellent choice for families and homes seeking powerful, stable, and long-term solar energy to handle both essential and heavy household loads with confidence.\r\n\r\nPackage Includes:\r\n* 1 unit 5kVA Solar Inverter \r\n* 1 unit 5kWh Lithium Battery \r\n* 6 units of 600W Solar Panels\r\n\r\nWhat It Can Power:\r\n* Phone charging and small electronics\r\n* LED lights and multiple fans\r\n* Laptops and desktop systems\r\n* TV and decoder\r\n* Refrigerator and freezer\r\n* Washing machine\r\n* 1HP – 1.5HP water pump (Sumo)\r\n* 2 units of 1HP Air Conditioners \r\n\r\nKey Benefits:\r\n* Strong inverter capacity for running multiple appliances simultaneously\r\n* Lithium battery ensures faster charging and longer service life\r\n\r\nRecommended Usage:\r\nIdeal for 2 bedroom – 4 bedroom apartments', '2026-01-14 17:46:57', 'uploads/image_1_6967cc9b0ef3b7.93435669.jpg', 'uploads/image_2_6967cc9b0f00b5.22120773.jpg', 'uploads/image_3_6967cc9b0f0ed0.76982828.jpg', 0, 'Other', 'solar energy, inverter, 5kva, power, solar, solar panel, 5kva inverter', '[{\"title\":\"Lithium Battery\",\"detail\":\"5kwh\"},{\"title\":\"Solar Panel\",\"detail\":\"600W\"},{\"title\":\"Solar Inverter\",\"detail\":\"5kva\"}]', NULL),
(29, '8kva Solar Inverter Package with 1 Lithium Battery & 12 Solar Panels', 'Complete Solar System', 14, 4830000.00, 'uploads/image_main_69a073cc216ab8.96371071.jfif', '8KVA Solar Inverter Power System – Complete Solar Package \r\n\r\nThis system is designed for large homes and families that need reliable, high-performance solar power to run both everyday appliances and heavy loads comfortably, even during extended power outages.\r\n\r\nPackage Includes:\r\n\r\n* 1 unit 8kVA Hybrid Solar Inverter\r\n* 1 unit 10kWh Lithium Battery\r\n* 12 units of 600W Solar Panels\r\n* 1 unit Medium Breaker Set\r\n\r\nWhat It Can Power:\r\n\r\n* Phone charging and laptops\r\n* LED lights and multiple fans\r\n* Television and decoder\r\n* Refrigerator and freezer\r\n* Washing machine\r\n* 1HP – 3HP water pump (Sumo)\r\n* 2 units of 1.5HP air conditioners\r\n\r\nKey Benefits:\r\n\r\n* High-capacity hybrid inverter for heavy and multiple loads\r\n* Large 10kWh lithium battery for longer backup time and faster charging\r\n* Strong solar panel array for efficient daytime power generation\r\n* Suitable for simultaneous appliance usage without stress\r\n\r\nRecommended Usage:\r\nIdeal for 4 bedroom – 6 bedroom apartments', '2026-02-26 16:24:44', 'uploads/image_1_6967d044a272d4.41856576.jpg', 'uploads/image_2_6967d044a283a9.95323375.jpg', 'uploads/image_3_6967d044a28fb4.15991562.jpg', 0, 'Other', 'solar energy, inverter, 8kva, power, solar, solar panel, 8kva inverter', '[{\"title\":\"Lithium Battery\",\"detail\":\"15kwh\"},{\"title\":\"Solar Panel\",\"detail\":\"600W\"},{\"title\":\"Solar Inverter\",\"detail\":\"8kva\"}]', NULL),
(30, '3000W Solar Inverter Package with 1Tubular Battery & 1 Solar Panel', 'Complete Solar System', 14, 650000.00, 'uploads/image_main_6967d37504c224.36021861.jpg', '3000W Solar Inverter Power System – Complete Solar Package\r\n\r\nA reliable starter solar power system designed to deliver steady, clean electricity for everyday home and office needs, keeping your essential devices running, ensuring comfort and productivity during power outages.\r\n\r\nPackage Includes:\r\n* 1 Sachet Inverter (3000w),\r\n* 1 unit of 22ah Battery, \r\n* 1 Charger Controller,\r\n* 1 unit of 450w solar panel. \r\n\r\nBenefits:\r\n* Silent operation, no fuel cost\r\n* Low maintenance and energy efficient\r\n* Upgradeable as your power needs grow\r\n\r\nCan power - charging phones, lights, fan, laptop, TV & decoder\r\nRecommended - self contained - 2 bedroom apartment \r\n', '2026-01-14 17:34:52', 'uploads/image_1_6967d37504e1d9.50218208.jpg', 'uploads/image_2_6967d37504f0f4.93289660.jpg', 'uploads/image_3_6967d37504fc94.17375935.jpg', 0, 'Other', 'solar energy, inverter, 3000w, power, solar, solar panel, 3000w inverter', '[{\"title\":\"Tubular Battery\",\"detail\":\"220Ah\"},{\"title\":\"Solar Panel\",\"detail\":\"450W\"},{\"title\":\"Solar Inverter\",\"detail\":\"3000W\"}]', NULL),
(31, '1000W Solar Generator', 'Complete Solar System', 14, 350000.00, 'uploads/image_main_6967d5b6994820.90350667.jpg', '1000w Solar Generator \r\n\r\nA compact and reliable 1000W solar generator designed to provide steady electricity for light home use. Ideal for self-contained 1-bedroom apartments, offering a clean and quiet alternative to fuel generators.\r\n\r\nCan power:\r\n* Phone charging\r\n* Lights\r\n* Fan\r\n\r\nBenefits:\r\n* Quiet operation\r\n* Easy to use\r\n* No fuel or fumes\r\n* Suitable for basic daily power needs\r\n\r\nPerfect for homes looking for an affordable and simple solar backup solution.', '2026-01-14 17:43:18', NULL, 'uploads/image_2_6967d5b6997a82.10943518.jpg', NULL, 0, 'Other', 'solar energy, inverter, 1000w, power, solar, solar panel, 1000w solar generator, generator', '[{\"title\":\"Battery\",\"detail\":\"1.25kwh\"},{\"title\":\"Solar System Voltage\",\"detail\":\"12v\"},{\"title\":\"Maximum\",\"detail\":\"30amps\"}]', NULL),
(37, '4 Eyes Solar Street Light', 'Solar Street Lights', 17, 32400.00, 'uploads/image_main_696a66461c1b47.51250306.jpg', '4-Eye Solar Street Light – High-Brightness Outdoor Lighting Solution\r\n\r\nThis solar street light is a reliable and cost-effective lighting option for outdoor spaces, providing strong illumination without electricity or wiring. It is designed for security, visibility, and long-term outdoor use.\r\n\r\nKey Benefits:\r\n\r\n* Four-eye LED design delivers brighter and wider light coverage\r\n* 100% solar powered – no electricity bills\r\n* Automatic charging in the daytime and lighting at night\r\n* Durable and weather-resistant for outdoor conditions\r\n* Easy installation – no wiring or electrician needed\r\n\r\nRecommended Usage:\r\n\r\nIdeal for residential compounds, estates, streets, schools, farms, and commercial outdoor areas', '2026-01-17 10:32:43', 'uploads/image_1_696a66461c3877.96302087.jpg', 'uploads/image_2_696a667ad1c2b4.90884864.jpg', 'uploads/image_3_696a66461c4ab5.66245838.jpg', 0, 'KTJ', 'Solar Lights, 4 Eye, Street Light, Outdoor Light, Light', '[{\"title\":\" LED Light\",\"detail\":\"High-Lumen 4-eye LED array of wide-area illumination\"},{\"title\":\"Sensor\",\"detail\":\"Daylight Sensor, motion sensor\"},{\"title\":\"Resistance\",\"detail\":\"Water Resistance\"},{\"title\":\"Remote Control\",\"detail\":\"Wireless control\"},{\"title\":\"Power Source & Battery\",\"detail\":\"Built-in solar panel with rechargeable lithium battery for all-night lighting without electricity or wiring. g\"}]', NULL),
(38, '3 Eyes Solar Street Light', 'Solar Street Lights', 17, 33700.00, 'uploads/image_main_696a79022db4e4.97667800.jpg', '3-Eye Solar Street Light – Efficient Outdoor Lighting Solution\r\n\r\nThis 3-eye solar street light uses high-efficiency monocrystalline materials. The solar panels maximize the conversion of sunlight into electricity.\r\n\r\nThe applications for this solar-powered outdoor lighting are endless. They can be used for security and safety lighting, rural area illumination, dock lights, park lighting, parking lot lighting, parkway and walkway lighting, street lighting, transit lighting, and general outdoor area lighting.\r\n\r\nMoreover, the reduced costs associated with trenching and underground wiring make this solar street light a more economically feasible option, providing a cost-effective alternative for large outdoor areas.', '2026-01-17 10:33:09', 'uploads/image_1_696a79022dcaa0.51518350.jpg', 'uploads/image_2_696a79022ddbf7.15375467.jpg', 'uploads/image_3_696a79022dec80.11541603.jpg', 0, 'KTJ', 'Solar Lights, 3 Eye, Street Light, Outdoor Light, Light', '[{\"title\":\"Led Brightness\",\"detail\":\"ultra-bright LEDs producing 6000+ lumens for strong outdoor lighting and security.       \"},{\"title\":\"Smart Sensor System\",\"detail\":\" Built-in light and motion sensors detect movement up to 8\\u201312m, switching from dim to full brightness automatically.\"},{\"title\":\"Waterproof Rating\",\"detail\":\"Reliable performance in rain, heat, and harsh outdoor conditions.              \"},{\"title\":\"Solar Power System\",\"detail\":\" High-efficiency solar panel charges fully in 6\\u20137 hours for zero electricity cost.                 \"}]', NULL),
(39, '5 Eyes Solar Street Light', 'Solar Street Lights', 17, 42800.00, 'uploads/image_main_696b6963f1c840.39324408.jpg', '\r\n5 Eyes Solar Street Lights – Powerful All-in-One Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion into electricity — delivering reliable, off-grid lighting that’s perfect for virtually any outdoor space. Monocrystalline solar cells are known for excellent energy conversion and better performance even under low sunlight conditions, making them ideal for areas with inconsistent sun exposure.\r\n\r\nThe 5 Eyes Solar Street Light integrates five high-output LED modules (“eyes”) with a built-in solar panel, battery, controller, and motion/light sensors into one compact unit — eliminating the need for wiring, trenching, or grid electricity. Its rugged, weather-proof design (typically IP65-rated) ensures long-lasting performance in harsh outdoor environments, including heavy rain and dust. \r\n\r\nApplications:\r\nThe applications for solar powered outdoor lighting systems are endless. \r\n\r\nThese units can be used for:\r\n\r\n*Security and Safety Lighting — Illuminate perimeters, compounds, and critical access points for enhanced visibility at night.\r\n\r\n*Rural Area Lighting — Bring dependable lighting to off-grid communities and remote roadways.\r\n\r\n*Street & Walkway Lighting — Light up roads, paths, and neighborhood streets without costly grid infrastructure.\r\n\r\n*Parking Lot & Transit Lighting — Provide safe, energy-efficient illumination for vehicles, stations, and stops.\r\n\r\n*Parks, Gardens & Outdoor Areas — Brighten recreation areas, public spaces, and outdoor event zones.\r\n\r\n*Commercial & Industrial Sites — Ensure secure operations and work areas with dependable nighttime lighting.\r\n\r\nThe 5 Eyes Solar Street Light is a cost-effective outdoor lighting solution, especially where trenching and installing underground wiring often make conventional lighting systems expensive. Solar street lights greatly reduce installation costs and eliminate ongoing electricity bills, making them an economically feasible option for modern outdoor lighting needs.\r\n', '2026-01-17 10:50:11', NULL, NULL, NULL, 0, 'KTJ', 'Solar Lights, 5 Eye, Street Light, Outdoor Light, Light', '[{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"Premium monocrystalline cells convert sunlight to energy with maximum efficiency, charging even on partially cloudy days.\"},{\"title\":\"Powerful Multi-LED Illumination\",\"detail\":\" Five separate LED arrays produce bright, wide-area lighting while remaining energy efficient.\"},{\"title\":\"All-in-One Design\",\"detail\":\"Solar panel, battery, controller, and LEDs come in a single unit for simple installation and low maintenance.\"},{\"title\":\"Smart Controls\",\"detail\":\"Auto dusk-to-dawn light sensor and optional motion sensor modes improve energy savings by adjusting illumination based on presence\\/activity.\"},{\"title\":\"Durable & Weather-Proof\",\"detail\":\"Built to withstand outdoor conditions and long term use with minimal upkeep.\"}]', NULL),
(40, 'Y8 Solar Street Light', 'Solar Street Lights', 17, 28500.00, 'uploads/image_main_696b6d263219f9.08022339.jpg', 'Y8 Solar Street Light – Advanced All-in-One Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion to electricity — delivering dependable performance even on cloudy days and reducing reliance on grid power. The Y8 Solar Street Light is designed as a fully integrated solar lighting system, combining the solar panel, LED lights, battery, and intelligent controller into a single durable unit for easy installation and low maintenance.\r\n\r\nApplications\r\nThe applications for solar powered outdoor lighting systems are endless. These units can be used for:\r\n\r\n* Security and Safety Lighting — Illuminate home perimeters, entrances, and dark corners to deter intruders.\r\n\r\n* Rural Area Lighting — Bring dependable lighting to off-grid communities and remote roadways.\r\n\r\n* Dock Lights & Parkway Lighting — Provide visibility along water edges and road corridors.\r\n\r\n* Park & Walkway Lighting — Brighten public parks, pathways, and pedestrian areas for safer night-time use.\r\n\r\n* Parking Lot & Transit Lighting — Ideal for lighting expansive outdoor lots, transit stops, and commercial spaces.\r\n\r\n* Outdoor Area Lighting — Enhance visibility around estates, campuses, compounds, and business environments.\r\n\r\nThe costs of trenching and installing underground wiring often make a solar street lighting system an economically feasible lower cost option — eliminating electricity bills and offering a sustainable lighting solution for both urban and rural outdoor spaces.\r\n', '2026-01-17 11:06:14', 'uploads/image_1_696b6d26322ef5.82089247.jpeg', 'uploads/image_2_696b6d26323ff9.49821930.jpeg', 'uploads/image_3_696b6d26324f84.59018614.jpeg', 0, 'KTJ', 'Solar Lights, Y8, Street Light, Outdoor Light, Light', '[{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"  Captures sunlight effectively throughout the day and converts it into stored energy for night-time illumination.\"},{\"title\":\"Integrated LED Lighting\",\"detail\":\"Bright LED output with long lifespan (up to ~80,000 hours), offering powerful illumination while remaining energy efficient.\"},{\"title\":\"Smart Controls\",\"detail\":\"Auto dusk-to-dawn light sensor and optional motion sensor modes improve energy savings by adjusting illumination based on presence\\/activity.\"},{\"title\":\"Durable & Weather-Proof\",\"detail\":\"Designed to withstand outdoor conditions with anti-rust and anti-corrosion components for long-term use in harsh environments.   \"},{\"title\":\"Easy Installation\",\"detail\":\"All-in-one design eliminates complex wiring or trenching \\u2014 install quickly on poles or walls for immediate lighting coverage.\"}]', NULL),
(41, 'Y10 Solar Street Light', 'Solar Street Lights', 17, 31100.00, 'uploads/image_main_696b72bc6a2059.97320661.jpg', 'Y10 Solar Street Light – Innovative All-In-One Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion to electricity — providing dependable, eco-friendly lighting without the need for grid power or complex wiring. The Y10 Solar Street Light combines a high-efficiency solar panel, powerful LED lighting, long-life battery, and intelligent controller into one compact and durable unit that charges by day and illuminates throughout the night.\r\n\r\nApplications\r\nThe applications for solar powered outdoor lighting systems are endless. These units can be used for:\r\n\r\n* Security and Safety Lighting — Illuminate homes, perimeters, entrances, and dark corners for enhanced visibility and protection.\r\n\r\n* Rural Area Lighting — Provide reliable lighting for off-grid roads and villages where conventional electricity is unavailable.\r\n\r\n* Dock Lights & Parkway Lighting — Ensure safe navigation and visibility in waterfront areas and alongside roadways.\r\n\r\n* Park & Walkway Lighting — Brighten parks, pedestrian paths, and public spaces for safer evening use.\r\n\r\n* Parking Lot & Transit Lighting — Ideal for lighting outdoor parking areas and transit hubs without costly infrastructure.\r\n\r\n* Outdoor Area Lighting — Excellent solution for commercial compounds, campuses, estates, and community spaces.\r\n\r\nThe costs of trenching and installing underground wiring often make a solar street lighting system an economically feasible lower cost option — offering significant savings on installation and ongoing electricity expenses while delivering sustainable, autonomous outdoor illumination.', '2026-01-17 12:36:19', 'uploads/image_1_696b72bc6a3492.51174924.jpeg', 'uploads/image_2_696b72bc6a4428.55714092.jpeg', NULL, 0, 'KTJ', 'Solar Lights, Y10, Street Light, Outdoor Light, Light', '[{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"Integrated monocrystalline solar panel captures maximum solar energy daily and converts it efficiently into stored power for nighttime illumination.\"},{\"title\":\"Bright LED Output\",\"detail\":\"Approximately 10W LED output with a luminous flux typically between 1200\\u20131400 lumens, delivering clear, bright light for outdoor spaces.\"},{\"title\":\"All-In-One Design\",\"detail\":\"Combines the solar panel, LED lamp, controller, and battery into a single compact unit \\u2014 making installation quick and eliminating the need for trenching or electrical connections.\"},{\"title\":\"Long-Lasting Battery\",\"detail\":\"Rugged construction ensures the system withstands sun, rain, dust, and varying outdoor conditions with minimal maintenance needs.\"},{\"title\":\"Easy Installation\",\"detail\":\"Designed for both pole and wall mounting, offering versatility for residential, commercial, and rural setups.\"}]', NULL),
(42, 'Y28 Solar Street Light', 'Solar Street Lights', 17, 55800.00, 'uploads/image_main_696b755934f8b6.35488423.jpg', 'Y24 Solar Street Light – Advanced Integrated Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion to electricity — delivering reliable off-grid performance and lower energy costs. The Y24 Solar Street Light integrates a premium monocrystalline solar panel, powerful LED light source, deep-cycle lithium battery, and intelligent controller in one sleek, durable unit built for all-weather outdoor use. Systems like this are designed with IP65-grade weather resistance for dependable performance through rain, sun, and dust conditions.\r\n\r\nApplications\r\nThe applications for solar powered outdoor lighting systems are endless. These units can be used for:\r\n\r\n* Security and Safety Lighting — Illuminate homes, compounds, and perimeter walls for added safety.\r\n\r\n* Rural Area Lighting — Bring bright, reliable lighting to off-grid communities and remote roads.\r\n\r\n* Dock Lights & Parkway Lighting — Ensure visibility along waterfronts and road corridors.\r\n\r\n* Park & Walkway Lighting — Brighten public parks, pedestrian paths, and residential walkways.\r\n\r\n* Parking Lot & Transit Lighting — Suitable for outdoor parking areas, bus stops, and transit hubs.\r\n\r\n* Outdoor Area Lighting — Ideal for commercial compounds, campuses, estates, and public spaces.\r\n\r\nThe costs of trenching and installing underground wiring often make a solar street lighting system an economically feasible lower cost option — eliminating ongoing electricity bills, reducing infrastructure expenses, and providing sustainable, autonomous outdoor illumination for any location.', '2026-01-17 12:35:55', NULL, 'uploads/image_2_696b7559351349.19574143.jpg', NULL, 0, 'KTJ', 'Solar Lights, Y28, Street Light, Outdoor Light, Light', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Captures maximum sunlight throughout the day and converts it into stored energy for night lighting.\"},{\"title\":\"Bright LED Illumination\",\"detail\":\"Delivers crisp, high-output lighting suitable for streets and expansive outdoor areas.\"},{\"title\":\"Integrated All-In-One Design\",\"detail\":\"Combines the solar module, LED array, battery pack, and controller into a single durable assembly, eliminating wiring hassles and reducing installation costs.\"},{\"title\":\"Smart Controller\",\"detail\":\"Smart control enables auto dusk-to-dawn operation.\"},{\"title\":\"Long-Lasting Battery\",\"detail\":\"Built-in lithium battery stores energy efficiently and powers the light through the night.\"},{\"title\":\"Weather-Proof Durability\",\"detail\":\"Rugged IP65 design ensures resilience in outdoor environments, maintaining performance through heavy rains and dust.\"},{\"title\":\"Easy Installation\",\"detail\":\"Mount on poles or walls quickly without complex electrical work.\"}]', NULL),
(43, '2 Eyes Solar Street Light', 'Solar Street Lights', 17, 30000.00, 'uploads/image_main_696b7b60b89555.70231868.jpg', '2 Eyes Solar Street Light – Efficient Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion to electricity — providing dependable off-grid performance with zero electricity costs. The 2 Eyes Solar Street Light typically features a dual-LED integrated design with a solar panel and battery built into one unit, making it ideal for easy installation on poles or walls without complex wiring. Many 2 eyes solar street lights also include automatic dusk-to-dawn operation and motion sensor functionality to maximize energy savings and security lighting performance.\r\n\r\nApplications\r\nThe applications for solar powered outdoor lighting systems are endless. These units can be used for:\r\n\r\n* Security and Safety Lighting — Illuminate perimeters and access points for enhanced visibility at night.\r\n\r\n* Rural Area Lighting — Provide dependable lighting for roads and communities with limited or no grid access.\r\n\r\n* Dock Lights & Parkway Lighting — Brighten waterfront areas and road corridors for improved nighttime visibility.\r\n\r\n* Park & Walkway Lighting — Enhance safety and ambiance in parks, pedestrian paths, and public spaces.\r\n\r\n* Parking Lot & Transit Lighting — Ideal for illuminating outdoor parking spaces, transit stops, and stations.\r\n\r\n* Outdoor Area Lighting — Suitable for estates, campuses, compounds, gardens, and recreational grounds.\r\n\r\nThe costs of trenching and installing underground wiring often make a solar street lighting system an economically feasible lower cost option — eliminating ongoing electricity bills and significantly reducing installation expenses while delivering sustainable, reliable lighting for almost any outdoor location.\r\n', '2026-01-17 12:35:32', NULL, 'uploads/image_2_696b7b60b8ad44.52529526.jpg', NULL, 0, 'KTJ', 'Solar Lights, 2 Eye, Street Light, Outdoor Light, Light', '[{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"Advanced monocrystalline panel efficiently absorbs sunlight throughout the day and converts it into stored energy for night-time illumination.\"},{\"title\":\"Dual LED Light Heads (\\u201c2 Eyes\\u201d)\",\"detail\":\"Two high-output LED modules provide enhanced lighting coverage with bright, energy-efficient illumination for outdoor environments.\"},{\"title\":\"All-In-One Design\",\"detail\":\"Combines the solar panel, LEDs, lithium battery, and intelligent controller into a single unit, minimizing installation time and costs.\"},{\"title\":\"Smart Lighting Controls\",\"detail\":\"Automatic light sensor switches the unit on at dusk and off at dawn, while motion detection ramps up brightness when movement is detected.\"},{\"title\":\"Weather-Proof & Durable\",\"detail\":\"Built with rugged, waterproof (IP65-rated) materials to withstand rain, dust, and harsh outdoor conditions.\"}]', NULL),
(44, 'J3 Industrial Solar Street Light', 'Solar Street Lights', 17, 70000.00, 'uploads/image_main_696b81f0af7109.16076544.jpg', 'J3 Industrial Solar Street Light – Heavy-Duty Outdoor Solar Lighting Solution\r\n\r\nThis solar lights outdoor state-of-the-art and weather-proof solar panel uses high-efficiency monocrystalline material that optimizes sunlight conversion to electricity, delivering strong and reliable off-grid illumination for industrial and large outdoor environments.\r\nThe J3 Industrial Solar Street Light features a separate high-capacity solar panel and a rugged aluminum alloy lamp body, designed to collect maximum solar energy during the day and provide consistent lighting throughout the night.\r\n\r\nThis model is equipped with three high-power LED lighting modules, offering wider light spread and higher brightness compared to standard single-head solar street lights. The robust industrial casing is built to withstand harsh weather conditions, making it suitable for long-term outdoor use. The system includes intelligent light control and a remote control, allowing users to adjust lighting modes, brightness levels, and timing functions with ease.\r\n\r\nThe applications for solar powered outdoor lighting systems are endless. These units can be used for:\r\nSecurity and safety lighting, rural area lighting, dock lights, park lighting, parking lot lighting, parkway lighting, walkway lighting, street lighting, transit lighting, and general outdoor area lighting such as estates, factories, warehouses, schools, churches, construction sites, and industrial compounds.\r\n\r\nThe costs of trenching and installing underground wiring often make a solar street lighting system an economically feasible lower-cost option. The J3 Industrial Solar Street Light eliminates the need for grid electricity, reduces installation complexity, and removes ongoing power bills — making it an ideal solution for both urban and off-grid locations.', '2026-01-17 12:34:56', 'uploads/image_1_696b81f0af8655.18317996.jpg', 'uploads/image_2_696b81f0af99b0.68269138.jpg', NULL, 0, 'KTJ', 'Solar Lights, J3, Street Light, Outdoor Light, Light, Industrial Street Light', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Separate, large-surface monocrystalline solar panel designed to capture maximum sunlight and convert it efficiently into stored energy for reliable night-time lighting.\"},{\"title\":\"Industrial-Grade All-Weather Design\",\"detail\":\"Built with a rugged aluminum alloy housing and weather-resistant construction, suitable for continuous outdoor use in harsh environments such as rain, heat, and dust.\"},{\"title\":\"Three High-Power LED Modules\",\"detail\":\"Equipped with three independent LED lighting heads that deliver wide light coverage and high brightness, making it ideal for large roads, compounds, and industrial areas.\"},{\"title\":\"Integrated Rechargeable Battery System\",\"detail\":\"Built-in high-capacity battery stores solar energy during the day and powers the light automatically at night without grid electricity.\"},{\"title\":\"Intelligent Light Control (Dusk-to-Dawn)\",\"detail\":\"Automatically switches ON at sunset and OFF at sunrise, ensuring efficient energy management and hands-free operation.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Comes with a remote control that allows adjustment of lighting modes, brightness levels, and timing functions for flexible usage based on location needs.\"},{\"title\":\"Wide Area Light Distribution\",\"detail\":\"Designed to illuminate a broader area compared to standard single-head solar street lights, improving visibility and safety.\"},{\"title\":\"Easy Installation \\u2013 No Trenching or Wiring\",\"detail\":\"Wall or pole-mount installation with no underground wiring required, significantly reducing installation time and cost.\"}]', NULL),
(45, '100W Outdoor/Indoor Solar Flood Light ', 'Flood Lights', 18, 28500.00, 'uploads/image_main_696b852a75d159.02098359.jpg', '100W Outdoor/Indoor Solar Flood Light – Powerful & Versatile Solar Lighting Solution\r\n\r\nThis 100W Outdoor/Indoor Solar Flood Light is a high-performance, weather-resistant solar lighting solution designed to deliver bright, reliable illumination for both residential and commercial spaces. It uses a high-efficiency monocrystalline solar panel that effectively converts sunlight into electricity, ensuring dependable lighting without reliance on grid power.\r\n\r\nThe system features a separate solar panel and LED floodlight unit, allowing flexible installation for optimal sun exposure and maximum charging efficiency. During the day, the solar panel charges the built-in long-life battery, while at night the powerful LED array provides strong, wide-angle illumination. The floodlight is built with a durable, weather-proof housing, making it suitable for long-term outdoor use in varying weather conditions.\r\n\r\nThis model comes with an intelligent controller and remote control, enabling users to easily switch the light ON/OFF, adjust brightness levels, and set lighting modes and timing functions for convenience and energy efficiency. Its ability to function both outdoor and indoor makes it a versatile lighting option for many environments.\r\n\r\nApplications\r\n\r\nThe applications for solar powered flood lighting systems are wide and flexible. This unit can be used for:\r\n\r\n * Security & Safety Lighting — Ideal for lighting compounds, entrances, perimeters, and dark areas to improve visibility and deter intruders.\r\n\r\n * Outdoor Area Lighting — Suitable for yards, gardens, streets, parking spaces, shops, and open commercial areas.\r\n\r\n * Indoor Backup Lighting — Can be used inside warehouses, halls, shops, and workshops where solar-powered backup lighting is required.\r\n\r\n * Rural & Off-Grid Lighting — Provides reliable lighting in areas without access to stable electricity.\r\n\r\n * Commercial & Estate Lighting — Perfect for schools, churches, estates, factories, and construction sites.\r\n\r\nBy eliminating the need for trenching, wiring, and grid electricity, the 100W Solar Flood Light offers a cost-effective, eco-friendly lighting solution with zero electricity bills and minimal maintenance — making it a smart choice for dependable illumination anytime, anywhere.', '2026-01-19 09:40:03', 'uploads/image_1_696b873d56c7a4.55636708.jpg', 'uploads/image_2_696b873d56ef44.56615056.jpg', NULL, 0, 'KTJ', 'Solar Lights, 100W, Street Light, Outdoor Light, Light, Flood Light', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Comes with a separate monocrystalline solar panel designed to efficiently convert sunlight into energy, ensuring reliable charging and consistent night-time lighting.\"},{\"title\":\"Powerful 100W LED Flood Light\",\"detail\":\" Fitted with high-brightness LED chips arranged for wide and uniform light distribution, suitable for illuminating large indoor and outdoor spaces.\"},{\"title\":\"Indoor & Outdoor Versatility\",\"detail\":\" Designed for both indoor and outdoor use \\u2014 ideal where grid electricity is unavailable or unreliable.\"},{\"title\":\"Separate Panel Design for Better Placement\",\"detail\":\"The external solar panel allows flexible installation to maximize sunlight exposure, while the floodlight can be mounted exactly where illumination is needed.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Supplied with a remote control for convenient ON\\/OFF operation, brightness adjustment, and timer settings without manual switching.\"},{\"title\":\"Automatic Dusk-to-Dawn Function\",\"detail\":\"Built-in intelligent light sensor\"}]', NULL);
INSERT INTO `products` (`id`, `name`, `category`, `category_id`, `price`, `image_main`, `description`, `created_at`, `image_1`, `image_2`, `image_3`, `is_featured`, `brand`, `tags`, `specifications`, `sub_category_id`) VALUES
(46, '200W Outdoor/Indoor Solar Flood Light', 'Flood Lights', 18, 35000.00, 'uploads/image_main_696dfe1ece8f80.57351882.jpg', '200W Outdoor/Indoor Solar Flood Light – High-Brightness Solar Lighting for Large Spaces\r\n\r\nThe 200W Outdoor/Indoor Solar Flood Light is a high-capacity solar lighting solution engineered to deliver very bright, wide-area illumination for demanding residential, commercial, and industrial applications. It is powered by a high-efficiency monocrystalline solar panel that maximizes sunlight conversion, ensuring reliable off-grid lighting without dependence on public electricity.\r\n\r\nThis model features a separate solar panel and floodlight design, allowing optimal panel placement for maximum charging while the light unit is positioned for best coverage. The integrated long-life rechargeable battery stores sufficient energy during the day to power the high-output LED floodlight throughout the night. Its robust, weather-proof housing is built to withstand rain, heat, and dust, making it suitable for continuous outdoor use.\r\n\r\nEquipped with an intelligent lighting controller and remote control, the 200W Solar Flood Light allows easy adjustment of brightness levels, lighting modes, and timing functions. The high-density LED array produces a stronger and wider light spread than lower-wattage models, making it ideal for lighting larger areas both outdoors and indoors where powerful illumination is required.\r\n\r\nApplications\r\n\r\nThe applications for solar powered flood lighting systems are extensive. This unit can be used for:\r\n\r\n * Security & Safety Lighting — Brightly illuminate large compounds, perimeters, warehouses, and entrances for improved security.\r\n\r\n * Outdoor Area Lighting — Ideal for parking lots, streets, open yards, markets, and commercial premises.\r\n\r\n * Indoor Solar Lighting — Suitable for halls, factories, workshops, shops, and storage facilities needing strong solar backup lighting.\r\n\r\n * Rural & Off-Grid Lighting — Provides dependable lighting in locations without access to stable grid power.\r\n\r\n * Commercial & Institutional Lighting — Perfect for schools, churches, estates, event centers, construction sites, and industrial environments.\r\n\r\nBy removing the need for underground wiring, fuel generators, or grid electricity, the 200W Outdoor/Indoor Solar Flood Light offers a cost-effective, eco-friendly, and low-maintenance lighting solution with zero electricity bills—delivering powerful illumination wherever it is needed most.', '2026-01-19 09:49:51', 'uploads/image_1_696dfe1eceab99.99380728.jpeg', 'uploads/image_2_696dfe1ecec879.39812794.jpeg', 'uploads/image_3_696dfe1ecedea9.21725540.jpeg', 0, 'KTJ', 'Solar Lights, 200W, Street Light, Outdoor Light, Light, Flood Light', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Comes with a separate monocrystalline solar panel designed to efficiently convert sunlight into energy, ensuring reliable charging and consistent night-time lighting.\"},{\"title\":\"Powerful 200W LED Flood Light\",\"detail\":\" Fitted with high-brightness LED chips arranged for wide and uniform light distribution, suitable for illuminating large indoor and outdoor spaces.\"},{\"title\":\"Indoor & Outdoor Versatility\",\"detail\":\" Designed for both indoor and outdoor use \\u2014 ideal where grid electricity is unavailable or unreliable.\"},{\"title\":\"Separate Panel Design for Better Placement\",\"detail\":\"The external solar panel allows flexible installation to maximize sunlight exposure, while the floodlight can be mounted exactly where illumination is needed.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Supplied with a remote control for convenient ON\\/OFF operation, brightness adjustment, and timer settings without manual switching.\"},{\"title\":\"Automatic Dusk-to-Dawn Function\",\"detail\":\"Built-in intelligent light sensor\"}]', NULL),
(47, '300W Outdoor/Indoor Solar Flood Light', 'Flood Lights', 18, 53200.00, 'uploads/image_main_696e00712133e5.30237556.jpg', '300W Outdoor/Indoor Solar Flood Light – Ultra-High Power Solar Lighting for Maximum Coverage\r\n\r\nThe 300W Outdoor/Indoor Solar Flood Light is a heavy-duty, ultra-bright solar lighting solution designed for very large spaces where maximum illumination and reliability are required. It is powered by a high-efficiency monocrystalline solar panel that captures and converts sunlight efficiently, delivering strong, consistent lighting without dependence on grid electricity.\r\n\r\nThis model features a separate large-capacity solar panel and floodlight unit, allowing optimal panel positioning for faster charging and higher energy storage. The built-in high-capacity lithium battery stores sufficient energy during the day to power the floodlight throughout the night, even in demanding environments. The floodlight housing is rugged and weather-proof, built to withstand rain, dust, and harsh outdoor conditions for long-term use.\r\n\r\nEquipped with a smart lighting controller and remote control, the 300W Solar Flood Light allows users to adjust brightness levels, lighting modes, and operating time with ease. Its high-density LED array delivers an extremely wide light spread and higher brightness than lower-wattage models, making it ideal for lighting expansive areas both outdoors and indoors.\r\n\r\nApplications\r\n\r\nThe applications for solar powered flood lighting systems are extensive. This unit is ideal for:\r\n\r\n* High-Security & Safety Lighting — Bright illumination for large compounds, perimeters, warehouses, and industrial premises.\r\n\r\n* Large Outdoor Area Lighting — Suitable for parking lots, open fields, streets, markets, and commercial outdoor spaces.\r\n\r\n* Indoor High-Power Solar Lighting — Ideal for factories, event halls, workshops, warehouses, and storage facilities.\r\n\r\n* Rural & Off-Grid Lighting — Reliable lighting solution for remote locations without access to stable electricity.\r\n\r\n* Commercial, Industrial & Institutional Lighting — Perfect for estates, schools, churches, factories, construction sites, and industrial compounds.\r\n\r\nBy eliminating trenching, complex wiring, fuel generators, and grid electricity costs, the 300W Outdoor/Indoor Solar Flood Light provides a cost-effective, eco-friendly, and low-maintenance lighting solution—delivering powerful, dependable illumination where conventional power is unreliable or unavailable.', '2026-01-19 09:59:13', 'uploads/image_1_696e0071214722.18358986.jpeg', 'uploads/image_2_696e0071215a80.79111263.jpeg', 'uploads/image_3_696e0071216b68.57418734.jpeg', 0, 'KTJ', 'Solar Lights, 300W, Street Light, Outdoor Light, Light, Flood Lights', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Comes with a separate monocrystalline solar panel designed to efficiently convert sunlight into energy, ensuring reliable charging and consistent night-time lighting.\"},{\"title\":\"Powerful 300W LED Flood Light\",\"detail\":\" Fitted with high-brightness LED chips arranged for wide and uniform light distribution, suitable for illuminating large indoor and outdoor spaces.\"},{\"title\":\"Indoor & Outdoor Versatility\",\"detail\":\" Designed for both indoor and outdoor use \\u2014 ideal where grid electricity is unavailable or unreliable.\"},{\"title\":\"Separate Panel Design for Better Placement\",\"detail\":\"The external solar panel allows flexible installation to maximize sunlight exposure, while the floodlight can be mounted exactly where illumination is needed.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Supplied with a remote control for convenient ON\\/OFF operation, brightness adjustment, and timer settings without manual switching.\"},{\"title\":\"Automatic Dusk-to-Dawn Function\",\"detail\":\"Built-in intelligent light sensor\"}]', NULL),
(48, '50W Outdoor/Indoor Solar Flood Light', 'Flood Lights', 18, 28500.00, 'uploads/image_main_696e032f18e9b2.26445087.jpg', '', '2026-01-19 10:10:55', NULL, NULL, NULL, 0, 'KING ON', 'Solar Lights, 50W, Street Light, Outdoor Light, Light, Flood Light', '[{\"title\":\"High-Efficiency Monocrystalline Solar Panel\",\"detail\":\"Comes with a separate monocrystalline solar panel designed to efficiently convert sunlight into energy, ensuring reliable charging and consistent night-time lighting.\"},{\"title\":\"Powerful 50W LED Flood Light\",\"detail\":\" Fitted with high-brightness LED chips arranged for wide and uniform light distribution, suitable for illuminating large indoor and outdoor spaces.\"},{\"title\":\"Indoor & Outdoor Versatility\",\"detail\":\" Designed for both indoor and outdoor use \\u2014 ideal where grid electricity is unavailable or unreliable.\"},{\"title\":\"Separate Panel Design for Better Placement\",\"detail\":\"The external solar panel allows flexible installation to maximize sunlight exposure, while the floodlight can be mounted exactly where illumination is needed.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Supplied with a remote control for convenient ON\\/OFF operation, brightness adjustment, and timer settings without manual switching.\"},{\"title\":\"Automatic Dusk-to-Dawn Function\",\"detail\":\"Built-in intelligent light sensor\"}]', NULL),
(49, ' 4G V380 Dual Lens PTZ Solar Camera (DS-20)', '4G CCTV', 21, 80000.00, 'uploads/image_main_696f62ec56b302.15597689.jpg', '4G V380 Dual Lens Solar PTZ Camera (DS-20)\r\n\r\nThe DS-20 4G V380 Dual Lens Solar PTZ Camera is a powerful, all-in-one outdoor security solution designed for remote and off-grid locations. Built with a dual-lens system, solar-powered operation, and 4G SIM connectivity, this camera delivers reliable surveillance without the need for Wi-Fi or constant electricity.\r\n\r\nEquipped with a high-efficiency solar panel and a built-in rechargeable battery, the DS-20 continuously charges during the day and operates day and night, making it ideal for locations with unstable or no power supply. The 4G LTE support ensures uninterrupted remote monitoring using a SIM card, allowing you to view live footage anytime via the V380 mobile app.\r\n\r\nThe dual-lens design combines a fixed lens for wide-area monitoring and a PTZ lens that supports pan, tilt, and zoom, giving you both broad coverage and focused detail from one device. With intelligent motion detection, the camera automatically tracks human movement and sends instant alerts to your phone.\r\n\r\nFor night surveillance, the DS-20 features full-color night vision supported by white LEDs and infrared LEDs, ensuring clear images even in complete darkness. The camera also supports two-way audio, allowing you to listen and speak remotely, enhancing security and communication.\r\n\r\nDesigned with a weather-proof, rugged outdoor housing, the DS-20 performs reliably in rain, heat, and harsh outdoor conditions—perfect for Nigerian environments.\r\n\r\nIdeal Applications:\r\n\r\n * Homes & residential compounds\r\n\r\n * Farms, farmlands & rural areas\r\n\r\n * Construction sites\r\n\r\n * Warehouses & industrial premises\r\n\r\n * Shops, schools & churches\r\n\r\n * Off-grid locations without electricity or Wi-Fi', '2026-01-20 11:38:15', 'uploads/image_1_696f62ec56d221.25434903.jpg', 'uploads/image_2_696f62ec56e7a3.59834352.jpg', NULL, 0, 'Other', 'DS-20, CCTV, Camera, Indoor/Outdoor Camera, Pan-Tilt-Zoom (PTZ), dual-lens,  4G V380 ', '[{\"title\":\"4G LTE SIM Connectivity (No Wi-Fi Required)\",\"detail\":\"Works perfectly in remote and rural areas without internet infrastructure.\"},{\"title\":\"Dual Lens System (Fixed + PTZ Lens)\",\"detail\":\"Provides wide-angle coverage and detailed zoomed-in monitoring from a single camera.\"},{\"title\":\"Solar Powered with Built-in Rechargeable Battery\",\"detail\":\"Continuous operation without NEPA power; saves electricity and running costs.\"},{\"title\":\"Pan, Tilt & Zoom (PTZ) Control\",\"detail\":\"Remotely rotate and zoom the camera to monitor large areas with ease.\"},{\"title\":\"Full-Color Night Vision & Infrared Mode\",\"detail\":\"Clear visibility at night with color images or infrared in total darkness.\"},{\"title\":\"Intelligent Human Motion Detection & Auto-Tracking\",\"detail\":\"Automatically detects and follows human movement, reducing false alarms.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Listen and talk remotely to visitors, workers, or intruders in real time.\"},{\"title\":\"Remote Viewing via V380 Mobile App\",\"detail\":\"Monitor your property anytime, anywhere using your smartphone.\"},{\"title\":\"SD Card & Cloud Storage Support\",\"detail\":\"Securely store and replay footage whenever needed.\"},{\"title\":\"Weather-Proof Outdoor Design\",\"detail\":\"Reliable performance in rain, heat, and harsh outdoor conditions.\"},{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"Faster charging and longer working time, even on cloudy days.\"}]', NULL),
(50, '4G Ubox Dual Lens PTZ Solar Camera (DS-35)', '4G CCTV', 21, 115000.00, 'uploads/image_main_696f68eb7d6a08.68974824.jpg', '4G UBox Dual Lens PTZ Solar Camera (DS-35)\r\n\r\nThe DS-35 4G UBox Dual Lens PTZ Solar Camera is a high-performance outdoor security camera designed for maximum coverage, smart monitoring, and off-grid operation. It combines dual-lens surveillance, solar-powered efficiency, and 4G SIM connectivity, making it an ideal solution for locations without stable electricity or Wi-Fi.\r\n\r\nThis advanced camera features a dual-lens system that delivers both wide-area monitoring and detailed close-up viewing at the same time. One lens provides a fixed wide-angle view, while the PTZ lens supports remote pan, tilt, and zoom, allowing users to monitor large spaces with precision directly from the UBox mobile app.\r\n\r\nPowered by a high-efficiency external solar panel and a built-in rechargeable battery, the DS-35 charges during the day and operates continuously, ensuring reliable security day and night. With 4G LTE SIM support, the camera connects directly to mobile networks, making it perfect for farms, construction sites, estates, and remote properties.\r\n\r\nFor enhanced security, the DS-35 is equipped with intelligent human motion detection and auto-tracking, instantly alerting you when movement is detected. Its full-color night vision and infrared night vision ensure clear footage even in total darkness. The built-in two-way audio system allows real-time communication, enabling you to warn intruders or speak with visitors remotely.\r\n\r\nBuilt with a rugged, weather-proof outdoor casing, the DS-35 is engineered to withstand harsh weather conditions, delivering dependable performance in demanding environments.\r\n\r\nIdeal Applications:\r\n\r\n* Residential homes & estates\r\n\r\n* Farms & agricultural land\r\n\r\n* Construction sites\r\n\r\n* Warehouses & industrial facilities\r\n\r\n* Schools, churches & commercial premises\r\n\r\n* Remote and off-grid locations', '2026-01-20 11:37:15', 'uploads/image_1_696f68eb7d7ed6.41534611.jpg', 'uploads/image_2_696f68eb7d8c50.45681214.jpg', NULL, 0, 'Other', '4G, CCTV, Dual Lens, PTZ Solar Camera', '[{\"title\":\"4G LTE SIM Connectivity (No Wi-Fi Required)\",\"detail\":\"Enables remote monitoring in areas without internet or fixed network coverage.\"},{\"title\":\"Dual Lens System (Fixed + PTZ Lens)\",\"detail\":\"Allows simultaneous wide-area surveillance and detailed close-up monitoring.\"},{\"title\":\"Solar Powered with Built-in Rechargeable Battery\",\"detail\":\"Ensures uninterrupted operation without reliance on grid power or generators.\"},{\"title\":\"Pan, Tilt & Zoom (PTZ) Functionality\",\"detail\":\"Provides full control to monitor large environments with precision from your phone.\"},{\"title\":\"Intelligent Human Motion Detection & Auto-Tracking\",\"detail\":\"Accurately detects and follows human movement, reducing false alerts.\"},{\"title\":\"Full-Color Night Vision & Infrared Night Vision\",\"detail\":\"Delivers clear, detailed images at night, even in complete darkness.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Enables real-time interaction with visitors or warning of intruders remotely.\"},{\"title\":\"Remote Access via UBox Mobile App\",\"detail\":\"View live footage, playback recordings, and control the camera anytime, anywhere.\"},{\"title\":\"SD Card & Cloud Storage Support\",\"detail\":\"Securely stores video recordings for later review and evidence.\"},{\"title\":\"Weather-Proof Outdoor Housing\",\"detail\":\"Reliable performance in rain, heat, and harsh outdoor environments.\"},{\"title\":\"High-Efficiency External Solar Panel\",\"detail\":\"Faster charging and longer operating time, even during cloudy days.\"}]', NULL),
(51, '4G Ubox Dual Lens PTZ Solar Camera (DS-40)', '4G CCTV', 21, 130000.00, 'uploads/image_main_696f6e12dc2bc1.55115729.jpg', '4G UBox Dual Lens PTZ Solar Camera (DS-40)\r\n\r\nThe DS-40 4G UBox Dual Lens PTZ Solar Camera is a premium outdoor surveillance solution engineered for wide-area coverage, intelligent monitoring, and complete off-grid operation. Designed for environments where power supply and Wi-Fi are unreliable or unavailable, the DS-40 delivers dependable, high-quality security using solar energy and 4G mobile connectivity.\r\n\r\nThis advanced camera features a dual-lens configuration that combines a fixed wide-angle lens for constant area monitoring with a PTZ (Pan-Tilt-Zoom) lens that allows precise, remote control viewing. This dual-view capability ensures you never miss critical activity while still being able to zoom in on important details—all managed through the UBox mobile app.\r\n\r\nPowered by a high-efficiency solar panel and an integrated rechargeable battery, the DS-40 charges automatically during daylight hours and operates continuously day and night. The 4G SIM card support allows seamless remote access without relying on local internet networks, making it ideal for farms, estates, construction sites, and other remote properties.\r\n\r\nFor enhanced security, the DS-40 supports intelligent human motion detection and auto-tracking, instantly notifying you of suspicious movement while minimizing false alerts. Its full-color night vision combined with infrared night vision ensures clear visibility even in low-light or complete darkness. The built-in two-way audio system enables real-time communication, allowing you to speak to visitors or deter intruders remotely.\r\n\r\nBuilt with a durable, weather-proof outdoor housing, the DS-40 is designed to withstand rain, heat, and harsh environmental conditions, ensuring long-term reliability and performance.\r\n\r\nIdeal Applications:\r\n\r\n* Residential homes & gated estates\r\n\r\n* Farms, ranches & agricultural land\r\n\r\n* Construction and project sites\r\n\r\n* Warehouses & industrial facilities\r\n\r\n* Schools, churches & commercial buildings\r\n\r\n* Remote and off-grid locations', '2026-01-20 11:59:14', 'uploads/image_1_696f6e12dc4377.47912964.jpg', 'uploads/image_2_696f6e12dc57e5.09745735.jpg', NULL, 0, 'Other', 'Dual Lens, PTZ Solar Camera, DS-40, CCTV Camera, 4G Ubox', '[{\"title\":\"4G LTE SIM Connectivity (No Wi-Fi Required)\",\"detail\":\"Works perfectly in remote and rural areas without internet infrastructure.\"},{\"title\":\"Dual Lens System (Fixed + PTZ Lens)\",\"detail\":\"Provides wide-angle coverage and detailed zoomed-in monitoring from a single camera.\"},{\"title\":\"Solar Powered with Built-in Rechargeable Battery\",\"detail\":\"Continuous operation without NEPA power; saves electricity and running costs.\"},{\"title\":\"Pan, Tilt & Zoom (PTZ) Control\",\"detail\":\"Remotely rotate and zoom the camera to monitor large areas with ease.\"},{\"title\":\"Full-Color Night Vision & Infrared Mode\",\"detail\":\"Clear visibility at night with color images or infrared in total darkness.\"},{\"title\":\"Intelligent Human Motion Detection & Auto-Tracking\",\"detail\":\"Automatically detects and follows human movement, reducing false alarms.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Listen and talk remotely to visitors, workers, or intruders in real time.\"},{\"title\":\"Remote Viewing via Ubox Mobile App\",\"detail\":\"Monitor your property anytime, anywhere using your smartphone.\"},{\"title\":\"SD Card & Cloud Storage Support\",\"detail\":\"Securely store and replay footage whenever needed.\"},{\"title\":\"Rugged Weather-Proof Outdoor Housing\",\"detail\":\"Reliable performance in rain, heat, and harsh outdoor conditions.\"},{\"title\":\"High-Efficiency Solar Panel\",\"detail\":\"Faster charging and longer working time, even on cloudy days.\"}]', NULL),
(52, 'Single Lens PTZ Bulb Camera (CS-100)', 'WIFI CCTV', 23, 25000.00, 'uploads/image_main_696f774d624388.70438737.jpg', 'Single Lens PTZ Bulb Camera (CS-100)\r\n\r\nThe Single Lens PTZ Bulb Camera is a smart, all-in-one security solution designed for easy installation and full-area surveillance. Shaped like a regular light bulb, this camera fits directly into a standard E27 bulb socket—no complex wiring, no drilling, no professional installation required.\r\n\r\nDespite its compact design, the camera delivers powerful 360° monitoring, intelligent motion detection, and real-time remote access, making it ideal for homes, offices, shops, warehouses, and outdoor covered areas.\r\n\r\n Ideal For:\r\n\r\n* Homes & apartments\r\n* Offices & workspaces\r\n* Retail shops\r\n* Warehouses\r\n* Indoor and covered outdoor areas\r\n\r\nWhy Choose the Single Lens PTZ Bulb Camera?\r\n\r\nThis camera combines discreet design, advanced surveillance features, and simple installation into one affordable security solution. It’s perfect for anyone looking to upgrade their security system without complicated setups or high costs.', '2026-01-31 11:31:58', 'uploads/image_1_696f774d6256f5.02964734.jpg', 'uploads/image_2_696f774d626352.75921320.jpg', NULL, 0, 'Other', 'Single Lens, PTZ Bulb Camera, CCTV, WIFI Camera', '[{\"title\":\"360\\u00b0 Pan & Tilt Coverage\",\"detail\":\"The PTZ (Pan-Tilt-Zoom) function allows wide-angle viewing with remote control, eliminating blind spots and giving you complete coverage of your space.\"},{\"title\":\"High-Definition Single Lens Camera\",\"detail\":\"Equipped with a high-resolution single lens that delivers clear, detailed video for reliable day and night monitoring.\"},{\"title\":\"Smart Motion Detection & Alerts\",\"detail\":\"Automatically detects movement and sends instant alerts to your mobile device, keeping you informed of any suspicious activity in real time.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Built-in microphone and speaker allow you to listen and speak through the camera\\u2014perfect for communicating with visitors or warning intruders.\"},{\"title\":\"Full-Color Night Vision & Infrared Mode\",\"detail\":\"Clear visibility at night with color images or infrared in total darkness.\"},{\"title\":\"Remote Access via Mobile App\",\"detail\":\"Monitor your property anytime, anywhere using a compatible mobile app. View live footage, playback recordings, and control camera movement directly from your phone.\"},{\"title\":\"Easy Bulb-Socket Installation\",\"detail\":\"Simply screw the camera into a standard light bulb holder\\u2014no special tools or technical expertise required.\"},{\"title\":\"Secure Cloud & SD Card Storage\",\"detail\":\"Supports cloud storage and memory card recording (SD card support varies by model), ensuring your footage is safely stored and accessible.\"}]', NULL),
(53, 'Dual Lens PTZ Bulb Camera (CS-101)', 'WIFI CCTV', 23, 30000.00, 'uploads/image_main_696f7e90b21530.48087917.jpg', 'Dual Lens PTZ Bulb Camera (CS-101)\r\n\r\nThe Dual Lens PTZ Bulb Camera is an advanced smart security solution designed to deliver wider coverage, enhanced clarity, and smarter monitoring—all in a simple bulb-style design. With two built-in lenses, this camera provides simultaneous multi-angle surveillance, reducing blind spots and increasing overall security.\r\n\r\nIt installs directly into a standard E27 light socket, making setup fast and hassle-free, while offering powerful features typically found in complex CCTV systems.\r\n \r\nIdeal Applications:\r\n\r\n* Homes & apartments\r\n* Offices & corporate spaces\r\n* Retail stores\r\n* Warehouses\r\n* Indoor and covered outdoor environments\r\n\r\nWhy Choose the Dual Lens PTZ Bulb Camera?\r\n\r\nThe CS-101 Dual Lens PTZ Bulb Camera offers enhanced coverage, smarter monitoring, and simple installation in one compact device. It’s an ideal choice for anyone seeking professional-grade surveillance without the complexity or cost of traditional CCTV systems.', '2026-01-20 13:39:57', 'uploads/image_1_696f7e90b22837.18804006.jpg', 'uploads/image_2_696f7e90b235a9.08513297.jpg', NULL, 0, 'Other ', 'CS-101, Dual Lens, PTZ Bulb Camera, CCTV', '[{\"title\":\"Dual-Lens Wide Coverage\",\"detail\":\"Equipped with two high-definition lenses, the camera captures multiple viewing angles at once\\u2014allowing broader area monitoring and improved depth of vision.\"},{\"title\":\"PTZ Pan & Tilt Control\",\"detail\":\"Remotely control the camera\\u2019s movement through the mobile app to pan and tilt, ensuring full-area coverage without repositioning the device.\"},{\"title\":\"High-Definition Video Quality\",\"detail\":\"Delivers clear, detailed footage for accurate monitoring during both day and night.\"},{\"title\":\"Smart Motion Detection\",\"detail\":\"Detects human movement and sends real-time alerts to your smartphone, helping you respond instantly to unusual activity.\"},{\"title\":\"Infrared & Full-Color Night Vision\",\"detail\":\"Built-in infrared and LED lights provide reliable visibility in low-light or dark environments, ensuring 24\\/7 surveillance.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Integrated microphone and speaker allow you to listen and speak through the camera\\u2014ideal for communication, monitoring, or deterrence.\"},{\"title\":\"Remote Monitoring via Mobile App\",\"detail\":\"Access live video, control PTZ functions, review recordings, and receive alerts anytime, anywhere through a compatible mobile application.\"},{\"title\":\"Easy Bulb-Socket Installation\",\"detail\":\"Simply screw the camera into a standard bulb holder\\u2014no wiring, drilling, or professional installation required.\"},{\"title\":\"Flexible Storage Options\",\"detail\":\"Supports SD card and cloud storage (depending on configuration), ensuring secure and reliable video recording.\"}]', NULL),
(54, '8MP V380 Dual Lens Battery Camera (DB-300)', '4G CCTV', 21, 80000.00, 'uploads/image_main_696f8588a8fbe7.28436153.jpg', '8MP V380 Dual Lens Battery Camera (DB-300)\r\n\r\nThe 8MP V380 Dual Lens Battery Camera is a powerful, wire-free security solution designed for high-resolution monitoring, flexible placement, and intelligent surveillance. With dual lenses and an advanced 8-megapixel sensor, this camera delivers wide coverage and sharp image quality—without the need for constant power connections.\r\n\r\nIdeal for both indoor and outdoor use, the DB-300 combines smart detection, long-lasting battery performance, and remote access through the V380 app for complete peace of mind.\r\n\r\n Ideal Applications:\r\n\r\n* Homes & apartments\r\n* Offices & commercial spaces\r\n* Shops & retail outlets\r\n* Warehouses\r\n* Outdoor entrances and perimeters\r\n\r\nWhy Choose the 8MP V380 Dual Lens Battery Camera?\r\n\r\nThe DB-300 delivers professional-grade security, ultra-clear video, and complete installation freedom in one smart device. Its dual-lens system, battery operation, and intelligent features make it a reliable choice for anyone seeking modern, hassle-free surveillance.', '2026-01-20 13:39:20', 'uploads/image_1_696f8588a91655.01221871.jpg', 'uploads/image_2_696f8588a92769.85110895.jpg', NULL, 0, 'Other', 'DB-300, 8MP, Dual Lens, CCTV Camera, Battery Camera, V380', '[{\"title\":\"8MP Dual Lens System\",\"detail\":\"Sharper detail and wider coverage with fewer blind spots.\"},{\"title\":\"Battery-Powered Design\",\"detail\":\"Install anywhere\\u2014no wiring, no power outlet needed.\"},{\"title\":\"Smart Motion Detection\",\"detail\":\"Get instant alerts the moment movement is detected.\"},{\"title\":\"Infrared & Color Night Vision\",\"detail\":\"Clear visibility day or night, even in low light.\"},{\"title\":\"Two-Way Audio\",\"detail\":\"Listen in and speak back from anywhere.\"},{\"title\":\"V380 App Remote Access\",\"detail\":\"Monitor live footage anytime from your phone.\"},{\"title\":\"Weather-Resistant Build\",\"detail\":\"Reliable performance indoors or outdoors.\"},{\"title\":\"SD Card & Cloud Storage Support\",\"detail\":\"Securely save and replay recordings when needed\"}]', NULL),
(55, '4G Ubox Single Lens Solar PTZ Camera', '4G CCTV', 21, 110000.00, 'uploads/image_main_6971f3a2d0d8f2.07580013.jpg', '4G UBox Single Lens Solar PTZ Camera\r\n\r\nThe 4G UBox Single Lens Solar PTZ Camera is a smart, self-powered security solution designed for remote and off-grid surveillance where electricity and Wi-Fi are unavailable. Powered by a high-efficiency solar panel and supported by a built-in rechargeable battery, this camera delivers 24/7 outdoor monitoring with minimal maintenance.\r\n\r\nEquipped with 4G SIM connectivity, the camera transmits live video and alerts directly to your mobile device via the UBox mobile app, allowing you to monitor your property anytime, anywhere. The PTZ (Pan-Tilt-Zoom) functionality enables wide-area coverage, letting users remotely rotate the camera to eliminate blind spots and capture more details with a single device.\r\n\r\nDesigned for outdoor durability, the camera features a weather-proof housing, making it suitable for homes, farms, construction sites, estates, warehouses, schools, churches, and other outdoor environments. With intelligent motion detection, the camera sends instant push notifications when movement is detected, helping you respond quickly to security events.\r\n\r\nNight surveillance is enhanced with infrared and full-color night vision LEDs, ensuring clear images even in complete darkness. The camera also supports two-way audio, allowing you to listen and speak through the camera remotely for warnings or communication.\r\n\r\nThis solar PTZ camera is an ideal choice for users seeking a cost-effective, energy-saving, and reliable surveillance system without the stress of constant power supply or complex wiring.\r\n\r\nIdeal Applications\r\n\r\n* Homes & residential buildings\r\n\r\n* Farms & agricultural land\r\n\r\n* Construction sites\r\n\r\n* Estates & gated communities\r\n\r\n* Warehouses & factories\r\n\r\n* Schools, churches & outdoor facilities\r\n\r\n* Remote and off-grid locations', '2026-01-22 09:53:38', 'uploads/image_1_6971f3a2d0f0a7.35903262.jpg', 'uploads/image_2_6971f3a2d104c7.09767401.jpg', NULL, 0, 'Other', '4G, CCTV, Single Lens, PTZ Solar Camera, Ubox, TS-10', '[{\"title\":\"4G SIM Connectivity (No Wi-Fi Required)\",\"detail\":\"Works anywhere with mobile network coverage, making it perfect for remote and off-grid locations.\"},{\"title\":\"Solar-Powered with Built-in Rechargeable Battery\",\"detail\":\"Eliminates electricity bills and power outages, ensuring continuous operation day and night.\"},{\"title\":\"PTZ (Pan-Tilt-Zoom) Remote Control\",\"detail\":\"Covers a wide area with one camera, reducing blind spots and the need for multiple cameras.\"},{\"title\":\"Single Lens High-Definition Camera\",\"detail\":\"Delivers clear and detailed video footage for better identification and monitoring.\"},{\"title\":\"Motion Detection with Instant Alerts\",\"detail\":\"Notifies you immediately of suspicious movement so you can respond quickly to security threats.\"},{\"title\":\"Infrared & Full-Color Night Vision\",\"detail\":\"Provides clear surveillance both in total darkness and low-light conditions.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Allows you to listen and speak through the camera to warn intruders or communicate remotely.\"},{\"title\":\"Weather-Proof Outdoor Design\",\"detail\":\"Withstands rain, dust, and harsh outdoor conditions for long-term reliability.\"},{\"title\":\"Mobile App Monitoring (UBox App)\",\"detail\":\"Enables real-time viewing, playback, and camera control from anywhere using your smartphone.\"},{\"title\":\"Supports Cloud & Memory Card Storage\",\"detail\":\"Gives flexible storage options so recordings are safe and easily accessible when needed.\"}]', NULL),
(56, '4G V380 Quadruple Lens Solar PTZ Camera', '4G CCTV', 21, 100000.00, 'uploads/image_main_6972380e6b6fd0.14842339.jpg', '4G V380 Quadruple View Solar PTZ Camera\r\n\r\nThe 4G V380 quadruple View Solar PTZ Camera is an advanced outdoor security solution engineered for maximum coverage, smart monitoring, and total energy independence. Designed with three integrated camera lenses, this system delivers a multi-angle, wide-area view from a single installation point—significantly reducing blind spots and the need for multiple cameras.\r\n\r\nPowered by a high-efficiency solar panel with a built-in rechargeable battery, the camera operates continuously without reliance on electricity. Its 4G SIM connectivity ensures stable remote access even in areas without Wi-Fi, making it ideal for remote sites, farms, estates, construction zones, and off-grid properties.\r\n\r\nThe camera supports PTZ (Pan-Tilt-Zoom) control, allowing users to remotely rotate and adjust viewing angles directly from the V380 mobile app. The triple-view design enables simultaneous monitoring of different angles, combining fixed wide-angle views with a rotating PTZ lens for comprehensive surveillance.\r\n\r\nEquipped with intelligent motion detection, the camera instantly sends real-time alerts to your smartphone when movement is detected. Night security is guaranteed with infrared and full-color night vision, ensuring clear footage even in total darkness. The built-in two-way audio system allows users to listen and communicate remotely, serving as both a monitoring and deterrence tool.\r\n\r\nHoused in a rugged, weather-proof enclosure, the 4G V380 Triple View Solar PTZ Camera is built to withstand harsh outdoor conditions while delivering reliable, long-term performance.', '2026-02-16 12:56:20', 'uploads/image_1_6972380e6b8b05.01433320.jpg', 'uploads/image_2_6972380e6ba3c3.04421191.jpg', NULL, 0, 'Other', '4G, PTZ Camera, CCTV, Quadruple View, V380', '[{\"title\":\"Quadruple-Lens Camera System (Triple View)\",\"detail\":\"Monitors multiple angles at the same time, drastically reducing blind spots and improving overall security coverage.\"},{\"title\":\"4G SIM Connectivity (No Wi-Fi Required)\",\"detail\":\"Works reliably in remote or off-grid locations where internet and routers are unavailable.\"},{\"title\":\"Solar-Powered with Built-in Rechargeable Battery\",\"detail\":\"Operates continuously without electricity, saving energy costs and ensuring security during power outages.\"},{\"title\":\"PTZ (Pan-Tilt-Zoom) Remote Control\",\"detail\":\"Allows wide-area surveillance and precise viewing control from your phone, reducing the need for multiple cameras.\"},{\"title\":\"V380 Mobile App Support\",\"detail\":\"Enables live viewing, playback, camera control, and alert management from anywhere in the world.\"},{\"title\":\"Intelligent Motion Detection\",\"detail\":\"Instantly alerts you to suspicious movement so you can take quick action when it matters most.\"},{\"title\":\"Infrared & Full-Color Night Vision\",\"detail\":\"Delivers clear images day and night, even in complete darkness or low-light conditions.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Lets you listen and speak through the camera to warn intruders or communicate remotely.\"},{\"title\":\"Weather-Proof Outdoor Housing\",\"detail\":\"Performs reliably in rain, dust, and harsh weather, ensuring long-term outdoor use.\"},{\"title\":\"Cloud & Memory Card Storage Support\",\"detail\":\"Provides flexible and secure recording options for reviewing footage whenever needed.\"}]', NULL),
(57, '2MP Outdoor Analogue Camera', 'Analog CCTV', 24, 13500.00, 'uploads/image_main_697241a70f9536.59664898.jpg', '2MP Outdoor Analogue Camera\r\n\r\nThe 2MP Outdoor Analogue Camera is a reliable and cost-effective surveillance solution designed for clear outdoor monitoring and long-term performance. Built with proven analogue technology, this camera delivers high-definition 1080p video quality, making it ideal for homes, offices, shops, schools, and commercial premises seeking dependable security without complexity.\r\n\r\nEquipped with a 2-megapixel image sensor, the camera captures sharp and detailed footage, ensuring clear identification of people, vehicles, and activities. Its infrared (IR) night vision provides consistent monitoring in low-light and complete darkness, automatically switching to night mode to maintain visibility around the clock.\r\n\r\nDesigned for outdoor use, the camera features a durable, weather-proof housing that protects it against rain, dust, and harsh environmental conditions. It integrates seamlessly with DVR systems, supporting stable video transmission over coaxial cables for long-distance installations with minimal signal loss.\r\n\r\nThis 2MP outdoor analogue camera is an excellent choice for customers who want affordable, stable, and easy-to-maintain CCTV surveillance with dependable performance.\r\n\r\nIdeal Applications:\r\n\r\n* Homes & residential buildings\r\n\r\n* Shops & supermarkets\r\n\r\n* Offices & business premises\r\n\r\n* Schools & educational facilities\r\n\r\n* Warehouses & storage facilities\r\n\r\n* Perimeter and outdoor monitoring', '2026-01-22 15:26:31', 'uploads/image_1_697241a70fae66.19666905.jpg', 'uploads/image_2_697241a70fbef6.98514230.jpg', NULL, 0, 'Other', '2MP Camera, CCTV, Outdoor, Analogue Camera', '[{\"title\":\"2MP (1080p) High-Definition Resolution\",\"detail\":\"Provides clear and detailed video footage for easy identification of people and activities.\"},{\"title\":\"Analogue Camera Technology\",\"detail\":\"Delivers stable and reliable performance with minimal lag and low maintenance requirements.\"},{\"title\":\"Compatible with DVR Systems\",\"detail\":\"Easily integrates with existing analogue CCTV systems, reducing upgrade and installation costs.\"},{\"title\":\"Infrared (IR) Night Vision\",\"detail\":\"Ensures continuous monitoring in low-light and complete darkness for 24\\/7 security.\"},{\"title\":\"Weather-Proof Outdoor Housing\",\"detail\":\"Withstands rain, dust, and harsh outdoor conditions for long-term outdoor use.\"},{\"title\":\"Long-Distance Video Transmission\",\"detail\":\"Maintains clear signal quality over long cable runs, ideal for large compounds.\"},{\"title\":\"Fixed Lens Design\",\"detail\":\"Offers consistent viewing angle without the complexity of motorized controls.\"},{\"title\":\"Low Power Consumption\",\"detail\":\"Reduces energy usage, making it cost-effective for continuous operation.\"},{\"title\":\"Simple Installation & Setup\",\"detail\":\"Quick and easy to install, saving time and installation costs.\"},{\"title\":\"Durable Build Quality\",\"detail\":\"Provides dependable performance over time, even in demanding environments.\"}]', NULL),
(58, '2MP Outdoor Analogue Camera', 'Analog CCTV', 24, 13500.00, 'uploads/image_main_697387c028dcf2.92736861.jpg', '2MP Indoor Analogue Camera\r\n\r\nThe 2MP Indoor Analogue Camera is a reliable and affordable surveillance solution designed for clear indoor monitoring and everyday security needs. Built with proven analogue technology, this camera delivers high-definition 1080p video quality, making it ideal for homes, offices, shops, schools, and other indoor environments.\r\n\r\nEquipped with a 2-megapixel image sensor, the camera captures sharp and detailed images, ensuring effective monitoring of people and activities. Its compact dome design blends neatly into indoor spaces while helping to reduce camera tampering and vandalism.\r\n\r\nThe camera features infrared (IR) night vision, allowing it to automatically switch to night mode and provide clear footage even in low-light or dark conditions. Designed for compatibility with DVR systems, it offers stable video transmission, easy integration, and long-term reliability.\r\n\r\nThis 2MP indoor analogue camera is an excellent choice for customers seeking a cost-effective, durable, and easy-to-maintain CCTV solution for indoor security applications.\r\n\r\nIdeal Applications:\r\n\r\n* Homes & apartments\r\n\r\n* Offices & business premises\r\n\r\n* Shops & supermarkets\r\n\r\n* Schools & training centers\r\n\r\n* Reception areas & hallways\r\n\r\n* Indoor security monitoring', '2026-01-23 14:37:52', 'uploads/image_1_697387c028f358.26856083.jpg', 'uploads/image_2_697387c02902b6.58493298.jpg', NULL, 0, 'Other', '2MP, indoor, analogue camera, CCTV, HD', '[{\"title\":\"2MP (1080p) High-Definition Resolution\",\"detail\":\"Produces clear and sharp video for easy monitoring and identification of people and activities.\"},{\"title\":\"Analogue Camera Technology\",\"detail\":\"Offers stable, reliable performance with low maintenance and long-term dependability.\"},{\"title\":\"Compatible with DVR Systems\",\"detail\":\"Integrates easily with existing analogue CCTV setups, saving upgrade and installation costs.\"},{\"title\":\"Infrared (IR) Night Vision\",\"detail\":\"Ensures clear surveillance even in low-light or dark indoor environments.\"},{\"title\":\"Compact Dome Design\",\"detail\":\"Blends neatly into indoor spaces and reduces the risk of tampering or vandalism.\"},{\"title\":\"Fixed Lens Viewing Angle\",\"detail\":\"Provides a consistent and wide indoor coverage without complex controls.\"},{\"title\":\"Low Power Consumption\",\"detail\":\"Enables continuous operation while keeping energy costs low.\"},{\"title\":\"Stable Video Transmission\",\"detail\":\"Delivers smooth video feed with minimal signal loss for reliable monitoring.\"},{\"title\":\"Simple Installation & Setup\",\"detail\":\"Quick and easy to install, reducing setup time and labor costs.\"},{\"title\":\"Durable Build Quality\",\"detail\":\"Ensures long-lasting performance for everyday indoor security needs.\"}]', NULL),
(59, 'Smart Owl Camera', 'WIFI CCTV', 23, 20000.00, 'uploads/image_main_6973925e3911b1.39493205.jpg', 'Smart Owl Camera\r\n\r\nThe Smart Owl Camera is a compact, intelligent indoor security camera designed for real-time monitoring, smart alerts, and everyday peace of mind. With its modern owl-inspired design, this camera blends seamlessly into homes and offices while delivering powerful surveillance features.\r\n\r\nEquipped with a high-definition camera lens, the Smart Owl Camera provides clear and detailed live video through a mobile app, allowing users to monitor their space anytime, anywhere. Its smart motion detection technology instantly alerts you when movement is detected, helping you stay aware of activities in your home or workplace.\r\n\r\nThe camera supports infrared night vision, ensuring reliable monitoring even in low-light or dark environments. With two-way audio, users can listen and speak through the camera—ideal for communicating with family members, staff, or deterring unwanted visitors.\r\n\r\nDesigned for easy plug-and-play installation, the Smart Owl Camera connects via Wi-Fi and can be mounted on a wall, ceiling, or placed on a flat surface. It supports cloud and memory card storage, giving users flexible options for recording and playback.\r\n\r\nThis camera is an excellent choice for home security, baby monitoring, office surveillance, and shop monitoring, offering smart protection in a small, stylish package.\r\n\r\nIdeal Applications:\r\n\r\n* Homes & apartments\r\n\r\n* Baby rooms & caregivers monitoring\r\n\r\n* Offices & workspaces\r\n\r\n* Shops & retail stores\r\n\r\n* Indoor security monitoring', '2026-01-26 13:22:00', 'uploads/image_1_6973925e392521.21384586.jpg', 'uploads/image_2_6973925e393494.70464120.jpg', NULL, 0, 'Other', 'Smart Camera, 360, HD, Indoor Camera, Infrared Night Vision', '[{\"title\":\"High-Definition Camera Lens\",\"detail\":\"Delivers clear and detailed live video so you can easily monitor people and activities indoors.\"},{\"title\":\"Smart Motion Detection\",\"detail\":\"Instantly alerts you when movement is detected, helping you respond quickly to unusual activity.\"},{\"title\":\"Infrared Night Vision\",\"detail\":\"Ensures reliable monitoring even in low-light or dark environments, day and night.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Allows you to listen and speak through the camera to communicate or deter intruders remotely.\"},{\"title\":\"Remote Viewing via Mobile App\",\"detail\":\"Lets you check in on your home or office anytime, anywhere using your smartphone.\"},{\"title\":\"Wide Indoor Coverage\",\"detail\":\"Covers more of the room with fewer cameras, reducing overall security costs.\"},{\"title\":\"Compact & Stylish Design\",\"detail\":\"Blends neatly into home or office interiors without drawing attention.\"}]', NULL),
(60, '4G Single Lens v380 Solar PTZ Camera', '4G CCTV', 21, 100000.00, 'uploads/image_main_6974bfe14f6de9.82655506.png', '4G Single Lens V380 Solar PTZ Camera\r\n\r\nThe 4G Single Lens V380 Solar PTZ Camera is a smart, off-grid security solution designed for locations without reliable electricity. Powered by solar energy and connected via a 4G SIM card, this camera delivers 24/7 remote surveillance anywhere—farms, construction sites, estates, warehouses, shops, and remote properties.\r\n\r\nBuilt with pan, tilt, and zoom (PTZ) functionality, the camera provides wide-area coverage and allows users to remotely rotate the camera horizontally and vertically using the V380 mobile app. The single high-definition lens captures clear, detailed footage during the day and night, ensuring nothing goes unnoticed.\r\n\r\nEquipped with intelligent motion detection, the camera instantly sends real-time alerts to your phone whenever movement is detected. Its solar panel and built-in rechargeable battery ensure continuous operation even during cloudy days, making it a reliable and cost-effective security option.\r\n\r\nWith two-way audio, users can listen and speak through the camera remotely—perfect for warning intruders or communicating with people on-site. The camera also supports cloud storage and SD card recording, giving you flexible options for video storage and playback.\r\n\r\nDesigned for outdoor use, the camera features a weather-proof housing that withstands rain, heat, and dust, making it ideal for Nigeria’s climate.\r\n\r\n', '2026-01-24 12:49:37', 'uploads/image_1_6974bfe14f8a07.65610684.jpg', 'uploads/image_2_6974bfe14f99a2.80713198.jpg', NULL, 0, 'Other', '4G, Single Lens, v380, Solar PTZ Camera', '[{\"title\":\"4G SIM Card Connectivity\",\"detail\":\"Works anywhere with mobile network coverage\\u2014no Wi-Fi needed, perfect for remote and off-grid locations.\"},{\"title\":\"Solar-Powered with Built-in Rechargeable Battery\",\"detail\":\"Provides continuous operation without electricity, reducing running costs and ensuring uninterrupted surveillance.\"},{\"title\":\"Single High-Definition Lens\",\"detail\":\"Captures clear, sharp images and videos for reliable monitoring and evidence recording.\"},{\"title\":\"PTZ (Pan, Tilt & Zoom) Functionality\",\"detail\":\"Allows wide-area coverage and remote camera control, eliminating blind spots and reducing the need for multiple cameras.\"},{\"title\":\"V380 Mobile App Support (Android & iOS)\",\"detail\":\"Enables live viewing, playback, and camera control anytime, anywhere from your smartphone.\"},{\"title\":\"Intelligent Motion Detection\",\"detail\":\"Instantly alerts you when movement is detected, helping you respond quickly to potential security threats.\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Lets you listen and speak through the camera to warn intruders or communicate with people on-site remotely.\"},{\"title\":\"Night Vision (Infrared \\/ Full-Color)\",\"detail\":\"Ensures clear monitoring in low-light and complete darkness for round-the-clock security.\"},{\"title\":\"Cloud & SD Card Storage Support\",\"detail\":\"Offers flexible video storage options, ensuring important footage is saved and easily accessible.\"},{\"title\":\"Weather-Proof Outdoor Design\",\"detail\":\"Withstands rain, heat, and dust, making it reliable for Nigeria\\u2019s outdoor and harsh weather conditions.\"},{\"title\":\"Remote Monitoring & Playback\",\"detail\":\"Allows you to review recorded footage anytime, providing peace of mind and accountability.\"},{\"title\":\"Easy Installation (No Cabling Required)\",\"detail\":\"Saves installation time and cost, ideal for farms, estates, construction sites, and temporary locations.\"}]', NULL);
INSERT INTO `products` (`id`, `name`, `category`, `category_id`, `price`, `image_main`, `description`, `created_at`, `image_1`, `image_2`, `image_3`, `is_featured`, `brand`, `tags`, `specifications`, `sub_category_id`) VALUES
(61, 'CS-500 Smart Mini Wi-Fi Security Camera', 'WIFI CCTV', 23, 110000.00, 'uploads/image_main_69775a83bc82b2.55097452.jpg', 'CS-500 Smart Mini Wi-Fi Security Camera\r\n\r\nThe CS-500 Smart Mini Wi-Fi Security Camera is a compact and discreet indoor surveillance camera designed for simple monitoring, motion alerts, and real-time remote viewing. Its small, modern design makes it easy to place or hide discreetly in homes, offices, shops, or personal spaces where unobtrusive security is required.\r\n\r\nEquipped with a high-definition camera lens, the CS-500 delivers clear live video directly to your smartphone via the BOX mobile app, allowing you to monitor your space anytime and from anywhere. The camera features intelligent motion detection, instantly notifying you when movement is detected so you can stay informed of activities in real time.\r\n\r\nThe camera supports infrared night vision, ensuring reliable monitoring even in low-light or dark environments. With Wi-Fi connectivity, setup is quick and straightforward, making it ideal for users who want a plug-and-play security solution without complex wiring.\r\n\r\nThe CS-500 also supports cloud and memory card storage, giving you flexible options to store and review recordings when needed. Its compact size and quiet operation make it perfect for indoor security, baby monitoring, office supervision, or shop surveillance.\r\n\r\nIdeal Applications:\r\n\r\n* Homes & apartments\r\n\r\n* Offices & workspaces\r\n\r\n* Shops & small businesses\r\n\r\n* Baby or caregiver monitoring\r\n\r\n* Indoor security monitoring', '2026-01-26 12:13:55', NULL, NULL, NULL, 0, 'Other', 'CS-500, Smart, Mini Wi-Fi Security Camera', '[{\"title\":\"High-Definition Video Resolution\",\"detail\":\"Delivers clear, sharp images for accurate monitoring and identification\"},{\"title\":\"Wide-Angle Viewing Lens\",\"detail\":\"Covers more area with fewer cameras, reducing installation cost\"},{\"title\":\"Night Vision (Infrared LEDs)\",\"detail\":\"Provides reliable surveillance even in complete darkness\"},{\"title\":\"Motion Detection Technology\",\"detail\":\"Alerts you instantly when movement is detected, improving security response\"},{\"title\":\"Weatherproof Housing\",\"detail\":\"Suitable for outdoor use and performs well in rain, dust, and harsh weather\"},{\"title\":\"Durable Build Quality\",\"detail\":\"Long-lasting performance with minimal maintenance\"},{\"title\":\"Easy Installation Design\",\"detail\":\"Saves time and cost during setup\"},{\"title\":\"Real-Time Monitoring\",\"detail\":\"Allows live viewing to keep an eye on your property at all times\"},{\"title\":\"Compatible with DVR\\/NVR Systems\",\"detail\":\"Seamlessly integrates with existing surveillance setups\"},{\"title\":\"Stable Signal Transmission\",\"detail\":\"Ensures smooth video feed without frequent interruptions\"}]', NULL),
(62, 'CS-401 Solar Battery Security Camera (Wireless Outdoor Camera)', 'WIFI CCTV', 23, 80000.00, 'uploads/image_main_6977634a585847.80515144.jpg', 'CS-401 Solar Battery Security Camera (Wireless Outdoor Camera)\r\n\r\nThe CS-401 Solar Battery Security Camera is a smart, wire-free surveillance solution designed for reliable outdoor security without dependence on constant power supply. Powered by a high-efficiency external solar panel and a built-in rechargeable battery, this camera delivers uninterrupted monitoring even in areas with unstable electricity.\r\n\r\nBuilt for outdoor use, the CS-401 features a compact, weather-resistant design that withstands rain, dust, and harsh environmental conditions. Its high-definition camera provides clear video footage during the day, while advanced infrared night vision ensures dependable monitoring in low-light and complete darkness.\r\n\r\nWith intelligent motion detection, the camera instantly alerts you when movement is detected, helping you respond quickly to potential security threats. The wireless design allows for easy installation without complex wiring, making it ideal for homes, offices, shops, farms, construction sites, and remote locations.\r\n\r\nThe CS-401 Solar Camera is a cost-effective, energy-saving security solution that combines convenience, durability, and smart surveillance technology', '2026-01-26 12:51:22', NULL, NULL, NULL, 0, 'Other', 'CS-401, Solar Battery Security Camera, Wireless Outdoor Camera, CCTV', '[{\"title\":\"Solar-Powered with External Solar Panel\",\"detail\":\"Provides continuous power without reliance on NEPA or generators, ideal for areas with unstable electricity\"},{\"title\":\"Built-In Rechargeable Battery\",\"detail\":\"Stores energy for night-time and cloudy-day operation, ensuring 24\\/7 monitoring\"},{\"title\":\"100% Wireless Design\",\"detail\":\"No cables required, allowing quick and stress-free installation\"},{\"title\":\"High-Definition Camera Lens\",\"detail\":\"Captures clear and detailed video footage for reliable surveillance\"},{\"title\":\"Infrared Night Vision\",\"detail\":\"Ensures clear monitoring in darkness and low-light conditions\"},{\"title\":\"Motion Detection Sensor\",\"detail\":\"Instantly alerts you when movement is detected, improving security response\"},{\"title\":\"Weatherproof Outdoor Housing\",\"detail\":\"Withstands rain, dust, and harsh outdoor conditions\"},{\"title\":\"Remote Viewing via Mobile App\",\"detail\":\"Monitor your home or business anytime, anywhere from your smartphone\"},{\"title\":\"Two-Way Audio Communication\",\"detail\":\"Allows you to listen and speak through the camera for added security control\"},{\"title\":\"Energy-Efficient Operation\",\"detail\":\"Reduces electricity costs while supporting eco-friendly power use\"}]', NULL),
(63, 'CS-400 Mini Wireless Security Camera (Indoor/Outdoor Smart Camera)', 'WIFI CCTV', 23, 18000.00, 'uploads/image_main_69776a22198e52.13948131.jpg', 'CS-400 Mini Wireless Security Camera (Indoor/Outdoor Smart Camera)\r\n\r\nThe CS-400 Mini Wireless Security Camera is a compact yet powerful surveillance solution designed for discreet and effective monitoring of homes, offices, shops, and personal spaces. Its small-size design allows it to blend easily into any environment while still delivering reliable security performance.\r\n\r\nEquipped with a high-definition camera lens, the CS-400 captures clear and detailed video footage, ensuring you never miss important moments. The camera supports wireless connectivity, enabling remote live viewing directly from your smartphone via a compatible mobile app.\r\n\r\nDesigned for both indoor and light outdoor use, the CS-400 features a durable housing and flexible mounting options, making installation quick and hassle-free. With built-in motion detection, the CS-400 instantly alerts you when movement is detected, helping you stay aware of activities around your property.\r\n\r\nThis smart camera is ideal for monitoring entrances, offices, bedrooms, shops, desks, and other areas where discreet security is required. The CS-400 Mini Wireless Camera offers a simple, affordable, and efficient way to stay connected and protected at all times', '2026-01-26 13:20:34', NULL, NULL, NULL, 0, 'Other', 'CS-400, Mini Wireless Security Camera, Indoor/Outdoor Smart Camera, CCTV', '[{\"title\":\"Mini & Compact Design\",\"detail\":\"Easily hides in any environment for discreet surveillance without drawing attention.\"},{\"title\":\"HD Video Resolution\",\"detail\":\"Captures clear and sharp footage, making it easy to identify faces, movements, and activities.\"},{\"title\":\"Wireless Connectivity (Wi-Fi)\",\"detail\":\"Allows remote monitoring from your smartphone anytime, anywhere.\"},{\"title\":\"Motion Detection Technology\",\"detail\":\"Instantly alerts you when movement is detected, improving security and response time.\"},{\"title\":\"Night Vision Capability\",\"detail\":\"Provides clear monitoring even in low-light or complete darkness.\"},{\"title\":\"Mobile App Viewing\",\"detail\":\"View live footage, recordings, and alerts directly from your phone for convenience.\"},{\"title\":\"Multiple Mounting Options\",\"detail\":\"Can be placed on desks, walls, ceilings, or hidden spots for flexible installation\"},{\"title\":\"Multiple Mounting Options\",\"detail\":\"Can be placed on desks, walls, ceilings, or hidden spots for flexible installation\"},{\"title\":\"Indoor & Light Outdoor Use\",\"detail\":\"Suitable for homes, offices, shops, stores, and entry points\"},{\"title\":\"Supports SD Card Storage\",\"detail\":\"Stores video recordings locally, allowing playback without constant internet access\"}]', NULL),
(66, '4 Channel DVR (Digital Video Recorder)', 'Analog CCTV', 24, 50000.00, 'uploads/image_main_69777889acf980.03426232.jpg', '4 Channel DVR (Digital Video Recorder)\r\n\r\nThe 4 Channel DVR is a reliable and efficient video recording solution designed for small to medium security setups. It allows you to connect and manage up to four CCTV cameras, making it ideal for homes, shops, offices, schools, and small businesses.\r\n\r\nBuilt for performance and ease of use, this DVR delivers clear video recording, smooth playback, and secure storage of footage. With smart features such as motion detection and remote viewing support, you can monitor your property anytime and respond quickly to security events.', '2026-01-26 14:22:01', 'uploads/image_1_69777889ad1370.81465185.jpg', 'uploads/image_2_69777889ad2e41.71589724.jpg', NULL, 0, 'HIKVISION', 'HD Video Recording, CCTV, DVR, 4 Channel, ', '[{\"title\":\"High-Definition Video Recording\",\"detail\":\"Enjoy clear, detailed footage for easy identification of people and activities.\"},{\"title\":\"Supports Up to 4 CCTV Cameras\",\"detail\":\"Monitor multiple areas using one device, making it ideal for small to medium security setups.\"},{\"title\":\"Motion Detection Technology\",\"detail\":\"Saves storage space by recording only when movement is detected.\"},{\"title\":\"Remote Viewing Capability\",\"detail\":\"Monitor your property anytime, anywhere using your smartphone or computer.\"},{\"title\":\"Multi-Format Camera Compatibility\",\"detail\":\"Works with different CCTV camera types, reducing the cost of system upgrades.\"},{\"title\":\"Hard Drive Storage Support\",\"detail\":\"Securely stores recorded footage for playback, review, and evidence when needed.\"},{\"title\":\"Easy Setup & User-Friendly Interface\",\"detail\":\"Allows quick installation and smooth operation with minimal technical knowledge.\"},{\"title\":\"Compact & Durable Design\",\"detail\":\"Saves space while ensuring long-term, reliable performance.\"},{\"title\":\"Real-Time Live Viewing\",\"detail\":\"Enables instant monitoring and faster response to security incidents.\"}]', NULL),
(68, '8 Channel DVR (Digital Video Recorder)', 'Analog CCTV', 24, 60000.00, 'uploads/image_main_69779173e9a146.85917600.jpg', '8 Channel DVR\r\n\r\nThe 8 Channel DVR is a powerful and reliable video recording solution designed for medium to large security installations. It allows you to connect and manage up to eight CCTV cameras simultaneously, making it ideal for homes, offices, shops, schools, warehouses, and commercial buildings that require wider surveillance coverage.\r\n\r\nBuilt for performance and stability, this DVR delivers clear high-definition video recording, ensuring important details are captured accurately. With smart motion detection, the system records only when activity is detected, helping to save storage space while keeping you informed of critical events.\r\n\r\nThe remote viewing feature allows you to monitor your property anytime and anywhere using a smartphone, tablet, or computer. Its multi-format compatibility ensures it works seamlessly with various CCTV camera types, making it easy to upgrade or expand your existing security system without replacing all components.\r\n\r\nDesigned with a compact, durable body and a user-friendly interface, the 8 Channel DVR is easy to install, configure, and operate. Whether for business or residential use, it provides dependable surveillance, secure video storage, and peace of mind.', '2026-01-26 16:08:19', 'uploads/image_1_69779173e9bd17.32479244.jpg', 'uploads/image_2_69779173e9d007.06770595.jpg', NULL, 0, 'HIKVISION', '8 Channel, DVR, CCTV, HD, Security, Motion', '[{\"title\":\"Supports Up to 8 CCTV Cameras\",\"detail\":\"Monitor multiple areas using one device, making it ideal for small to medium security setups.\"},{\"title\":\"High-Definition Video Recording\",\"detail\":\"Enjoy clear, detailed footage for easy identification of people and activities.\"},{\"title\":\"Motion Detection Technology\",\"detail\":\"Saves storage space by recording only when movement is detected.\"},{\"title\":\"Remote Viewing Capability\",\"detail\":\"Monitor your property anytime, anywhere using your smartphone or computer.\"},{\"title\":\"Multi-Format Camera Compatibility\",\"detail\":\"Works with different CCTV camera types, reducing the cost of system upgrades.\"},{\"title\":\"Hard Drive Storage Support\",\"detail\":\"Securely stores recorded footage for playback, review, and evidence when needed.\"},{\"title\":\"Easy Setup & User-Friendly Interface\",\"detail\":\"Allows quick installation and smooth operation with minimal technical knowledge.\"},{\"title\":\"Compact & Durable Design\",\"detail\":\"Saves space while ensuring long-term, reliable performance.\"},{\"title\":\"Real-Time Live Viewing\",\"detail\":\"Enables instant monitoring and faster response to security incidents.\"}]', NULL),
(69, '360 Panoramic HD Camera', 'Analog CCTV', 24, 50000.00, 'uploads/image_main_69779947d477a0.35325442.jpg', '360° Panoramic HD Camera\r\n\r\nSee everything. Miss nothing.\r\n\r\nThe 360° Panoramic HD Camera delivers complete room coverage in a single device—eliminating blind spots and reducing the need for multiple cameras. Designed for indoor security, this smart panoramic camera uses a wide-angle fisheye lens to capture a full 360-degree view, giving you real-time visibility of your home or business directly from your phone.\r\n\r\nWith crystal-clear HD video, built-in night vision, motion detection alerts, and two-way audio, this camera keeps you connected and protected anytime, anywhere.\r\n\r\nPerfect for homes, offices, shops, schools, and warehouses.\r\n\r\nWhy Choose the 360° Panoramic HD Camera?\r\n\r\nUnlike traditional cameras that cover only one direction, this panoramic camera provides a complete bird’s-eye view of your space, making it ideal for large rooms and open areas. One camera does the job of multiple units—saving you money while improving coverage.\r\n\r\nWhether you’re protecting your family or monitoring your business, this camera gives you peace of mind with smart security technology you can trust\r\n\r\nIdeal For:\r\n\r\n• Homes & apartments\r\n• Offices & conference rooms\r\n• Shops & supermarkets\r\n• Churches & event halls\r\n• Warehouses & schools', '2026-01-26 16:41:43', 'uploads/image_1_69779947d491f3.31253087.jpg', 'uploads/image_2_69779947d4a9a9.33497062.jpg', NULL, 0, 'POLYVISION', '360, Panoramic, HD Camera, CCTV, Infrared', '[{\"title\":\" 360\\u00b0 Panoramic View\",\"detail\":\"Covers the entire room with one camera\"},{\"title\":\"HD Video Quality\",\"detail\":\"Sharp, clear footage day and night\"},{\"title\":\"Infrared Night Vision\",\"detail\":\"See clearly even in total darkness\"},{\"title\":\"Motion Detection Alerts\",\"detail\":\" Get instant notifications on your phone\"},{\"title\":\"Two-Way Audio\",\"detail\":\" Listen and speak through the camera remotely\"},{\"title\":\"Remote Viewing via Mobile App\",\"detail\":\"Monitor from anywhere in the world\"}]', NULL),
(70, 'Wireless Intercom With Display', 'Display', 25, 52000.00, 'uploads/image_main_6978a83a0d6ee8.30544243.jpg', 'Wireless Intercom with Display\r\n\r\nUpgrade your communication and access control with our Wireless Intercom with Display — a reliable, easy-to-use desktop intercom system designed for homes, offices, hotels, hospitals, schools, and security posts.\r\n\r\nFeaturing a clear LCD screen, numeric keypad, and hands-free calling, this intercom allows instant two-way communication at the press of a button. The bright display shows call status and dialing information, making operation simple even for first-time users.\r\n\r\nBuilt for durability and everyday use, its sleek compact design fits perfectly on reception desks or security counters. Whether you’re managing visitors, coordinating staff, or enhancing building security, this intercom delivers clear voice transmission and dependable performance.\r\n\r\nIdeal For:\r\n\r\n* Reception desks\r\n* Gated properties\r\n* Office communication\r\n* Visitor management\r\n* Internal building communication\r\n* Security stations\r\n\r\n Benefits\r\n\r\n✔ Fast internal communication\r\n✔ Improves visitor control\r\n✔ Reduces unnecessary movement\r\n✔ Enhances workplace efficiency\r\n✔ Professional front-desk setup', '2026-01-27 11:57:46', 'uploads/image_1_6978a4b47a0e23.99823588.jpg', 'uploads/image_2_6978a4b47a1f58.08741087.jpg', NULL, 0, 'POLYVISION', 'Wireless, Intercom, LCD, Keypad, Audio, Communication', '[{\"title\":\"LCD Display Screen\",\"detail\":\"Clearly view call status and dialed numbers at a glance \\u2014 no guessing required\"},{\"title\":\"Two-Way Voice Communication\",\"detail\":\"Speak and listen clearly in real time without leaving your desk\"},{\"title\":\"Numeric Keypad\",\"detail\":\"Quickly dial extensions or contacts with easy button control\"},{\"title\":\"Hands-Free Speaker Mode\",\"detail\":\"Talk comfortably while multitasking or attending to customers\"},{\"title\":\"Clear Audio Output\",\"detail\":\"Enjoy crisp sound quality with minimal background noise\"},{\"title\":\"Plug-and-Play Installation\",\"detail\":\"Set up in minutes with no technical skills or complex wiring required\"}]', NULL),
(71, 'Wireless Intercom Without Display', 'Non-Display', 26, 50000.00, 'uploads/image_main_6978a7ef78a886.24109471.jpg', 'Wireless Intercom without Display\r\n\r\nUpgrade your communication and access control with our Wireless Intercom without Display — a reliable, easy-to-use desktop intercom system designed for homes, offices, hotels, hospitals, schools, and security posts.\r\n\r\nFeaturing a numeric keypad, and hands-free calling, this intercom allows instant two-way communication at the press of a button. The bright display shows call status and dialing information, making operation simple even for first-time users.\r\n\r\nBuilt for durability and everyday use, its sleek compact design fits perfectly on reception desks or security counters. Whether you’re managing visitors, coordinating staff, or enhancing building security, this intercom delivers clear voice transmission and dependable performance.\r\n\r\nIdeal For:\r\n\r\n* Reception desks\r\n* Gated properties\r\n* Office communication\r\n* Visitor management\r\n* Internal building communication\r\n* Security stations\r\n\r\n Benefits\r\n\r\n✔ Fast internal communication\r\n✔ Improves visitor control\r\n✔ Reduces unnecessary movement\r\n✔ Enhances workplace efficiency\r\n✔ Professional front-desk setup', '2026-01-27 11:56:31', 'uploads/image_1_6978a7ef78bb13.70363910.jpg', 'uploads/image_2_6978a7ef78c658.07209609.jpg', 'uploads/image_3_6978a7ef78cf92.66652602.jpg', 0, 'MEGAVISION', 'Wireless, Intercom, Keypad, Audio, Communication', '[{\"title\":\"Two-Way Voice Communication\",\"detail\":\"Speak and listen clearly in real time without leaving your desk\"},{\"title\":\"Numeric Keypad\",\"detail\":\"Quickly dial extensions or contacts with easy button control\"},{\"title\":\"Hands-Free Speaker Mode\",\"detail\":\"Talk comfortably while multitasking or attending to customers\"},{\"title\":\"Clear Audio Output\",\"detail\":\"Enjoy crisp sound quality with minimal background noise\"},{\"title\":\"Plug-and-Play Installation\",\"detail\":\"Set up in minutes with no technical skills or complex wiring required\"}]', NULL),
(72, 'Motorola Walkie Talkie', 'Walkie Talkie1', 117, 25000.00, 'uploads/image_main_6978ae4dd8e882.29141374.jpg', 'Motorola Walkie Talkie (Two-Way Radio)\r\n\r\nInstant communication. Professional reliability.\r\n\r\nStay connected anywhere with the Motorola Walkie Talkie, a powerful two-way radio designed for clear, reliable communication in demanding environments. Built with Motorola’s trusted technology, this walkie talkie delivers crisp audio, long-range performance, and durable construction—making it ideal for security teams, businesses, construction sites, events, and industrial operations.\r\n\r\nFeaturing simple push-to-talk functionality, long-lasting rechargeable batteries, and strong signal reception, this device ensures your team communicates instantly without relying on mobile networks.\r\n\r\nWhether coordinating staff, managing security, or operating on large sites, Motorola walkie talkies provide dependable real-time communication you can trust.\r\n\r\nPerfect For:\r\n\r\n• Security personnel\r\n• Construction crews\r\n• Hotels & hospitality staff\r\n• Warehouses & factories\r\n• Churches & event organizers\r\n• Schools & campuses\r\n• Logistics teams\r\n\r\nWhy Choose Motorola Walkie Talkies?\r\n\r\nMotorola is globally trusted for professional communication equipment. These walkie talkies offer faster coordination, improved safety, and increased productivity, eliminating delays caused by phone calls or weak mobile signals.\r\n\r\nWith rugged reliability and crystal-clear sound, they keep your team connected when it matters most.', '2026-02-28 16:25:05', 'uploads/image_1_6978ae4dd90003.98089674.jpg', 'uploads/image_2_6978ae4dd91462.37934736.jpg', NULL, 0, 'Motorola', 'Motorola, Walkie Talkie, Two-way, Radio, Audio', '[{\"title\":\"Two-Way Radio Communication\",\"detail\":\"Instantly communicate with team members without phone calls or network coverage\"},{\"title\":\"Push-to-Talk Button\",\"detail\":\"One-press operation makes communication fast and effortless\"},{\"title\":\"Long Communication Range\",\"detail\":\"Stay connected across large areas like warehouses, events, estates, or buildings\"},{\"title\":\"High-Quality Audio Output\",\"detail\":\"Hear voices clearly even in noisy work environments\"},{\"title\":\"Rechargeable Battery with Charging Dock\",\"detail\":\"Keeps devices powered and ready for reliable daily use\"},{\"title\":\"Durable Professional Design\",\"detail\":\"Built to withstand drops and tough working conditions\"},{\"title\":\"Lightweight & Portable\",\"detail\":\"Comfortable to carry and use all day without fatigue\"},{\"title\":\"Noise Reduction Speaker\",\"detail\":\"Reduces background noise for clearer conversations\"}]', NULL),
(73, 'Baofeng 888s Walkie Talkie', 'Walkie Talkie1', 117, 15000.00, 'uploads/image_main_6978b50414a501.86198171.jpg', 'Baofeng BF-888S Walkie Talkie (widely used in security, construction, events, warehouses, and Baofeng BF-888S Walkie Talkie\r\n\r\nStay connected instantly with the Baofeng BF-888S Walkie Talkie — a compact, powerful two-way radio designed for clear communication in demanding environments. Whether you’re coordinating security teams, managing construction sites, organizing events, or running daily business operations, the BF-888S delivers reliable performance without relying on mobile networks.\r\n\r\nBuilt with durability and simplicity in mind, this professional walkie talkie features high-quality audio, long-range transmission, and an easy push-to-talk function for fast communication. Its lightweight design makes it comfortable to carry all day, while the rechargeable battery ensures uninterrupted operation during long shifts.\r\n\r\nPerfect for indoor and outdoor use, the Baofeng 888S supports multiple channels so teams can stay organized and communicate efficiently. With strong signal stability and noise-reduction technology, every message comes through loud and clear — even in busy environments.\r\n\r\nIf you need dependable, cost-effective communication, the Baofeng BF-888S is a smart choice for professional and commercial use.\r\n\r\nIdeal For:\r\n\r\nSecurity companies\r\nConstruction sites\r\nHotels & facilities management\r\nEvent coordination\r\nWarehouses & logistics\r\nRetail staff communication', '2026-02-28 16:24:30', NULL, 'uploads/image_2_6978b50414c032.82124550.jpg', NULL, 0, 'BAOFENG', 'Baofeng, 888s, Walkie Talkie, Audio ', '[{\"title\":\"Long Communication Range\",\"detail\":\"Stay connected across large areas like warehouses, events, estates, or buildings\"},{\"title\":\"Two-Way Radio Communication\",\"detail\":\"Instantly communicate with team members without phone calls or network coverage\"},{\"title\":\"Push-to-Talk Button\",\"detail\":\"One-press operation makes communication fast and effortless\"},{\"title\":\"High-Quality Audio Output\",\"detail\":\"Hear voices clearly even in noisy work environments\"},{\"title\":\"Rechargeable Battery with Charging Dock\",\"detail\":\"Keeps devices powered and ready for reliable daily use\"},{\"title\":\"Durable Professional Design\",\"detail\":\"Built to withstand drops and tough working conditions\"},{\"title\":\"Lightweight & Portable\",\"detail\":\"Comfortable to carry and use all day without fatigue\"},{\"title\":\"Noise Reduction Speaker\",\"detail\":\"Reduces background noise for clearer conversations\"}]', NULL),
(74, 'V380 Smart Wifi Camera', 'WIFI CCTV', 23, 35000.00, 'uploads/image_main_6978bb5b718055.18890485.jpg', 'Smart WiFi Camera\r\n\r\nThe Smart WiFi Camera is a versatile and user-friendly home security solution that gives you reliable remote surveillance using your existing WiFi network. Designed for both residential and small business security, this compact camera delivers crisp video quality and smart features that make monitoring easier and more effective — whether you’re across the house or miles away.\r\n\r\nEquipped with automatic WiFi connectivity, this camera pairs quickly with your smartphone so you can view live footage in real time from anywhere. It supports smooth pan and tilt control, enabling you to cover more area with a single unit. With built-in motion detection and instant alerts, you’ll never miss important activity. Easy to install and operate, this camera is perfect for entryways, living areas, nurseries, garages, or offices.\r\n\r\nThe Smart WiFi Camera provides peace of mind with seamless performance and intuitive control, making home security accessible, affordable, and effortless.\r\n\r\nWho It’s Ideal For:\r\n\r\n* Homeowners wanting effortless indoor security\r\n* Parents monitoring children or pets\r\n* Small business owners keeping an eye on their store\r\n* Anyone needing affordable remote surveillance', '2026-01-27 13:19:23', 'uploads/image_1_6978bb5b719618.13203573.jpg', 'uploads/image_2_6978bb5b71a681.71266677.jpg', NULL, 0, 'Other', 'V380, Smart Wifi Camera, CCTV, Night Vision, Cloud Storage, Wireless', '[{\"title\":\"Wireless WiFi Connectivity\",\"detail\":\" Easy setup with no complex wiring\"},{\"title\":\"Real-Time Live View\",\"detail\":\"Monitor your space anytime from anywhere\"},{\"title\":\"Motion Detection & Alerts\",\"detail\":\"Instant notifications when movement is detected\"},{\"title\":\"Pan & Tilt Control\",\"detail\":\" Wide coverage with flexible viewing angles\"},{\"title\":\"Clear Video Quality\",\"detail\":\"Reliable day and night monitoring\"},{\"title\":\"Multi-User Access\",\"detail\":\"Share camera access with family or team members\"},{\"title\":\"Multi-Platform Support\",\"detail\":\"Works across smartphones, tablets, and other devices\"},{\"title\":\"Cloud Storage Support \",\"detail\":\"Securely store and access recorded footage online\"},{\"title\":\"Two-Way Audio (where supported)\",\"detail\":\"Listen and speak through the camera remotely\"}]', NULL),
(75, 'Minimum Solar Protection Set', '', 6, 40000.00, 'uploads/image_main_6978bfe54a4c99.74319631.jpg', 'Minimum Solar Protection Set\r\n\r\nThe Minimum Solar Protection Set is an essential safety package designed to protect small to medium solar power systems from electrical faults, overloads, and voltage fluctuations. It provides reliable protection for both AC and DC sides of a solar installation, helping to extend the lifespan of your inverter, batteries, and connected appliances.\r\n\r\nThis set is ideal for residential and light commercial solar setups where safety, affordability, and reliability are key. All components are neatly housed in a compact enclosure, ensuring easy installation, organized wiring, and professional system protection.\r\n\r\nBy combining circuit breakers, voltage and current protection, and a manual isolation switch, this solar protection set helps prevent damage caused by short circuits, overcurrent, unstable voltage, and unexpected power surges.\r\n\r\nWhat’s Included:\r\n\r\n* 4-Way Enclosure Box – Durable housing for safe and organized installation\r\n* 1P 32A AC Input Breaker – Protects the AC line from overload and short circuits\r\n* 1P 60A DC Breaker – Provides reliable DC-side protection from excessive current\r\n* Volt & Amp Protector – Monitors voltage and current to safeguard connected equipment\r\n* Knife Switch (Isolator) – Allows manual disconnection of power for maintenance and safety\r\n\r\nKey Benefits:\r\n\r\n* Protects solar systems from electrical damage\r\n* Improves safety for users and installers\r\n* Reduces risk of inverter and battery failure\r\n* Easy to install and maintain\r\n* Ideal for basic and entry-level solar systems\r\n\r\n Recommended For:\r\n\r\n* Small home solar systems\r\n* Backup power installations\r\n* Entry-level inverter setups\r\n* Customers looking for affordable but essential solar protection', '2026-01-27 13:38:45', NULL, NULL, NULL, 0, 'Other', '4-Way Enclosure Box, 1P 32A AC Input Breaker, 1P 60A DC Breaker, Volt & Amp Protector         ', '[{\"title\":\" 4-Way Enclosure Box             \",\"detail\":\"  Keeps all protection components neatly organized and safely enclosed\"},{\"title\":\" 1P 32A AC Input Breaker           \",\"detail\":\" Protects the inverter and appliances from AC overloads and short circuits\"},{\"title\":\"1P 60A DC Breaker                  \",\"detail\":\"Safeguards the solar panels and battery line from excessive DC current\"},{\"title\":\"Volt & Amp Protector               \",\"detail\":\"Monitors voltage and current to prevent damage from unstable power\"},{\"title\":\"Manual Knife Switch (Isolator)     \",\"detail\":\"Allows quick and safe disconnection during maintenance or emergencies\"},{\"title\":\"Compact & Durable Design           \",\"detail\":\"Saves space and ensures long-term reliability\"},{\"title\":\"Dual AC & DC Protection            \",\"detail\":\"Provides complete system safety on both power sides \"},{\"title\":\"Easy Installation Setup            \",\"detail\":\"Reduces installation time and labor costs                      \"},{\"title\":\"Suitable for Small\\u2013Medium Systems  |\",\"detail\":\"Ideal for homes and basic commercial solar setups\"},{\"title\":\"Cost-Effective Protection Solution \",\"detail\":\" Delivers essential safety without high system costs \"}]', NULL),
(76, 'Baofeng C5 Walkie talkie', 'Walkie Talkie1', 117, 25000.00, 'uploads/image_main_697a171437e174.02972459.jpg', 'Baofeng C5 Walkie Talkie – Reliable Two-Way Communication for Work & Security\r\n\r\nThe Baofeng C5 Walkie Talkie is a compact, rugged, and easy-to-use two-way radio designed for clear and instant communication in both indoor and outdoor environments. Built for reliability, the C5 is ideal for security personnel, construction sites, event management teams, warehouses, hotels, schools, churches, factories, and estates where fast communication is critical.\r\n\r\nWith its strong signal penetration, clear audio output, and long battery life, the Baofeng C5 ensures your team stays connected even in noisy or demanding environments. Its simple push-to-talk operation makes it user-friendly for both professionals and first-time users.\r\n\r\nApplications:\r\n\r\n* Security & Guard Services\r\n* Construction & Engineering Sites\r\n* Event Planning & Crowd Control\r\n* Hotels, Malls & Warehouses\r\n* Schools, Churches & Estates\r\n* Factories & Industrial Facilities\r\n\r\nWhat’s in the Box\r\n\r\n* Baofeng C5 Walkie Talkie\r\n* Rechargeable Battery\r\n* Charging Cable / Dock\r\n* Belt Clip\r\n\r\n', '2026-02-28 16:26:09', 'uploads/image_1_697a171437f7c9.11626380.jpg', 'uploads/image_2_697a1714380a93.88249016.jpg', NULL, 0, 'BAOFENG', 'Baofeng, C5, Walkie talkie, Two-way Communication', '[{\"title\":\"UHF Two-Way Radio Communication\",\"detail\":\"Enables stable and clear communication with minimal interference, even in built-up environments\"},{\"title\":\"Push-to-Talk (PTT) Button\",\"detail\":\"Allows instant communication with a single press, saving time during urgent situation\"},{\"title\":\"Long Communication Range\",\"detail\":\"Keeps team members connected across large sites such as estates, warehouses, and event venue\"},{\"title\":\"High-Quality Audio Output\",\"detail\":\"Ensures voices are loud and clear, even in noisy environments like construction site\"},{\"title\":\"Durable Build Quality\",\"detail\":\"Withstands daily professional use in tough working conditions\"},{\"title\":\"Rechargeable High-Capacity Battery\",\"detail\":\"Provides extended usage time, reducing frequent charging interruptions\"},{\"title\":\"Compact & Lightweight Design\",\"detail\":\"Comfortable to carry all day without fatigue\"}]', NULL),
(77, '5 Way Unlock Smart Lock', '5 Way Unlock', 31, 290000.00, 'uploads/image_main_697df56642d630.52696568.jpg', '\r\n5 Way Unlock Smart Lock – Advanced Keyless Security for Modern Living\r\n\r\nUpgrade your door security with the 5 Way Unlock Smart Lock, a next-generation smart door lock designed to deliver maximum security, convenience, and style. Built with advanced biometric and digital access technologies, this smart lock eliminates traditional keys and gives you full control over who enters your space — anytime, anywhere.\r\n\r\nPerfect for homes, offices, hotels, short-let apartments (Airbnb), schools, and commercial buildings, the 5 Way Unlock Smart Lock combines high-level security with elegant design, making it ideal for modern properties.\r\n\r\nIdeal Applications:\r\n\r\n* Residential Homes & Apartments\r\n* Offices & Corporate Buildings\r\n* Hotels & Short-Let Apartments (Airbnb)\r\n* Schools & Hostels\r\n* Commercial Buildings\r\n* Guest Houses\r\n\r\nWhy Choose This 5 Way Unlock Smart Lock?\r\n\r\n✔ Eliminates keys completely\r\n✔ Enhances property security\r\n✔ Prevents unauthorized access\r\n✔ Boosts property value\r\n✔ Ideal for Nigerian power & security conditions\r\n\r\nTechnical Highlights\r\n\r\n* Unlock Methods: Fingerprint, PIN, RFID Card, Mechanical Key, Mobile App (model dependent)\r\n* Material: Premium Aluminum Alloy + Stainless Steel Lock Body\r\n* Power Supply: AA Batteries with USB emergency power backup\r\n* Suitable Door Types: Wooden, Steel & Security Doors\r\n* Installation: Professional installation recommended\r\n\r\nPerfect for Smart Homes & Smart Offices\r\n\r\nTransform your property into a smart, secure, and modern environment with this 5 Way Unlock Smart Lock — combining technology, safety, and convenience in one powerful solution.\r\n\r\n\r\n', '2026-01-31 12:28:22', 'uploads/image_1_697df56642e944.66127148.jpg', 'uploads/image_2_697df56642fb64.39813194.jpg', NULL, 0, 'Other ', '5 Way Unlock Smart Lock, Keyless, Security, Modern Living, Fingerprint, Passcode, Pin, RFID, Mobile', '[{\"title\":\"Fingerprint Unlock\",\"detail\":\"Fast, secure, and highly accurate biometric access\"},{\"title\":\"Passcode \\/ PIN Unlock\",\"detail\":\"Ideal for family members, staff, and guests\"},{\"title\":\"RFID Card Unlock\",\"detail\":\"Convenient tap access\"},{\"title\":\"Mechanical Key Backup\",\"detail\":\"Emergency access when needed\"},{\"title\":\"Mobile App Control (Optional Model Feature)\",\"detail\":\"Unlock remotely and manage users\"},{\"title\":\"Advanced Fingerprint Recognition Technology\",\"detail\":\"Equipped with high-speed biometric scanning that recognizes fingerprints in less than 0.5 seconds\"},{\"title\":\"Anti-Peep Virtual Password System\",\"detail\":\"Allows you to enter random digits before or after your real PIN to prevent others from spying.\"},{\"title\":\"High-Security Locking Mechanism\",\"detail\":\"Built with a durable stainless steel lock body and multiple deadbolts for maximum strength.\"},{\"title\":\"Smart Alarm System\",\"detail\":\"Triggers an alarm in cases of:  Wrong password attempts,  Forced entry detection,  Door not properly closed\"},{\"title\":\"Emergency Power Backup (USB Charging Port)\",\"detail\":\"In case of battery drain, you can temporarily power the lock using a power bank.\"},{\"title\":\"Sleek & Modern Design\",\"detail\":\"Premium finish that blends perfectly with wooden, steel, and security doors.\"}]', NULL),
(78, 'SMS 12v 220ah Tubular Battery', 'Tubular Battery', 33, 260000.00, 'uploads/image_main_697f5528212fd9.60890061.jpg', 'SMS 12V 220Ah Tubular Solar Battery – High-Performance Deep Cycle Battery for Solar & Inverter Systems\r\n\r\nPower your solar and inverter systems with confidence using the SMS 12V 220Ah Tubular Solar Battery, a heavy-duty deep cycle battery* engineered for reliable, long-lasting energy storage. Designed with advanced tubular plate technology and carbon-enhanced materials, this battery delivers superior backup time, longer lifespan, and stable performance, even under frequent deep discharge conditions.\r\n\r\nIdeal for homes, offices, schools, hospitals, hotels, churches, and commercial facilities, the SMS 12V 220Ah battery ensures consistent power supply during outages, making it a dependable choice for Nigeria’s power environment.\r\n \r\nIdeal Applications:\r\n\r\n* Solar Power Systems\r\n* Inverter Backup Systems\r\n* Homes & Apartments\r\n* Offices & Corporate Buildings\r\n* Hospitals & Clinics\r\n* Schools & Hostels\r\n* Churches & Mosques\r\n* CCTV & Security Systems\r\n* Telecom & Network Equipment\r\n\r\n\r\nWhy Choose SMS 12V 220Ah Battery?\r\n\r\n✔ Long backup time\r\n✔ High deep-cycle durability\r\n✔ Faster charging\r\n✔ Reduced sulphation\r\n✔ Reliable Nigerian climate performance\r\n✔ Excellent value for money\r\n\r\n\r\nTechnical Specifications:\r\n\r\n* Battery Type: Tubular Deep Cycle Lead Acid\r\n* Rated Voltage: 12V\r\n* Capacity: 220Ah\r\n* Technology: Tubular Plate with Carbon Additive\r\n* Application: Solar & Inverter Systems\r\n* Maintenance: Low maintenance\r\n* Design: Heavy-duty industrial grade\r\n\r\n\r\nPerfect for Solar Installations in Nigeria\r\n\r\nThe SMS 12V 220Ah Tubular Battery is built to deliver consistent, long-lasting backup power, making it an excellent choice for residential and commercial solar projects across Nigeria.\r\n\r\n', '2026-02-28 14:09:50', 'uploads/image_1_697f5528214638.54937276.jpg', 'uploads/image_2_697f55282159b1.48489391.jpg', NULL, 0, 'SMS', 'SMS, Battery, Tubular, 220ah, 12v, Power, Voltage', '[{\"title\":\"220Ah High Capacity\",\"detail\":\" Provides long backup time, allowing you to power essential appliances for extended hours during power outages\"},{\"title\":\"12V Output Voltage\",\"detail\":\"Compatible with most solar inverters and backup power systems used in homes and offices.\"},{\"title\":\"Advanced Tubular Plate Technology \",\"detail\":\" Ensures deeper discharge cycles, higher efficiency, and longer battery lifespan.\"},{\"title\":\"Carbon-Enhanced Active Material\",\"detail\":\"Charges faster, delivers higher energy output, and reduces sulphation for improved durability. \"},{\"title\":\"Deep Cycle Design\",\"detail\":\"Supports frequent charge and discharge cycles without rapid performance loss.   \"},{\"title\":\"Low Maintenance Operation\",\"detail\":\"Reduces the need for frequent water topping, saving time and maintenance costs.\"},{\"title\":\"Heat-Resistant Design\",\"detail\":\"Performs reliably in Nigeria\\u2019s hot climate, ensuring stable power supply.  \"},{\"title\":\"High Charge Acceptance\",\"detail\":\"Enables quicker charging from solar panels or generators.            \"},{\"title\":\"Stable Voltage Output\",\"detail\":\"Protects sensitive electronics from voltage fluctuations and improves appliance safety. \"}]', NULL),
(79, '5kwh Felicity Lithium Battery', 'Lithium Battery', 34, 1050000.00, 'uploads/image_main_697f6ecb90f3a8.36773727.jpg', '5kWh Felicity Lithium Battery – Reliable Energy Storage for Solar & Backup Power Systems\r\n\r\nThe 5kWh Felicity Lithium Battery is a high-performance, long-life energy storage solution designed for solar power systems, inverter backup solutions, and off-grid power applications. Built with advanced LiFePO₄ (Lithium Iron Phosphate) technology, this battery delivers superior safety, efficiency, durability, and deep discharge capability, making it ideal for both residential and commercial energy storage.\r\n\r\nWith its compact wall-mounted design, intelligent Battery Management System (BMS), and high charge-discharge efficiency, the Felicity 5kWh lithium battery ensures stable power supply, reduced generator dependency, and significant energy cost savings.\r\n\r\n\r\nBenefits:\r\n\r\n* Provides long-lasting backup power during outages\r\n* Maximizes solar energy usage and reduces electricity bills\r\n* Safer than traditional lead-acid batteries\r\n* Faster charging with minimal energy loss\r\n* Saves space with its slim wall-mounted design\r\n* Low maintenance and long operational lifespan\r\n* Reliable performance even in unstable power environments\r\n\r\n\r\nTechnical Specifications (Typical):\r\n\r\n* Battery Type: LiFePO₄ (Lithium Iron Phosphate)\r\n* Energy Capacity: 5kWh\r\n* Nominal Voltage: 51.2V\r\n* Usable Capacity: Up to 95%\r\n* Cycle Life: 6000+ cycles @ 80% DoD\r\n* Charge Voltage: 58.4V\r\n* Discharge Cut-off Voltage: 44.8V\r\n* Communication Ports: CAN / RS485\r\n* Installation: Wall Mounted\r\n* Operating Temperature: -20°C to 60°C\r\n\r\n\r\n\r\n\r\nApplications:\r\n\r\n* Home Solar Power Systems\r\n* Inverter Backup Solutions\r\n* Offices & Commercial Buildings\r\n* Estates & Apartment Complexes\r\n* Schools, Churches & Hospitals\r\n* Small Businesses & Retail Outlets\r\n\r\n\r\nWhy Choose Felicity Lithium Battery?\r\n\r\nFelicity Solar is a globally trusted brand known for high-quality lithium battery technology and dependable energy solutions. This 5kWh lithium battery offers exceptional safety, long lifespan, fast charging, and consistent performance, making it a smart investment for uninterrupted power supply.\r\n\r\n\r\n\r\n', '2026-02-01 15:18:35', 'uploads/image_1_697f6ecb910719.30022245.jpg', 'uploads/image_2_697f6ecb911405.49855305.jpg', NULL, 0, 'Felicity', '5kwh, Lithium Battery, fast charge, Long cycle, felicity', '[{\"title\":\"5kWh Energy Storage Capacity \",\"detail\":\"Provides reliable backup power for homes, offices, and small businesses during outages\"},{\"title\":\"LiFePO\\u2084 (Lithium Iron Phosphate) Technology \",\"detail\":\"Offers superior safety, thermal stability, and longer lifespan compared to lead-acid batteries\"},{\"title\":\"Long Cycle Life (6000+ cycles)\",\"detail\":\" Delivers many years of dependable service, reducing replacement costs\"},{\"title\":\"High Depth of Discharge (Up to 95%) \",\"detail\":\"Allows you to use more of the stored energy, maximizing battery efficiency\"},{\"title\":\"Built-in Smart Battery Management System (BMS) \",\"detail\":\"Protects against overcharge, over-discharge, overheating, and short circuits\"},{\"title\":\"High Charge & Discharge Efficiency \",\"detail\":\"Ensures faster charging and stable power output for connected loads\"},{\"title\":\"Compact Wall-Mount Design \",\"detail\":\"Saves floor space and allows neat, professional installation\"},{\"title\":\"LCD Display with Real-Time \",\"detail\":\"Monitoring Lets users easily monitor battery status, voltage, and charge level\"},{\"title\":\"Fast Charging Capability \",\"detail\":\"Reduces downtime and ensures quick energy replenishment\"},{\"title\":\"Stable Output Voltage \",\"detail\":\"Protects sensitive electronics and appliances\"},{\"title\":\"Parallel Connection Support \",\"detail\":\"Allows easy system expansion for higher energy storage capacity\"}]', NULL),
(80, 'Solar Street Light Camera', 'Solar Street Lights', 17, 150000.00, 'uploads/image_main_6985df7aeb3c78.48188454.jpeg', 'Solar Street Light Camera – All-in-One Security & Lighting Solution\r\n\r\nThe Solar Street Light Camera is a powerful dual-function outdoor security solution that combines high-brightness solar LED lighting with a smart surveillance camera in one sleek unit. Designed for 24/7 security monitoring and illumination, this system is ideal for streets, estates, compounds, parking lots, schools, farms, warehouses, factories, and remote locations.\r\n\r\nPowered entirely by solar energy, this unit eliminates electricity bills and works efficiently even in off-grid areas. The built-in 4K Ultra HD camera, motion detection system, and mobile app remote viewing provide real-time security monitoring directly from your smartphone — anytime, anywhere.\r\n\r\n\r\n\r\nBenefits:\r\n\r\n* Provides powerful outdoor lighting and real-time security surveillance\r\n* Operates 100% on solar power – no electricity or wiring required\r\n* Enhances security, visibility, and safety at night\r\n* Enables remote monitoring from your smartphone anywhere in the world\r\n* Reduces energy cost and eliminates generator dependence\r\n* Works perfectly in rural, remote, and off-grid areas\r\n* Easy installation with minimal maintenance\r\n\r\n\r\nTechnical Specifications (Typical):\r\n\r\n* Lighting Power: 500W LED\r\n* Camera Resolution: 4K Ultra HD\r\n* Power Source: High-efficiency solar panel + lithium battery\r\n* Night Vision: Infrared + full-color night vision\r\n* Connectivity: WiFi / 4G (model dependent)\r\n* Control: Mobile App (Android & iOS)\r\n* Protection Rating: IP65 Waterproof\r\n* Mounting: Pole / Wall Mount\r\n\r\n\r\nApplications:\r\n\r\n* Street & Road Lighting\r\n* Estate & Community Security\r\n* Farms & Agricultural Facilities\r\n* Schools & Churches\r\n* Warehouses & Factories\r\n* Parking Lots & Driveways\r\n* Construction Sites\r\n\r\n\r\nWhy Choose Our Solar Street Light Camera?\r\n\r\nThis solution offers maximum security + brilliant illumination + zero power bills. It is the perfect choice for locations requiring smart surveillance and dependable lighting without grid electricity.\r\n\r\n\r\n\r\n', '2026-02-06 12:32:58', 'uploads/image_1_697f75ffb517c9.11000475.jpg', 'uploads/image_2_697f75ffb53086.11710701.jpg', NULL, 0, 'Ubox', 'Street Light, Solar, Security, CCTV, 4K, HD, 500W, LED', '[{\"title\":\"All-in-One Solar Street Light + CCTV Camera\",\"detail\":\" Combines powerful lighting and smart surveillance in one unit, saving cost and installation space\"},{\"title\":\"4K Ultra HD Camera Resolution\",\"detail\":\" Delivers crystal-clear video for accurate monitoring, identification, and evidence\"},{\"title\":\"500W High-Brightness LED Light \",\"detail\":\"Provides very bright illumination, improving visibility and security at night\"},{\"title\":\"Solar Powered Operation\",\"detail\":\" Eliminates electricity bills and works perfectly in off-grid and remote locations\"},{\"title\":\"Built-in Lithium Battery \",\"detail\":\"Stores solar energy for reliable night-time operation and backup\"},{\"title\":\"Motion Detection Technology \",\"detail\":\"Detects movement and triggers alerts, improving proactive security\"},{\"title\":\"Mobile App Remote Viewing \",\"detail\":\"Allows real-time monitoring and control from anywhere using your smartphone\"},{\"title\":\"Night Vision (Infrared + Full Color) \",\"detail\":\"Ensures clear video monitoring even in total darkness\"},{\"title\":\"Auto Dusk-to-Dawn Lighting Control\",\"detail\":\" Automatically turns light ON at night and OFF during the day for convenience\"},{\"title\":\"Wide-Angle Camera Lens \",\"detail\":\"Covers larger areas, reducing the number of cameras required\"},{\"title\":\"Weatherproof IP65 Outdoor Design \",\"detail\":\"Withstands rain, dust, heat, and harsh outdoor conditions\"},{\"title\":\"Easy Installation (No Wiring Required) \",\"detail\":\"Saves installation time and cost, no electrician needed\"}]', NULL);
INSERT INTO `products` (`id`, `name`, `category`, `category_id`, `price`, `image_main`, `description`, `created_at`, `image_1`, `image_2`, `image_3`, `is_featured`, `brand`, `tags`, `specifications`, `sub_category_id`) VALUES
(81, 'Smarten 1.7kva 24v Transformer Based Inverter', '1.7kva Inverter', 36, 240000.00, 'uploads/image_main_697f7ce77d0a94.54772308.jpg', 'Smarten 1.7kVA 24V Transformer-Based Inverter – Reliable Backup Power for Homes & Offices\r\n\r\nThe Smarten 1.7kVA 24V Transformer-Based Inverter is a durable, high-performance power backup solution designed to deliver stable, clean, and uninterrupted electricity for homes, offices, and small businesses. Built with advanced DSP-based technology and a heavy-duty transformer design, this inverter provides excellent load handling capacity, voltage stability, and long-term reliability.\r\n\r\nWith its pure sine wave output, the Smarten 1.7kVA inverter safely powers sensitive electronics, home appliances, and office equipment, ensuring smooth operation without damage or noise. Its rugged build quality and efficient charging system make it ideal for Nigeria’s unstable grid environment.\r\n\r\n\r\nBenefits:\r\n\r\n* Provides stable and uninterrupted power supply during outages\r\n* Safely powers TVs, refrigerators, fans, lights, computers, routers, and CCTV systems\r\n* Handles high surge loads such as fridges and pumps with ease\r\n* Protects connected devices from voltage fluctuations and power spikes\r\n* Ensures long battery life with smart charging technology\r\n* Performs reliably even under unstable grid conditions\r\n\r\n\r\n\r\nTechnical Specifications (Typical):\r\n\r\n* Rated Power: 1.7kVA\r\n* DC Input Voltage: 24V\r\n* Battery Requirement: 2 × 12V batteries\r\n* Waveform: Pure Sine Wave\r\n* Charging Current: 15–25A (model dependent)\r\n* Efficiency: ≥85%\r\n* Display: LCD\r\n* Protections: Overload, short circuit, over-temperature, battery overcharge & deep discharge\r\n\r\n\r\nIdeal Applications:\r\n\r\n* Homes & Apartments\r\n* Offices & Workspaces\r\n* Shops & Small Businesses\r\n* CCTV & Security Systems\r\n* Internet & Communication Equipment\r\n\r\n\r\n\r\nWhy Choose Smarten Inverters?\r\n\r\nSmarten is a trusted global inverter brand, known for durability, stable performance, and excellent power management technology. This 1.7kVA inverter offers excellent value, dependable backup power, and long service life, making it perfect for Nigeria’s power conditions.\r\n\r\n', '2026-02-01 16:18:47', 'uploads/image_1_697f7ce77d2002.61191489.jpg', 'uploads/image_2_697f7ce77d2fd5.46077018.jpg', NULL, 0, 'SMARTEN', '1.7kva, Smarten, Inverter, Solar, Transformer, 24v', '[{\"title\":\"1.7kVA Power Output \",\"detail\":\"Provides reliable backup power for essential home and office appliances\"},{\"title\":\"24V DC System (2 \\u00d7 12V Batteries)\",\"detail\":\" Improves efficiency, reduces current loss, and supports longer backup time\"},{\"title\":\"Pure Sine Wave Output \",\"detail\":\"Safely powers sensitive electronics like TVs, laptops, routers, and CCTV systems\"},{\"title\":\"Heavy-Duty Transformer-Based Design \",\"detail\":\"Handles high surge loads and offers long-lasting durability\"},{\"title\":\"DSP-Based Smart Control Technology\",\"detail\":\" Ensures stable voltage, better performance, and system protection\"},{\"title\":\"Fast Battery Charging System \",\"detail\":\"Reduces charging time and ensures batteries are quickly ready for use\"},{\"title\":\"Wide Input Voltage Range \",\"detail\":\"Works efficiently even in unstable grid power conditions\"},{\"title\":\"LCD Digital Display \",\"detail\":\"Allows easy monitoring of system status, battery level, and fault alerts\"},{\"title\":\"Intelligent Protection System \",\"detail\":\"Protects against overload, short circuit, overheating, and battery damage\"},{\"title\":\"High Efficiency Operation \",\"detail\":\"Minimizes power loss, saving energy and improving backup performance\"},{\"title\":\"Rugged Build Quality \",\"detail\":\"Designed for long-term use in tough Nigerian power environments\"},{\"title\":\"Compatible with Tubular & Lithium Batteries \",\"detail\":\"Offers flexible battery options to match budget and backup needs\"}]', NULL),
(82, '4G V380 Triple Lens Solar Camera (DS-90)', '4G CCTV', 21, 110000.00, 'uploads/image_main_6985c784ed27f1.53977108.jpeg', '4G V380 Triple Lens Solar Camera – Advanced Solar-Powered Smart Surveillance\r\n\r\nThe 4G V380 Triple Lens Solar Camera is a next-generation outdoor security solution designed for maximum coverage, total independence, and smart monitoring in locations without stable power or Wi-Fi. Built with a triple-lens PTZ camera system, 4G LTE connectivity, and a high-efficiency solar power setup, this camera delivers 24/7 intelligent surveillance for homes, businesses, farms, construction sites, and remote properties.\r\n\r\nWith its wide-angle triple camera design, the V380 Solar Camera captures more area with fewer blind spots, while the pan-tilt-zoom (PTZ) function allows remote viewing and tracking from anywhere via the V380 Pro mobile app. The solar-powered battery system ensures continuous operation, making it ideal for Nigeria’s power challenges and off-grid installations.\r\n\r\n\r\nBenefits:\r\n\r\n* Works perfectly in areas without electricity or Wi-Fi\r\n* Covers large spaces with fewer cameras\r\n* Provides 24/7 security using solar energy\r\n* Sends real-time motion alerts to your smartphone\r\n* Allows remote monitoring and control from anywhere\r\n* Delivers clear night footage with color and infrared modes\r\n* Deters intruders using two-way audio communication\r\n* Reduces installation cost with fully wireless setup\r\n\r\n\r\n\r\nTechnical Specifications (Typical):\r\n\r\n* Camera Type: Triple Lens PTZ\r\n* Network: 4G LTE (SIM Card)\r\n* Power Source: Solar Panel + Rechargeable Battery\r\n* Rotation: Up to 355° Pan / 90° Tilt\r\n* Night Vision: Infrared & Full-Color LEDs\r\n* Audio: Two-Way Audio\r\n* Storage: MicroSD Card (up to 128GB) & Cloud\r\n* App Support: V380 Pro (Android & iOS)\r\n* Protection Rating: IP66 Weatherproof\r\n\r\n\r\n\r\nIdeal Applications:\r\n\r\n* Homes & Compounds\r\n* Offices & Business Premises\r\n* Construction Sites\r\n* Farms & Agricultural Land\r\n* Warehouses & Yards\r\n* Remote Locations & Off-Grid Areas\r\n* Gates, Perimeters & Driveways\r\n\r\n\r\n\r\nWhy Choose the 4G V380 Triple Lens Solar Camera?\r\n\r\nThe 4G V380 Triple Lens Solar Camera offers a perfect blend of smart technology, solar power efficiency, and wide-area surveillance. Designed for reliability, flexibility, and ease of use, it eliminates the need for cables, power supply, and Wi-Fi—making it a cost-effective and dependable security solution** for Nigeria’s environment.\r\n\r\n\r\n\r\n', '2026-02-06 10:50:44', 'uploads/image_1_69808a37ee0f45.87567805.jpg', 'uploads/image_2_69808a37ee2488.13098714.jpg', NULL, 0, 'DA BLINK', '4G, LTE, Triple Lens, PTZ, Solar, CCTV, AI Motion, Infrared', '[{\"title\":\"4G LTE SIM Card Connectivity \",\"detail\":\"Works anywhere without Wi-Fi, ideal for remote areas, farms, and construction sites\"},{\"title\":\"Triple Lens Camera System \",\"detail\":\"Covers wider areas with fewer blind spots, reducing the need for multiple cameras\"},{\"title\":\"PTZ (Pan-Tilt-Zoom) Function\",\"detail\":\" Remotely rotate and zoom the camera to monitor large spaces in real time\"},{\"title\":\"Solar-Powered with Built-in Battery \",\"detail\":\"Operates 24\\/7 without electricity, lowering running costs and power dependence\"},{\"title\":\"Full-Color & Infrared Night Vision \",\"detail\":\"Clear, detailed surveillance day and night, even in total darkness\"},{\"title\":\"AI Motion Detection\",\"detail\":\" Detects human movement accurately and reduces false alarms\"},{\"title\":\"Instant Mobile Alerts \",\"detail\":\"Get real-time notifications on your phone when motion is detected\"},{\"title\":\"Two-Way Audio Communication \",\"detail\":\"Talk to visitors or warn intruders remotely from anywhere\"},{\"title\":\"Weatherproof Outdoor Design (IP66) \",\"detail\":\"Reliable performance in rain, heat, and harsh outdoor conditions\"},{\"title\":\"MicroSD & Cloud Storage Support \",\"detail\":\"Flexible recording options with secure video backup\"},{\"title\":\"Wireless Installation\",\"detail\":\" Quick setup with no cables, trenching, or complex wiring\"}]', NULL),
(83, '50W Solar Ceiling Light', 'Ceiling Light', 37, 50000.00, 'uploads/image_main_697f8d11c6c474.54929456.jpg', '50W Solar Ceiling Light – Bright, Reliable Indoor Solar Lighting Solution\r\n\r\nThe 50W Solar Ceiling Light is a high-brightness, energy-efficient indoor lighting solution designed to provide long-lasting illumination without electricity. Powered by a high-efficiency solar panel and built-in lithium battery, this ceiling light delivers reliable lighting for 8–12 hours on a full charge—making it ideal for homes, shops, offices, and off-grid locations.\r\n\r\nDesigned for easy indoor installation, the solar panel is mounted outdoors to absorb sunlight while the ceiling light is installed indoors, ensuring clean, silent, and cost-free lighting every night. With its energy-saving mode and remote control operation, the 50W Solar Ceiling Light is a practical answer to Nigeria’s frequent power outages.\r\n\r\n\r\nBenefits:\r\n\r\n* Provides free lighting with zero electricity bills\r\n* Ideal for areas with unstable or no power supply\r\n* Lights up rooms for long hours throughout the night\r\n* Easy to install with no wiring or inverter required\r\n* Offers convenient control using the remote\r\n* Reduces fuel and generator dependence\r\n* Safe, eco-friendly, and cost-effective lighting option\r\n\r\n\r\n\r\nTechnical Specifications (Typical):\r\n\r\n* Power Rating: 50W\r\n* Lighting Time: 8–12 hours (fully charged)\r\n* Battery Type: Rechargeable Lithium Battery\r\n* Charging Source: Solar Panel\r\n* Control: Remote Control\r\n* Installation: Indoor Ceiling Mount\r\n* Lighting Mode: Normal & Energy-Saving Mode\r\n* Application: Indoor Use\r\n\r\n\r\n\r\nIdeal Applications:\r\n\r\n* Homes & Apartments\r\n* Shops & Stores\r\n* Offices & Workspaces\r\n* Bedrooms & Living Rooms\r\n* Shops in Markets\r\n* Rural & Off-Grid Homes\r\n* Backup Lighting for Power Outages\r\n\r\n\r\n\r\nWhy Choose the 50W Solar Ceiling Light?\r\n\r\nThe 50W Solar Ceiling Light offers a simple, affordable, and dependable lighting solution for everyday use. With long battery life, bright illumination, and zero running cost, it is perfectly suited for Nigeria’s power challenges. It delivers comfort, convenience, and peace of mind without reliance on PHCN, generators, or inverters.\r\n\r\n\r\n\r\n', '2026-02-01 17:28:54', NULL, NULL, NULL, 0, 'Other ', '50w, Ceiling, Light, Led, Solar', '[{\"title\":\"50W High-Brightness LED Output \",\"detail\":\"Provides bright and clear lighting suitable for rooms, shops, and offices\"},{\"title\":\"Solar-Powered System \",\"detail\":\"Eliminates electricity bills and works during power outages\"},{\"title\":\"External High-Efficiency Solar Panel\",\"detail\":\" Charges faster and performs well even in moderate sunlight\"},{\"title\":\"Built-In Long-Lasting Lithium Battery \",\"detail\":\"Stores enough power to last throughout the night\"},{\"title\":\"8\\u201312 Hours Lighting Time \",\"detail\":\"Ensures continuous lighting from evening till morning\"},{\"title\":\"Energy-Saving Mode \",\"detail\":\" Extends battery life and improves night-long performance\"},{\"title\":\"Remote Control Operation\",\"detail\":\" Allows easy ON\\/OFF and mode control without getting up\"},{\"title\":\"Indoor Ceiling Mount Design \",\"detail\":\"Neat, space-saving installation with uniform light distribution\"},{\"title\":\"Instant Full Brightness \",\"detail\":\"Lights up immediately with no delay or flicker\"},{\"title\":\"Low Heat & Silent Operation \",\"detail\":\"Safe for indoor use and comfortable for living spaces\"},{\"title\":\"No Wiring or Generator Required \",\"detail\":\" Quick installation and reduced setup cost\"}]', NULL),
(84, 'Felicity Solar 5KVA 48v Hybrid High-Frequency Inverter', '5kva inverter', 38, 750000.00, 'uploads/image_main_69809e8d8a45a1.77978969.png', 'Felicity Solar 5KVA 48v Power Inverter\r\n\r\nThe Felicity Solar 5KVA 48V Power Inverter is a rugged, high-performance solar inverter engineered for residential and small commercial off-grid solar systems. Built to deliver reliable power conversion, this inverter efficiently transforms DC energy from solar panels or battery banks into clean AC electricity for everyday appliances, tools, and electronics.\r\n\r\nDesigned with advanced inverter technology, the Felicity Solar 5KVA delivers stable, uninterrupted power with excellent surge capacity — making it ideal for homes, offices, shops, and rural installations where grid supply may be inconsistent or unavailable.\r\n\r\nFeaturing a 48V input configuration, this inverter integrates seamlessly with high-capacity battery banks, optimizing performance and extending battery life. The high-definition LCD display provides real-time system data, including voltage, frequency, load percentage, and battery status, enabling easy monitoring and control.\r\n\r\nDurable and built for the long term, the Felicity Solar 5KVA inverter includes protections such as over-load cutoff, short-circuit protection, reverse polarity detection, and over-temperature shutdown to safeguard both the inverter and connected devices.\r\n\r\nWhether you’re powering lights, fans, televisions, refrigerators, or office equipment, the Felicity Solar 5KVA 48V Power Inverter offers dependable performance and peace of mind — all in a sleek, modern design.\r\n\r\nIdeal For:\r\n\r\n* Residential solar power systems\r\n\r\n* Off-grid cabins and rural homes\r\n\r\n* Shops, offices, small businesses\r\n\r\n* Backup power during grid outages\r\n\r\n* Renewable energy installations', '2026-02-07 09:26:01', 'uploads/image_1_69809e8d8a86e5.22418963.jpg', 'uploads/image_2_69809e8d8a9201.75937921.jpg', NULL, 0, 'Felicity', 'Felicity, Solar, 5KVA, 48v, Power, Inverter', '[{\"title\":\"Power Output\",\"detail\":\"5000VA (5kVA) continuous power capability\"},{\"title\":\"Input Voltage\",\"detail\":\"48V DC \\u2014 ideal for large battery banks\"},{\"title\":\"Pure\\/Modified Sine Wave Output\",\"detail\":\"Stable AC power\"},{\"title\":\"Advanced Protection\",\"detail\":\"Overload, short circuit, over temperature, reverse polarity\"},{\"title\":\"LCD Display\",\"detail\":\"Clear real-time performance readout\"},{\"title\":\"Reliable Design\",\"detail\":\" Long service life and efficient performance\"},{\"title\":\"Easy Integration\",\"detail\":\"Works with solar panels, battery banks, and generators\"}]', NULL),
(85, 'Felicity Solar 3KVA 24V Hybrid Inverter With Inbuilt 4000W MPPT Controller', '3kva inverter', 39, 384000.00, 'uploads/image_main_6980b80dd369e7.77032702.jpeg', 'Felicity Solar 3KVA 24V Hybrid Inverter With Inbuilt 4000W MPPT Controller\r\n\r\nThe Felicity Solar 3KVA 24V Hybrid Inverter with Inbuilt 4000W MPPT Controller is a high-performance all-in-one solar inverter designed to deliver reliable, efficient, and uninterrupted power for homes, offices, shops, schools, and small businesses. It intelligently combines solar power, battery storage, and grid electricity to ensure stable power supply even during outages.\r\n\r\nEquipped with a powerful 4000W MPPT solar charge controller, this inverter maximizes energy harvest from your solar panels, delivering faster battery charging, higher efficiency, and reduced energy losses. Its wide AC input voltage range (90–280V) makes it perfectly suited for Nigeria’s unstable grid conditions, ensuring smooth operation and enhanced system protection.\r\n\r\nThe inverter supports grid, solar, and battery priority modes, allowing users to customize power usage based on energy availability and cost-saving preferences. With advanced intelligent protection systems, this inverter ensures safe operation against overload, short-circuit, over-voltage, and overheating.\r\n\r\nDesigned with durability, smart control, and performance in mind, the Felicity Solar 3KVA Hybrid Inverter is ideal for 24/7 power backup and dependable solar energy systems.\r\n\r\nIdeal Applications:\r\n\r\nHomes • Offices • Shops • Schools • Hospitals • Clinics • Small Businesses • Solar Backup Systems', '2026-02-07 09:24:11', 'uploads/image_1_6980b80dd38879.59747393.jpg', 'uploads/image_2_6980b80dd39713.58568621.jpg', NULL, 0, 'Felicity', 'Felicity Solar, 3KVA, 24V, Hybrid Inverter, Inbuilt 4000W MPPT Controller', '[{\"title\":\"3KVA \\/ 2400W Output Capacity \",\"detail\":\"Powers essential home and office appliances like TVs, fans, lights, laptops, routers, and small fridges without interruptions.\"},{\"title\":\"24V Battery System \",\"detail\":\"Enables efficient battery usage, improved system stability, and reduced power losses.\"},{\"title\":\"Inbuilt 4000W MPPT Solar Charge Controller \",\"detail\":\"Maximizes solar energy harvest, charges batteries faster, and improves overall system efficiency.\"},{\"title\":\"Wide PV Input Range (120\\u2013450V DC) \",\"detail\":\"Supports flexible solar panel configurations, allowing easy system expansion and design freedom.\"},{\"title\":\"Hybrid Operation (Solar + Battery + Grid) \",\"detail\":\"Automatically switches between power sources for uninterrupted electricity supply.\"},{\"title\":\"Pure Sine Wave Output \",\"detail\":\"Provides clean and stable power, protecting sensitive electronics like TVs, laptops, and medical devices.\"},{\"title\":\"Wide AC Input Voltage Range (90\\u2013280V) \",\"detail\":\"Works reliably even with Nigeria\\u2019s unstable grid power, preventing shutdowns and damage.\"},{\"title\":\"Intelligent Charging Priority Settings\",\"detail\":\" Allows users to prioritize solar charging to reduce electricity bills and generator usage.\"},{\"title\":\"Advanced Protection System\",\"detail\":\" Protects against overload, short circuit, overheating, and overvoltage, ensuring safety and long lifespan.\"},{\"title\":\"LCD Display & Smart Control Panel\",\"detail\":\" Enables easy monitoring of battery level, load usage, charging status, and system performance.\"},{\"title\":\"High Conversion Efficiency\",\"detail\":\" Reduces energy loss, giving more usable power from your solar and battery system.\"},{\"title\":\"Wall-Mount Compact Design \",\"detail\":\"Saves installation space and ensures neat, professional setup.\"}]', NULL),
(87, '2.5kVA 24V Glow Energy Inverter', '2.5kva', 40, 296000.00, 'uploads/image_main_6989e0a9861878.99053853.jpeg', '2.5kVA 24V Glow Energy Inverter\r\n\r\nThe 2.5kVA 24V Glow Energy Inverter is a reliable power backup solution designed to keep your essential appliances running smoothly during outages. Built for efficiency, durability, and stable performance, it’s ideal for homes, offices, shops, and small businesses.\r\n\r\nWith a 24V battery system, this inverter delivers better efficiency and longer backup time compared to lower-voltage systems, while maintaining steady power output that protects your electronics.\r\n\r\n\r\nIdeal For:\r\n\r\n* Homes and apartments\r\n* Offices and workspaces\r\n* Shops and small businesses\r\n* CCTV systems and networking equipment\r\n\r\nWhy Choose Glow Energy?\r\n\r\nGlow Energy inverters are known for their stable performance, long lifespan, and dependable power delivery, making them a trusted choice for everyday backup power needs.\r\n\r\n', '2026-02-09 13:32:10', 'uploads/image_1_6989e0a9863248.22234185.jpeg', 'uploads/image_2_6989e1da0eb6e5.31453427.jpeg', 'uploads/image_3_6989e0a9864dd6.01269682.jpeg', 0, 'Glow Energy ', '2.5kva, 2500VA, 24V, Inverter, Pure Sine, Power, Electricity ', '[{\"title\":\"2.5kVA \\/ 2500VA capacity \",\"detail\":\" powers TVs, fans, lights, laptops, routers, and more\"},{\"title\":\"24V battery system\",\"detail\":\"improved efficiency and reduced current loss\"},{\"title\":\"Pure sine wave output\",\"detail\":\"safe for sensitive electronics\"},{\"title\":\"Smart LCD display\",\"detail\":\"shows battery level, load status, and system alerts\"},{\"title\":\"Built-in protection\",\"detail\":\"overload, short-circuit, low battery, and over-temperature protection\"},{\"title\":\"Fast switching\",\"detail\":\"seamless transition during power outages\"},{\"title\":\"Silent operation\",\"detail\":\"no noise, no fumes\"}]', NULL),
(88, 'Complete 0.75hp Solar Borehole Installation Kit', '0.75hp', 42, 860000.00, 'uploads/image_main_6989ea9ac17141.91058652.jpeg', 'Complete 0.75HP Solar Borehole Installation Kit\r\n\r\nThe Complete 0.75HP Solar Borehole Installation Kit is a fully integrated water-pumping solution designed to deliver consistent, off-grid water supply using clean solar energy. It’s ideal for homes, farms, schools, estates, and small commercial facilities looking to eliminate fuel costs, generator noise, and power outages.\r\n\r\nThis system combines a high-efficiency 0.75HP DC submersible pump with three high-output solar panels, ensuring strong water flow even under varying sunlight conditions.\r\n\r\nWhat’s Included:\r\n\r\n* 0.75HP DC submersible solar pump – efficient, durable, and designed for borehole use\r\n* 3 × 450W solar panels – high power output for optimal pumping performance\r\n* 2-core PV solar cable – durable and weather-resistant for long-term outdoor use\r\n* Complete system configuration – ready for professional installation\r\n\r\nIdeal For:\r\n\r\n* Residential boreholes\r\n* Farms and irrigation systems\r\n* Schools and hospitals\r\n* Estates and remote locations\r\n* Small commercial water projects\r\n\r\nWhy Choose This Kit?\r\n\r\nThis kit is engineered to provide maximum efficiency, long-term reliability, and energy independence, making it a smart investment for anyone looking to secure water supply without rising electricity or fuel costs.\r\n\r\n', '2026-02-09 14:09:30', NULL, NULL, NULL, 0, 'Other', '0.75, DC, Pump, Solar, 450W', '[{\"title\":\"0.75HP DC Submersible Solar Pump\",\"detail\":\"Pumps water efficiently from boreholes without relying on electricity or fuel\"},{\"title\":\"100% Solar Powered System\",\"detail\":\"Enjoy free energy from the sun with zero monthly power or fuel costs\"},{\"title\":\"3 \\u00d7 450W High-Efficiency Solar Panels \",\"detail\":\"Provides strong, consistent pumping performance even in moderate sunlight\"},{\"title\":\"Direct DC Operation (No Inverter Required)\",\"detail\":\"Fewer components, lower failure risk, and higher system reliability\"},{\"title\":\"Durable Submersible Pump Design\",\"detail\":\"Built to withstand continuous use and harsh borehole conditions\"},{\"title\":\"Low Maintenance System\",\"detail\":\"Saves you money and time on repairs and servicing\"},{\"title\":\"Silent Operation\",\"detail\":\"No noise pollution compared to generators\"},{\"title\":\"Eco-Friendly Energy Source\",\"detail\":\"Reduces carbon emissions and environmental impact\"},{\"title\":\"Off-Grid Capability\",\"detail\":\"Ideal for rural or remote areas with unstable or no electricity\"},{\"title\":\"Complete Installation Kit\",\"detail\":\"Everything needed for setup, reducing installation delays and extra costs\"}]', NULL),
(89, 'Complete 1hp Solar Borehole Installation Kit', '1hp', 43, 887500.00, 'uploads/image_main_6989ee6e442fb8.14741696.jpeg', 'Complete 1HP Solar Borehole Installation Kit\r\n\r\nThe Complete 1HP Solar Borehole Installation Kit is a powerful, reliable water-pumping solution designed for homes, farms, estates, and commercial properties that need a consistent water supply without relying on grid electricity or fuel.\r\n\r\nThis system runs 100% on solar energy, delivering strong water pressure and high output using a durable 1HP DC submersible pump. It is ideal for deep boreholes and locations with unreliable or no power supply.\r\n\r\nEquipped with three high-efficiency 450W solar panels, the system captures ample sunlight to ensure steady water flow throughout the day. The direct DC setup eliminates the need for an inverter, reducing energy loss, maintenance costs, and system complexity.\r\n\r\nBuilt for long-term outdoor and submersible use, the pump is corrosion-resistant, energy-efficient, and designed to operate quietly. This complete kit is perfect for users looking to cut fuel costs, eliminate generator noise, and enjoy a sustainable, low-maintenance water solution.\r\n\r\nWhat’s Included:\r\n\r\n* 1HP DC Submersible Solar Pump\r\n* 3 × 450W High-Efficiency Solar Panels\r\n* 2-Core PV Solar Cable\r\n* 1-Year Warranty\r\n\r\n\r\nIdeal For:\r\n\r\n* Residential homes\r\n* Farms and irrigation systems\r\n* Estates and apartment buildings\r\n* Schools, hotels, and commercial properties\r\n* Off-grid and rural locations\r\n', '2026-02-09 14:25:50', NULL, 'uploads/image_2_6989ee6e446252.37022349.jpeg', NULL, 0, 'Other', '1hp, Solar, Dc, Pump, Borehole, ', '[{\"title\":\"1HP DC Submersible Solar Pump\",\"detail\":\"Pumps water efficiently from deep boreholes with strong, reliable pressure\"},{\"title\":\"Runs 100% on Solar Energy\",\"detail\":\"No electricity bills, fuel costs, or generator dependence\"},{\"title\":\"3 \\u00d7 450W High-Efficiency Solar Panels\",\"detail\":\"Delivers steady water flow even during moderate sunlight\"},{\"title\":\"Direct DC System (No Inverter Needed)\",\"detail\":\"Fewer components, lower maintenance, and higher energy efficiency\"},{\"title\":\"Corrosion-Resistant Stainless Steel Pump\",\"detail\":\"Long-lasting performance in harsh water and soil conditions\"},{\"title\":\"High Water Output Capacity\",\"detail\":\"Suitable for homes, farms, estates, and commercial use\"},{\"title\":\"Quiet Operation\",\"detail\":\"No noise pollution compared to fuel generators\"},{\"title\":\"Off-Grid Capability\",\"detail\":\"Perfect for rural areas and locations with unreliable power\"},{\"title\":\"2-Core PV Solar Cable Included\",\"detail\":\"Safe, efficient power transmission from panels to pump\"},{\"title\":\"1-Year Warranty\",\"detail\":\"Peace of mind and protection after purchase\"}]', NULL),
(90, 'Complete 1.5hp Solar Borehole Installation Kit', '1.5hp', 44, 1180000.00, 'uploads/image_main_6989f268345e40.97157756.jpeg', 'Complete 1.5HP Solar Borehole Installation Kit\r\n\r\nThe Complete 1.5HP Solar Borehole Installation Kit is a high-capacity, off-grid water pumping solution designed for homes, farms, estates, schools, and commercial properties that require strong, reliable water supply without dependence on PHCN or generators.\r\n\r\nPowered by high-efficiency solar panels and a durable 1.5HP AC/DC submersible pump, this system delivers consistent water flow even in areas with unstable electricity. The included solar borehole charge controller ensures safe, optimized performance while protecting the pump and system components.\r\n\r\nBuilt for Nigerian conditions, this kit is ideal for deep boreholes, large households, agricultural irrigation, and high-demand water usage.\r\n\r\nWhat’s Included:\r\n\r\n* 1.5HP AC/DC Submersible Borehole Pump – strong water pressure for deep wells\r\n* 4 × 600W High-Efficiency Solar Panels – reliable energy generation for continuous pumping\r\n* Solar Borehole Charge Controller – regulates power and protects the pump\r\n* 4-Core Solar Borehole Cable – durable cable for underground pump connection\r\n* 2-Core PV Solar Cable – efficient power transmission from panels\r\n* Complete Installation Components\r\n\r\nIdeal For:\r\n\r\n* Residential buildings\r\n* Farms and irrigation systems\r\n* Estates and apartment complexes\r\n* Schools, hospitals, and commercial facilities\r\n* Remote or off-grid locations\r\n\r\n\r\n', '2026-02-09 14:42:48', 'uploads/image_1_6989f268347861.35786444.jpeg', 'uploads/image_2_6989f2683482d0.56242753.jpeg', NULL, 0, 'Other', '1.5hp, Solar, Borehole, Pump, DC', '[{\"title\":\"1.5HP AC\\/DC Submersible Borehole Pump\",\"detail\":\"Delivers strong water pressure for deep boreholes and high daily water demand\"},{\"title\":\"4 \\u00d7 600W High-Efficiency Solar Panels\",\"detail\":\"Generates enough power for consistent pumping without electricity or fuel\"},{\"title\":\"Solar Borehole Charge Controller\",\"detail\":\"Protects the pump from power fluctuations and extends system lifespan\"},{\"title\":\"Works Fully Off-Grid\",\"detail\":\"Reliable water supply even in areas with no PHCN or frequent outages\"},{\"title\":\"4-Core Solar Borehole Cable\",\"detail\":\"Safe, durable underground connection for long-term use\"},{\"title\":\"2-Core PV Solar Cable\",\"detail\":\"Efficient power transfer from panels to the controller\"},{\"title\":\"Low Maintenance System\",\"detail\":\"Saves money over time with minimal servicing required\"},{\"title\":\"Quiet Operation\",\"detail\":\"No noise pollution unlike generators\"},{\"title\":\"Eco-Friendly Solar Power\",\"detail\":\"Reduces carbon footprint and ongoing energy costs\"},{\"title\":\"Designed for Nigerian Conditions\",\"detail\":\"Built to withstand heat, dust, and harsh environments\"}]', NULL),
(91, 'Complete 2hp Solar Borehole Installation Kit', '2hp', 45, 1250000.00, 'uploads/image_main_699078dde3bd31.92513227.jpeg', 'Complete 2HP Solar Borehole Installation Kit\r\n\r\nThe Complete 2HP Solar Borehole Installation Kit is a powerful, off-grid water pumping solution designed for large homes, farms, estates, schools, hotels, and commercial facilities with high daily water demand. Built to operate efficiently on solar power, this system delivers strong, consistent water flow without reliance on grid electricity or fuel.\r\n\r\nPowered by four high-capacity 600W solar panels, the system drives a 2HP AC/DC submersible borehole pump, ensuring reliable water supply even in deep boreholes and challenging environments. The included solar borehole charge controller intelligently manages power from the panels, protecting the pump and optimizing performance throughout the day.\r\n\r\nThis kit is engineered for durability, low maintenance, and long-term cost savings, making it an ideal solution for areas with unstable electricity or no grid access at all.\r\n\r\n\r\nWhat’s Included:\r\n\r\n* 2HP AC/DC Submersible Borehole Pump – High-power pump for deep boreholes and heavy water usage\r\n* 4 × 600W Solar Panels – High-efficiency panels for reliable daytime pumping\r\n* Solar Borehole Charge Controller** – Protects and regulates power to extend pump lifespan\r\n* 4-Core Solar Borehole Cable – Durable cable suitable for underground borehole installations\r\n* 2-Core PV Solar Cable – Efficient energy transfer from panels to controller\r\n\r\n\r\nWhy Choose This System?\r\n\r\n* Runs completely off-grid — no NEPA, no generator, no fuel\r\n* Handles high water demand effortlessly\r\n* Low operating cost after installation\r\n* Quiet and eco-friendly operation\r\n* Designed for harsh Nigerian weather conditions\r\n* Ideal for commercial and large-scale residential use\r\n\r\n', '2026-02-14 13:30:05', NULL, 'uploads/image_2_699078dde3da49.99262016.jpeg', NULL, 0, 'Other', '2hp, solar, borehole, kit, pump', '[{\"title\":\"2HP AC\\/DC Submersible Borehole Pump\",\"detail\":\"Delivers strong water pressure and high flow rate, ideal for deep boreholes and heavy daily water usage\"},{\"title\":\"AC\\/DC Dual Power Compatibility\",\"detail\":\"Can run directly on solar power and automatically adapt when power conditions change\"},{\"title\":\"4 \\u00d7 600W High-Efficiency Solar Panels\",\"detail\":\"Generates sufficient power to run the pump efficiently without batteries or fuel\"},{\"title\":\"Solar Borehole Charge Controller\",\"detail\":\"Protects the pump from power fluctuations and maximizes system lifespan\"},{\"title\":\"Deep Borehole Capability\",\"detail\":\"Suitable for farms, estates, hotels, schools, and commercial facilities\"},{\"title\":\"4-Core Solar Borehole Cable\",\"detail\":\"Safe, durable underground wiring designed for long-term borehole use\"},{\"title\":\"2-Core PV Solar Cable\",\"detail\":\"Ensures efficient energy transfer from solar panels to the controller\"},{\"title\":\"Off-Grid Operation\",\"detail\":\"Works without NEPA, generator, or fuel\\u2014perfect for remote or low-power areas\"},{\"title\":\"Low Maintenance Design\",\"detail\":\"Minimal servicing required, saving money over time\"}]', NULL),
(92, '1.5HP Astra AC/DC Solar Submersible Pump', '1.5hp Solar Submersible Pump', 47, 470000.00, 'uploads/image_main_69907e0f5a17e4.93007766.jpeg', '1.5HP Astra AC/DC Solar Submersible Pump\r\n\r\nReliable. Energy-Efficient. Built for Deep Boreholes.\r\n\r\nThe 1.5HP Astra AC/DC Solar Submersible Pump is a powerful and durable water pumping solution designed for homes, farms, estates, schools, and commercial properties. Engineered to run on both solar power (DC) and electricity/generator supply (AC), it guarantees consistent water supply — even in areas with unstable power.\r\n\r\nWhether you\'re installing a new borehole or upgrading your current system, this pump delivers strong water output, long lifespan, and energy savings in one efficient unit.\r\n\r\n\r\nWhy Choose the 1.5HP Astra AC/DC Solar Pump?\r\n\r\n* Dual Power Flexibility (AC/DC Technology)\r\nRuns directly on solar panels during the day and switches to PHCN or generator when needed — giving you uninterrupted water supply.\r\n\r\n* High Performance 1.5HP Motor\r\nProvides strong pumping capacity suitable for medium to deep boreholes, ensuring steady water flow for residential and light commercial use.\r\n\r\n* Stainless Steel Body\r\nBuilt with corrosion-resistant stainless steel to withstand harsh borehole conditions, sand particles, and long-term submersion.\r\n\r\n* Energy Efficient Operation\r\nDesigned to reduce electricity costs by maximizing solar energy usage, helping you save money long-term.\r\n\r\n* Smart Controller Compatibility\r\nWorks with a solar pump controller for voltage regulation, dry-run protection, overload protection, and system safety.\r\n\r\n* Low Maintenance Design\r\nDurable internal components minimize wear and tear, reducing maintenance frequency and downtime.\r\n\r\n\r\nIdeal For:\r\n\r\n* Residential homes\r\n* Farms & irrigation systems\r\n* Schools & hospitals\r\n* Estates & apartment buildings\r\n* Areas with unstable electricity\r\n\r\n\r\nKey Benefits at a Glance\r\n\r\n✔ Lower electricity bills\r\n✔ Reliable water supply all year round\r\n✔ Long service life\r\n✔ Solar-powered independence\r\n✔ Suitable for Nigerian borehole depths\r\n✔ Eco-friendly and cost-effective\r\n\r\nMake the Smart Switch to Solar\r\n\r\nThe 1.5HP Astra AC/DC Solar Submersible Pump is a dependable investment for anyone who wants consistent water supply without relying solely on grid power.\r\n\r\nUpgrade your borehole system today and enjoy efficient, uninterrupted water pumping.\r\n', '2026-02-14 13:52:15', NULL, 'uploads/image_2_69907e0f5a38f6.64574229.jpeg', NULL, 0, 'Other', '1.5HP Astra, AC/DC Solar, Submersible Pump', '[{\"title\":\"1.5HP High-Power Motor\",\"detail\":\"1.5HP High-Power Motor\"},{\"title\":\"AC\\/DC Dual Power Operation\",\"detail\":\"Runs on solar during the day and electricity\\/generator when needed \\u2014 no water interruptions.\"},{\"title\":\"Stainless Steel Submersible Body\",\"detail\":\"Rust-resistant and built to last in deep boreholes and harsh water conditions\"},{\"title\":\"Solar-Compatible Design\",\"detail\":\"Reduces electricity bills and saves money long-term.\"},{\"title\":\"High Efficiency Pumping System\",\"detail\":\"Delivers more water output with lower energy consumption.\"},{\"title\":\"Deep Borehole Capability\",\"detail\":\"Suitable for medium to deep well installations common in Nigeria.\"},{\"title\":\"Low Maintenance Engineering\",\"detail\":\"Low Maintenance Engineering\"},{\"title\":\"Overload & Dry-Run Protection (with controller)\",\"detail\":\"Protects the pump from damage and extends its lifespan.\"},{\"title\":\"Quiet Operation\",\"detail\":\"Pumps water efficiently without excessive noise.\"},{\"title\":\"Durable Internal Components\",\"detail\":\"Ensures long service life and reliable performance year-round.\"}]', NULL),
(94, '40 Amps MPPT Solar Charge Controller', '40 Amps', 52, 125000.00, 'uploads/image_main_699329cda13d17.00575425.jpeg', '40 Amps MPPT Solar Charge Controller \r\n\r\nPower your solar system smarter and faster with the 40 Amps MPPT Solar Charge Controller — a high-efficiency intelligent regulator designed to maximize the performance and lifespan of your batteries.\r\nBuilt with advanced MPPT (Maximum Power Point Tracking) technology, it automatically extracts the highest possible energy from your solar panels, delivering up to 30% more charging efficiency than traditional PWM controllers.\r\n\r\nPerfect for homes, shops, offices, CCTV systems, and off-grid solar installations, this controller stabilizes charging, prevents battery damage, and ensures reliable energy supply even during low sunlight conditions.\r\n\r\nThe digital display provides real-time system information while built-in protection features guard against overcharge, short circuit, overheating, reverse polarity, and over-discharge — giving you peace of mind and long-term durability.\r\n\r\nWhether you’re setting up a new solar system or upgrading an existing one, this controller helps you get more power, faster charging, and longer battery life every single day.\r\n\r\n\r\nIdeal For:\r\n\r\n* Home solar systems\r\n* Inverter & battery setups\r\n* CCTV and security installations\r\n* Small business & office power backup\r\n* Off-grid and rural electrification ', '2026-02-16 14:33:44', 'uploads/image_1_699329cda155c0.40736966.jpeg', 'uploads/image_2_699329cda169f6.36790064.jpeg', NULL, 0, 'Other', '40 Amps, MPPT, Solar, charge, controller , 12v, 24v, lcd', '[{\"title\":\"40 Amps Charging Capacity\",\"detail\":\"Handles medium to large solar systems efficiently without overload.\"},{\"title\":\"Handles medium to large solar systems efficiently without overload.\",\"detail\":\"Up to 30% more energy harvesting compared to PWM controllers.\"},{\"title\":\"LCD Digital Display\",\"detail\":\"Monitor voltage, charging status, and battery level in real time.\"},{\"title\":\"Smart Multi-Stage Charging\",\"detail\":\"Charges your batteries properly, extending their lifespan.\"},{\"title\":\"Automatic Battery Voltage Detection (12V\\/24V)\",\"detail\":\"No manual configuration stress \\u2014 the controller adjusts itself.\"},{\"title\":\"Overcharge Protection\",\"detail\":\"Prevents battery damage and overheating.\"},{\"title\":\"Temperature Compensation\",\"detail\":\"Adjusts charging based on temperature for optimal performance.\"},{\"title\":\"Compatible with AGM, Gel & Lead-Acid Batteries\",\"detail\":\"Flexible for different solar setups and upgrades.\"}]', NULL),
(95, '60 Amps PWM Solar Charge Controller', '60 Amps', 53, 45000.00, 'uploads/image_main_69932f56ed9781.46854888.jpeg', '60 Amps PWM Solar Charge Controller \r\n\r\nThe 60 Amps PWM Solar Charge Controller is a reliable power management unit designed to protect and optimize your solar battery system. It regulates the voltage and current coming from your solar panels, ensuring your batteries charge safely, efficiently, and last significantly longer.\r\n\r\nBuilt for homes, shops, offices, and off-grid setups, this controller automatically manages charging and discharging while preventing over-charging, deep discharge, overheating, and short-circuits. The smart LCD screen gives you real-time system information so you always know your battery status and solar performance.\r\n\r\nWhether you\'re running lights, TVs, fans, routers, or small appliances, this controller keeps your solar system stable and protected — especially in areas with unstable electricity supply.\r\n\r\nPerfect for 12V & 24V battery systems and compatible with most lead-acid batteries including sealed, gel, and flooded types.\r\n\r\n\r\nWhat It Does For You:\r\n\r\nThis controller acts as the brain of your solar system — protecting your battery investment, improving charging efficiency, and keeping your power steady day and night.\r\n\r\nIdeal for:\r\n\r\n* Homes & apartments\r\n* Shops & POS systems\r\n* CCTV & security systems\r\n* Rural/off-grid setups\r\n* Small business solar installations\r\n', '2026-02-28 15:57:50', NULL, 'uploads/image_2_69932f56edb102.82838048.jpeg', NULL, 0, 'Other', '60 amps, charge, controller, pwm charging, solar', '[{\"title\":\"60 Amps Charging Capacity\",\"detail\":\"Supports larger solar panel setups and higher power demand systems.\"},{\"title\":\"PWM Charging Technology\",\"detail\":\"Provides stable and reliable battery charging at an affordable cost.\"},{\"title\":\"Automatic 12V\\/24V Detection\",\"detail\":\"No manual switching \\u2014 the controller adjusts to your system automatically.\"},{\"title\":\"LCD Digital Display\",\"detail\":\"Easily monitor battery voltage, charging status, and load output in real time.\"},{\"title\":\"Dual USB Output Ports\",\"detail\":\"Charge phones and small devices directly from your solar system.\"},{\"title\":\"Overcharge Protection\",\"detail\":\"Prevents battery damage and extends battery lifespan.\"},{\"title\":\"Over-Discharge Protection\",\"detail\":\"Stops batteries from draining too low, protecting your investment.\"},{\"title\":\"Short Circuit Protection\",\"detail\":\"Keeps your system safe from electrical faults.\"},{\"title\":\"Load Output Control\",\"detail\":\"Automatically manages connected appliances to prevent overload.\"}]', NULL),
(97, '4G SIM Card Single Lens Indoor/Outdoor Security Camera', '4G CCTV', 21, 80000.00, 'uploads/image_main_699336089d49a7.28737393.jpeg', '4G SIM Card Single Lens Indoor/Outdoor Security Camera \r\n\r\nStay connected to what matters most — even without Wi-Fi.\r\nThe 4G SIM Card Single Lens Security Camera is designed for homes, shops, farms, construction sites, and remote locations where traditional internet isn’t available. Simply insert a SIM card and monitor your property live from anywhere in the world using your smartphone.\r\n\r\nBuilt for both indoor and outdoor use, this smart surveillance camera delivers clear HD video, motion alerts, and night vision so you never miss a moment — day or night.\r\n\r\nWhether NEPA takes light, router goes off, or you’re far away from the location, your security never stops.\r\n\r\n\r\nPerfect For:\r\n\r\n* Homes & apartments\r\n* Shops & offices\r\n* Warehouses\r\n* Farms & poultry\r\n* Construction sites\r\n* Remote locations without Wi-Fi', '2026-02-16 15:25:41', NULL, 'uploads/image_2_699336089d6db2.53798451.jpeg', NULL, 0, 'Other', '4g, SIM card, HD quality, Single Lens, Security, Solar, Camera', '[{\"title\":\"4G SIM Network Support\",\"detail\":\"Works with MTN, Airtel, Glo, 9mobile\"},{\"title\":\"HD Video Quality\",\"detail\":\"Clear and detailed live footage\"},{\"title\":\"Night Vision\",\"detail\":\"See clearly even in total darkness\"},{\"title\":\"Motion Detection Alerts\",\"detail\":\"Instant phone notification when movement is detected\"},{\"title\":\"Two-Way Audio\",\"detail\":\"Listen and speak through the camera\"},{\"title\":\"Indoor & Outdoor Use\",\"detail\":\"Weather-resistant design\"},{\"title\":\"Mobile App Control\",\"detail\":\"View live feed from anywhere\"},{\"title\":\"Memory Card Support\",\"detail\":\"Local recording storage\"},{\"title\":\"24\\/7 Monitoring\",\"detail\":\"Continuous security coverage\"}]', NULL),
(98, 'WiFi Digital Table Clock & Hidden Camera', 'WIFI CCTV', 23, 50000.00, 'uploads/image_main_69941e249ac9e0.20264024.jpeg', 'WiFi Digital Table Clock & Hidden Camera\r\n\r\nStay on time — and stay protected.\r\nThe WiFi Digital Table Clock and Camera looks like a simple bedside or office clock, but inside it’s a fully functional smart security camera. Designed for discreet monitoring, it lets you watch your home, shop, office, or kids’ room in real-time directly from your phone — from anywhere in the world.\r\n\r\nBecause it blends perfectly into everyday environments, nobody suspects it’s recording. You get security without drawing attention.\r\n\r\nWhether you\'re at work, traveling, or asleep, you can check live video, receive motion alerts, and replay recordings instantly through the mobile app.\r\n\r\n\r\nPerfect For:\r\n\r\n* Home security monitoring\r\n* Babysitter or nanny monitoring\r\n* Office surveillance\r\n* Shop & POS counter monitoring\r\n* Hotel rooms & rentals\r\n* Student hostels\r\n\r\n\r\nWhy People Love It:\r\n\r\nUnlike visible CCTV cameras that can be avoided or tampered with, this device records naturally because it looks like an ordinary clock. You get evidence, safety, and peace of mind — without making anyone uncomfortable.\r\n\r\n\r\n', '2026-02-17 07:54:02', NULL, 'uploads/image_2_69941e249ae511.97123154.jpeg', NULL, 0, 'Other', 'WiFi, clock, hidden camera, motion detector, night vision ', '[{\"title\":\"Disguised as a real digital clock\",\"detail\":\"Nobody suspects it\\u2019s a camera \\u2014 natural monitoring without drawing attention\"},{\"title\":\"WiFi remote viewing\",\"detail\":\"Watch live video from anywhere using your phone\"},{\"title\":\"Motion detection alerts\",\"detail\":\"Get notified instantly when movement happens\"},{\"title\":\"Night vision recording\",\"detail\":\"Clear monitoring even in darkness or at night\"},{\"title\":\"Loop recording (SD card support)\",\"detail\":\"Never runs out of space \\u2014 old footage automatically replaced\"},{\"title\":\"HD video quality\",\"detail\":\"See faces and activities clearly for evidence\"},{\"title\":\"Plug-and-play setup\",\"detail\":\"No technician or complicated wiring needed\"},{\"title\":\"Works while charging\",\"detail\":\"Continuous monitoring 24\\/7 without stopping\"},{\"title\":\"Remote playback\",\"detail\":\"Check past recordings anytime from your phone\"},{\"title\":\"Compact bedside design\",\"detail\":\"Fits perfectly in homes, offices, shops, and hotel rooms\"},{\"title\":\"Snapshot & video download\",\"detail\":\"Save proof directly to your phone when needed\"}]', NULL),
(99, '120Amps Felicity Solar Charge Controller', '', 51, 120000.00, 'uploads/image_main_699428cb742a26.09039984.jpeg', '120Amps Felicity Solar Charge Controller \r\n\r\nThe 120A Felicity Solar Charge Controller is a heavy-duty solar management unit designed for large home and commercial solar systems that require stable, fast, and safe battery charging. Built with advanced charging technology and intelligent protection features, it efficiently regulates the voltage and current coming from your solar panels to your battery bank — preventing over-charging, overheating, and power loss.\r\n\r\nWhether you’re running a full residential solar setup, office backup system, or small business installation, this controller maximizes solar harvest during the day and extends battery lifespan at night. Its smart LCD display gives you real-time monitoring of battery status, charging current, voltage level, and system performance so you always know exactly how your power system is working.\r\n\r\nEngineered for reliability in tough environments, the Felicity 120A controller features strong heat dissipation, automatic voltage recognition, and multiple electronic protections — making it ideal for Nigerian power conditions and continuous daily use.\r\n\r\nPerfect for:\r\n\r\n* Large inverters & battery banks\r\n* Homes running full solar backup\r\n* Shops, offices & mini-grids\r\n* Installers & solar technicians\r\n\r\n\r\nWhy You Need It:\r\n\r\nWithout a quality charge controller, solar panels can destroy batteries within months.\r\n\r\nThe Felicity 120A Controller protects your investment, improves charging efficiency, and keeps your power system stable every day — even during unstable sunlight conditions.\r\n\r\nReliable power starts with proper charging.\r\n', '2026-02-17 08:37:31', NULL, 'uploads/image_2_699428cb744804.31780430.jpeg', NULL, 0, 'Felicity ', '120amps, felicity, automatic 12v, lcd, solar, charge, controller ', '[{\"title\":\"120A High Charging Capacity\",\"detail\":\"Handles large solar panel setups and big battery banks without overload\"},{\"title\":\"Multi-stage Smart Charging (Bulk, Boost, Float)\",\"detail\":\"Charges batteries faster and extends battery life significantly\"},{\"title\":\"Automatic 12V \\/ 24V \\/ 48V Detection\",\"detail\":\"No manual settings \\u2014 works instantly with different system sizes\"},{\"title\":\"LCD Monitoring Display\",\"detail\":\"Easily see battery level, charging status, and system performance in real time\"},{\"title\":\"Over-Charge Protection\",\"detail\":\"Prevents battery damage and swelling\"},{\"title\":\"Reverse Polarity Protection\",\"detail\":\"Saves the controller if wires are mistakenly connected wrongly\"},{\"title\":\"Short-Circuit Protection\",\"detail\":\"Protects your entire solar system from electrical faults\"},{\"title\":\"Temperature & Heat Dissipation Design\",\"detail\":\"Stable operation even in hot weather and long daily usage\"},{\"title\":\"High Conversion Efficiency\",\"detail\":\"More solar power stored, less energy wasted\"},{\"title\":\"Battery Life Optimization\",\"detail\":\"Reduces replacement costs and keeps batteries healthy longer\"}]', NULL);
INSERT INTO `products` (`id`, `name`, `category`, `category_id`, `price`, `image_main`, `description`, `created_at`, `image_1`, `image_2`, `image_3`, `is_featured`, `brand`, `tags`, `specifications`, `sub_category_id`) VALUES
(100, 'SMS 60Amps Solar Charge Controller', '60 Amps', 53, 165000.00, 'uploads/image_main_69943155c86af7.53486701.jpeg', 'SMS 60Amps Solar Charge Controller\r\n\r\nPower your solar system with confidence.\r\n\r\nThe 60Amps Solar Charge Controller is designed to efficiently regulate the flow of energy from your solar panels to your battery bank, ensuring safe charging, longer battery life, and stable system performance. Built for medium to large solar installations, it’s the perfect solution for homes, offices, shops, and off-grid setups that demand reliable power management.\r\n\r\nWhether you\'re running lights, TVs, fans, fridges, or small business equipment, this controller helps you maximize every ray of sunlight.\r\n\r\n\r\nWhy You Need It:\r\n\r\nWithout a charge controller, your batteries can easily become overcharged or deeply discharged — reducing lifespan and performance. This 60A controller acts as the brain of your solar system, protecting your investment and improving overall efficiency.\r\n\r\n\r\nPerfect For:\r\n\r\n✔ Residential solar systems\r\n✔ Small businesses and shops\r\n✔ Offices and commercial setups\r\n✔ Off-grid homes\r\n✔ Backup power systems\r\n\r\n\r\nThe Result?\r\n\r\n* Longer battery lifespan\r\n* Stable and consistent power supply\r\n* Improved solar energy efficiency\r\n* Reduced maintenance costs\r\n* Peace of mind knowing your system is protected\r\n\r\nIf you\'re investing in solar, don’t cut corners on protection.\r\nThe 60Amps Solar Charge Controller ensures your system runs smarter, safer, and stronger.\r\n', '2026-02-28 16:02:33', NULL, 'uploads/image_2_69943155c87f43.52669031.jpeg', NULL, 0, 'SMS', 'SMS, 60amps, Solar, Charge, Controller', '[{\"title\":\"60A High Charging Capacity\",\"detail\":\"Handles larger solar panel systems and bigger battery banks with ease.\"},{\"title\":\"Intelligent Voltage Regulation\",\"detail\":\"Prevents battery damage and ensures optimal charging efficiency.\"},{\"title\":\"Automatic 12V \\/ 24V Detection\",\"detail\":\"Easy installation without complicated manual settings.\"},{\"title\":\"Digital LCD Display\",\"detail\":\"Monitor battery level, charging status, and system performance in real time.\"},{\"title\":\"Overcharge Protection\",\"detail\":\"Extends battery lifespan and prevents overheating.\"},{\"title\":\"Over-Discharge Protection\",\"detail\":\"Protects batteries from deep discharge damage.\"},{\"title\":\"Reverse Polarity Protection\",\"detail\":\"Prevents damage from incorrect wiring during installation.\"},{\"title\":\"Temperature Compensation\",\"detail\":\"Adjusts charging based on temperature for better battery health.\"},{\"title\":\"Durable Metal\\/Heat-Resistant Body\",\"detail\":\"Long-lasting performance even in hot environments.\"},{\"title\":\"Energy Efficient Design\",\"detail\":\"Maximizes solar energy usage and reduces power waste.\"}]', NULL),
(101, '450 Watt Half-Cut Mono Solar Panels', 'Monocrystaline', 115, 45000.00, 'uploads/image_main_69945b5705d575.10401868.png', '450 Watt Half-Cut Mono Solar Panels\r\n\r\nHigh-Efficiency, Durable Solar Power Solution for Homes & Businesses\r\n\r\nThe 450 Watt Half-Cut Mono Solar Panel is a premium solar module designed for maximum energy harvest, long-lasting performance, and superior reliability. Built with advanced half-cut monocrystalline cell technology, these panels deliver higher efficiency and better performance in all weather conditions compared to traditional solar panels.\r\n\r\nWhy Choose 450 W Half-Cut Mono Solar Panels?\r\n\r\n* Maximize energy production with high efficiency per panel\r\n* Reduce your electricity bills with clean solar power\r\n* Lower carbon footprint and support sustainability\r\n* Reliable performance in various climates and conditions\r\n* Ideal for residential, commercial, and industrial solar systems', '2026-02-28 16:21:16', NULL, 'uploads/image_2_69945b570646d7.40821005.jpeg', NULL, 0, 'Other', 'Solar panels, 450w, mono, half-cut, ', '[{\"title\":\"450 Watt High Power Output\",\"detail\":\"Fewer panels needed to generate more electricity, saving space and installation costs.\"},{\"title\":\"Half-Cut Cell Technology\",\"detail\":\"Higher efficiency with reduced power loss and better performance in partial shading.\"},{\"title\":\"Monocrystalline Silicon Cells\",\"detail\":\"Delivers superior efficiency and consistent energy production over time.\"},{\"title\":\"Improved Low-Light Performance\",\"detail\":\"Generates power even during cloudy weather, early mornings, and late evenings.\"},{\"title\":\"Lower Internal Resistance\",\"detail\":\"Reduces heat buildup and energy loss, improving overall system lifespan.\"},{\"title\":\"High Conversion Efficiency\",\"detail\":\"Maximizes solar energy conversion, giving you more power per square meter.\"},{\"title\":\"Strong Tempered Glass Front\",\"detail\":\"Protects the panel from impact, dust, and harsh environmental conditions.\"},{\"title\":\"Corrosion-Resistant Aluminum Frame\",\"detail\":\"Ensures durability and long-term outdoor use in various climates.\"},{\"title\":\"High Wind & Snow Load Capacity\",\"detail\":\"Reliable performance in tough weather conditions.\"},{\"title\":\"Low Degradation Rate\",\"detail\":\"Maintains strong power output for many years, protecting your investment\"},{\"title\":\"Standard Mounting Compatibility\",\"detail\":\"Easy integration with most rooftop and ground-mounted solar systems.\"}]', NULL),
(102, 'Solar Security Sensor Alarm', 'Alarm & remote', 60, 25000.00, 'uploads/image_main_699462611e1ab5.03210376.png', 'Solar Security Sensor Alarm:\r\n\r\nEnhance your property’s protection with the Solar Security Sensor Alarm — an efficient, self-powered alert system designed for homes, offices, farms, and outdoor spaces. Using solar energy, this intelligent alarm system offers reliable security without the need for frequent electrical power or wiring, making it both cost-effective and easy to install.\r\n\r\nProduct Overview:\r\n\r\nThe Solar Security Sensor Alarm is a compact and durable motion-activated alert system that uses a solar panel to stay charged throughout the day. When movement is detected within the monitored area, the alarm instantly emits a loud alert to deter intruders and notify nearby individuals. Its solar-powered design ensures continuous operation with minimal maintenance, making it ideal for remote or off-grid applications.\r\n\r\nWhy This Alarm Is a Smart Choice:\r\n\r\nThe Solar Security Sensor Alarm combines ingenuity and convenience — using renewable solar energy to deliver reliable security wherever you need it. It’s perfect for homeowners, business owners, and anyone looking to secure spaces without electrical infrastructure. Its motion detection and loud alert system offer peace of mind while reducing ongoing maintenance costs.\r\n', '2026-02-17 12:48:33', 'uploads/image_1_699463a12ae161.97736314.jpeg', 'uploads/image_2_699463a12afe03.47783123.jpeg', NULL, 0, 'Other', 'Alarm, Security, Sensor, Alarm, Solar', '[{\"title\":\"Solar-Powered System\",\"detail\":\"Operates without electricity, reducing energy costs and ensuring continuous use even during power outages.\"},{\"title\":\"Built-In Motion Sensor (PIR)\",\"detail\":\"Detects movement instantly and triggers an alarm to stop intruders before they get close.\"},{\"title\":\"Loud Alarm Sound Output\",\"detail\":\"Scares away intruders and alerts people nearby for immediate response.\"},{\"title\":\"Remote Control Operation\",\"detail\":\"Easily arm or disarm the alarm from a distance for added convenience.\"},{\"title\":\"Rechargeable Battery Backup\",\"detail\":\"Stores solar energy for reliable night-time and low-sunlight performance.\"},{\"title\":\"USB Charging Option\",\"detail\":\"Allows charging even during extended cloudy weather or indoor use.\"},{\"title\":\"Weather-Resistant Casing\",\"detail\":\"Designed for outdoor use in rain, heat, and dust without damage.\"},{\"title\":\"Wide Detection Coverage\",\"detail\":\"Secures larger areas such as entrances, compounds, farms, and parking spaces.\"},{\"title\":\"Wireless & Cable-Free Design\",\"detail\":\"Quick installation without complex wiring or professional setup.\"},{\"title\":\"Compact & Visible Design\",\"detail\":\"Acts as a visual deterrent while blending neatly into the environment.\"},{\"title\":\"Low Maintenance System\",\"detail\":\"No frequent battery replacements or servicing required.\"}]', NULL),
(103, 'Low Power Wi-Fi Polyvision Camera', 'WIFI CCTV', 23, 76000.00, 'uploads/image_main_699469d8c28a61.55195345.png', 'Low Power Wi-Fi Polyvision Camera\r\n\r\nStay connected and secure with the Low Power Wi-Fi Polyvision Camera — a smart surveillance solution built for efficient performance, extended battery life, and easy wireless monitoring. Designed for both indoor and outdoor use, this camera combines reliable connectivity, energy-saving technology, and crisp video quality to keep your home or business under constant watch.\r\n\r\nProduct Overview:\r\n\r\nThe Low Power Wi-Fi Polyvision Camera is a next-generation security camera that leverages low-power consumption with wireless connectivity to provide continuous surveillance without draining system resources. Featuring easy Wi-Fi setup, high-resolution imaging, and intuitive remote access, this camera ensures you’re always in control — whether at home or on the go.\r\n\r\n\r\nWhy Choose the Low Power Wi-Fi Polyvision Camera?\r\n\r\nThis camera strikes the perfect balance between energy efficiency and performance. It’s an ideal choice for homeowners, small business owners, and property managers who want dependable security without the complexity of traditional wired systems. With its combination of wireless convenience, extended power life, and smart features, you get powerful monitoring that fits seamlessly into your lifestyle.\r\n', '2026-02-17 13:15:04', NULL, 'uploads/image_2_699469d8c2bb11.46377783.jpeg', NULL, 0, 'Other', 'WiFi, security, cctv, camera, WiFi, HD, Polyvision', '[{\"title\":\"Low Power Consumption Design\",\"detail\":\"Runs longer on battery or solar power, reducing frequent recharging and energy costs.\"},{\"title\":\"Wi-Fi Wireless Connectivity\",\"detail\":\"Monitor your space remotely without complex wiring or network cables.\"},{\"title\":\"High-Definition Video Quality\",\"detail\":\"Captures clear images and videos for better visibility and identification.\"},{\"title\":\"Smart Motion Detection\",\"detail\":\"Instantly alerts you when movement is detected, keeping you informed in real time.\"},{\"title\":\"Mobile App Remote Access\",\"detail\":\"View live footage, playback recordings, and manage settings from anywhere.\"},{\"title\":\"Night Vision Technology\",\"detail\":\"Provides reliable surveillance even in complete darkness\"},{\"title\":\"Two-Way Audio Support\",\"detail\":\"Communicate with people on-site or warn intruders remotely.\"},{\"title\":\"Indoor & Outdoor Compatibility\",\"detail\":\"Suitable for homes, offices, shops, warehouses, and outdoor areas.\"},{\"title\":\"Weather-Resistant Housing\",\"detail\":\"Performs reliably in rain, dust, and changing weather conditions.\"},{\"title\":\"Wireless Installation\",\"detail\":\"Quick and easy setup without professional installation.\"},{\"title\":\"Cloud & Local Storage Support\",\"detail\":\"Choose flexible recording options for secure video storage.\"}]', NULL),
(104, '2 Poles 63 Amps AC Breaker', 'AC Breaker 1', 106, 15000.00, 'uploads/image_main_699470249fb4f0.97324409.png', '2 Poles 63 Amps AC Breaker \r\n\r\nReliable Power Protection for Homes & Solar Systems\r\n\r\nThe 2 Poles 63 Amps AC Breaker is a high-performance miniature circuit breaker (MCB) designed to protect electrical systems from overloads and short circuits. Built for durability and safety, this breaker ensures stable and secure power distribution in residential, commercial, and solar installations.\r\n\r\nWhether you are setting up a solar inverter system, protecting your distribution board, or securing heavy-load appliances, this 63A double-pole breaker delivers dependable performance.\r\n\r\n\r\nPerfect For:\r\n\r\n* Solar inverter installations\r\n* Residential electrical panels\r\n* Commercial distribution boards\r\n* Air conditioners and heavy appliances\r\n* Generator changeover systems\r\n\r\n\r\n\r\nWhy You Need a 63A Double Pole Breaker:\r\n\r\nIn Nigerian power environments where voltage fluctuations and sudden surges are common, proper circuit protection is not optional — it is essential.\r\n\r\nThis 2P 63A breaker ensures:\r\n\r\n* Complete isolation of power during faults\r\n* Protection of expensive solar inverters and batteries\r\n* Reduced risk of electrical fire\r\n* Safe maintenance and troubleshooting\r\n\r\n\r\n\r\nTechnical Specifications:\r\n\r\n* Type: Miniature Circuit Breaker (MCB)\r\n* Poles: 2 (Double Pole)\r\n* Rated Current: 63 Amps\r\n* Application: AC Systems\r\n* Mounting Type: DIN Rail\r\n\r\n\r\n Ideal for Solar Installations:\r\n\r\nWhen installing solar systems, protecting your inverter and battery bank is critical. This breaker acts as a secure disconnect point and overload protection device, helping your solar setup operate safely and efficiently.\r\n\r\n', '2026-02-28 14:57:42', 'uploads/image_1_69947024a05810.78860727.jpeg', 'uploads/image_2_69947024a06fa2.72607561.png', NULL, 0, 'Other', '63amps, double pole, breaker, Ac, Dc, current', '[{\"title\":\"63 Amps Current Rating\",\"detail\":\"Ideal for medium to heavy electrical loads\"},{\"title\":\"Double Pole (2P) Protection\",\"detail\":\"Simultaneously disconnects both live and neutral lines for maximum safety\"},{\"title\":\"Overload & Short Circuit Protection\",\"detail\":\"Prevents equipment damage and fire hazards\"},{\"title\":\"High Breaking Capacity\",\"detail\":\"Designed to handle fault currents effectively\"},{\"title\":\"Durable Construction\",\"detail\":\"Heat-resistant and long-lasting internal components\"},{\"title\":\"Easy DIN Rail Mounting\",\"detail\":\"Simple installation inside distribution boards\"}]', NULL),
(106, 'WiFi Low Power Battery Camera', 'WIFI CCTV', 23, 70000.00, 'uploads/image_main_699477acd4e4f5.50972438.png', 'WiFi Low Power Battery Camera\r\n\r\nSecure your home or business with the WiFi Low Power Battery Camera — a smart, energy-efficient surveillance solution designed for reliable monitoring without constant power supply. Built for convenience and performance, this wireless camera delivers clear video, motion alerts, and remote access while consuming minimal battery power, making it ideal for both indoor and outdoor use.\r\n\r\nProduct Overview:\r\n\r\nThe WiFi Low Power Battery Camera is a compact, fully wireless security camera designed for flexible installation and long-lasting performance. Powered by a rechargeable low-consumption battery, it connects seamlessly to your WiFi network, allowing you to monitor your property from anywhere using a mobile app. With motion detection technology and real-time alerts, it records only when activity is detected, conserving battery life while keeping you informed.\r\n\r\n\r\nWhy This Camera Is a Smart Choice:\r\n\r\nThe WiFi Low Power Battery Camera combines wireless convenience with intelligent energy efficiency. Its low power design ensures longer operating time between charges, while motion detection reduces unnecessary recordings. Perfect for homes, shops, offices, farms, and remote locations, this camera provides dependable security monitoring without complicated installation or constant electricity.\r\n\r\nStay connected. Stay protected. Anytime, anywhere.\r\n', '2026-02-21 12:38:22', NULL, 'uploads/image_2_699477acd52097.99062596.jpeg', NULL, 0, 'Other', 'WiFi, security, motion detection, low power ', '[{\"title\":\"WiFi Connectivity\",\"detail\":\"Connects directly to your home or office WiFi for real-time remote viewing.\"},{\"title\":\"Low Power Consumption\",\"detail\":\"Designed for extended battery life with efficient energy usage.\"},{\"title\":\"Mobile App Control\",\"detail\":\"View live footage, receive alerts, and playback recordings from your smartphone.\"},{\"title\":\"Motion Detection\",\"detail\":\"Automatically records and sends notifications when movement is detected.\"},{\"title\":\"Clear HD Video\",\"detail\":\"Provides sharp, high-quality video for reliable monitoring.\"},{\"title\":\"Weather-Resistant Design\",\"detail\":\"Suitable for both indoor and outdoor installation.\"},{\"title\":\"Rechargeable Battery\",\"detail\":\"Easy charging for continued use without frequent battery replacement.\"},{\"title\":\"Easy Installation\",\"detail\":\"No wiring required; mount anywhere with flexible positioning.\"}]', NULL),
(108, '410W Solar Panel Flames', 'Monocrystaline', 115, 120000.00, 'uploads/image_main_69947d0bf3d208.43637337.png', '410W Solar Panel Flames\r\n\r\nIlluminate your energy independence with the 410W Solar Panel Flames — a high-efficiency solar module engineered for powerful performance in residential, commercial, and off-grid solar systems. Designed for durability, long life, and excellent energy output, this solar panel is ideal for anyone looking to maximize power generation from clean and renewable sunlight.\r\n\r\nProduct Overview:\r\n\r\nThe 410W Solar Panel Flames is a premium solar photovoltaic (PV) panel built with advanced cell technology to deliver high power output and reliable performance. With a robust construction and superior conversion efficiency, it captures sunlight and converts it into usable electricity for homes, businesses, solar inverters, and off-grid power systems. Its durable design makes it suitable for harsh weather conditions while ensuring long-term energy production.\r\n\r\n\r\nWhy This Solar Panel Is a Smart Choice:\r\n\r\nThe 410W Solar Panel Flames delivers exceptional value for anyone investing in solar energy:\r\n\r\n* More Energy, Less Space: High wattage per panel means you generate more power using fewer panels.\r\n\r\n* Long-Lasting Performance: Built to last with minimal maintenance and excellent weather resistance.\r\n\r\n* Lower Electricity Costs: Generate your own clean energy and reduce dependence on grid or generator power.\r\n\r\n* Ideal for Nigerian Climate: Designed to perform well under high temperatures and strong sunlight — perfect for homes, businesses, farms, and remote installations.\r\n\r\n\r\nIdeal For:\r\n\r\n* Residential rooftop solar systems\r\n* Commercial power installations\r\n* Solar battery charging systems\r\n* Off-grid solar setups\r\n* Solar-powered street lighting\r\n\r\n', '2026-02-28 16:18:21', NULL, NULL, NULL, 0, 'Other', '410w, high power, solar, panel, flames, crystalline', '[{\"title\":\"High Power Output (410 Watts)\",\"detail\":\"Generates significant energy from sunlight, ideal for powering larger loads and reducing reliance on grid or generator power.\"},{\"title\":\"High Conversion Efficiency\",\"detail\":\"Advanced solar cell technology converts more sunlight into electricity compared to standard panels.\"},{\"title\":\"Sturdy & Durable Build\",\"detail\":\"Tempered glass and corrosion-resistant aluminum frame protect against dust, water, and extreme outdoor environments.\"},{\"title\":\"All-Weather Performance\",\"detail\":\"Designed to withstand rain, wind, and high temperatures without performance loss.\"},{\"title\":\"Easy Mounting & Integration\",\"detail\":\"Compatible with most solar mounting systems and inverters for seamless installation.\"},{\"title\":\"Low Degradation Rate\",\"detail\":\"Maintains power output over long service life, ensuring consistent energy generation year after year.\"}]', NULL),
(111, '450W AI Solar Camera + Lightning 2-in-1', '', 3, 120000.00, 'uploads/image_main_699486feddc754.01984308.png', '450W AI Solar Camera + Lightning 2-in-1\r\n\r\nExperience next-level security and illumination with the 450 Watts AI Solar Camera + Lightning 2-in-1— a powerful solar-powered surveillance and lighting solution designed for homes, businesses, outdoor spaces, and remote locations. Combining intelligent AI-driven camera features with bright solar lighting in one integrated device, this product offers reliable performance with zero wiring and minimal maintenance.\r\n\r\n\r\nProduct Overview:\r\n\r\nThe 450W AI Solar Camera + Lightning 2-in-1 is a dual-purpose smart unit that integrates advanced artificial intelligence (AI) surveillance and high-output LED lighting, all powered by solar energy. With its robust solar panel and efficient battery system, this product captures crisp live video, delivers bright illumination, and keeps your property secure — even in off-grid locations. With no need for external electricity, complicated wiring, or frequent charging, it’s ideal for Nigerian homes, businesses, farms, and outdoor estates looking for smart, self-sustaining security.\r\n\r\n\r\nWhy This Product Is a Smart Choice:\r\n\r\nThe 450W AI Solar Camera + Lightning 2-in-1 bridges security and lighting in a single, self-sustained system. Its solar-powered design eliminates electricity costs and minimizes maintenance, while its AI features enhance security accuracy and responsiveness. The high-output lighting turns dark spaces into safe, well-lit areas — perfect for driveways, gates, compounds, parking lots, and more.\r\n\r\nThis all-in-one unit is especially ideal in areas with limited or unreliable grid electricity — like many parts of Nigeria — giving you peace of mind with smart monitoring and bright illumination anytime, day or night.\r\n\r\n\r\nApply For:\r\n\r\n* Home and compound security\r\n* Business entrances and perimeters\r\n* Outdoor lighting for estates and walkways\r\n* Farm and remote land monitoring\r\n* Construction sites and outdoor venues', '2026-02-21 12:42:21', NULL, 'uploads/image_2_699486feddfe36.89184415.jpeg', NULL, 0, 'Other', 'Ai, Camera, 450w, Solar, remote, smart ', '[{\"title\":\"450W Solar Power System\",\"detail\":\"Generates strong solar energy for sustained camera and lighting performance without using grid power.\"},{\"title\":\"AI Smart Camera\",\"detail\":\"Detects motion intelligently, reduces false alerts, and tracks activity with precision.\"},{\"title\":\"Integrated Bright Lighting\",\"detail\":\"Dual-function LED lighting provides powerful illumination to light up yards, driveways, and entrances.\"},{\"title\":\"Remote Viewing & Alerts\",\"detail\":\"View live footage, receive motion alerts, and check event history from your smartphone app.\"},{\"title\":\"Long Battery Life\",\"detail\":\"Efficient battery storage ensures extended operation even during low sunlight.\"},{\"title\":\"Durable Weather-Resistant Design\",\"detail\":\"Built to withstand rain, dust, and outdoor conditions.\"},{\"title\":\"Easy Installation\",\"detail\":\"Wireless setup without electrical wiring; mount on walls, poles, or outdoor locations.\"}]', NULL),
(112, 'Sunshine 100W Mono Solar Panels', 'Monocrystaline', 115, 40000.00, 'uploads/image_main_69958004c28ed2.34626983.jpeg', 'Sunshine 100W Mono Solar Panels\r\n\r\nReliable Power. Maximum Efficiency. Built to Last.\r\n\r\nThe Sunshine 100W Monocrystalline Solar Panel is designed to deliver strong, consistent power output for homes, businesses, and off-grid systems. Built with high-efficiency monocrystalline cells, this panel captures more sunlight and converts it into usable electricity — even in low-light conditions.\r\n\r\nWhether you\'re powering lights, TVs, fans, CCTV systems, or charging batteries, this panel gives you dependable energy every day.\r\n\r\n\r\nWhy Choose Monocrystalline?\r\n\r\nMonocrystalline panels are known for:\r\n\r\n* Higher efficiency rates\r\n* Better performance in cloudy weather\r\n* Longer lifespan\r\n* Sleek, modern appearance\r\n\r\nThat means more power from less space — and better value for your investment.\r\n\r\n\r\nIdeal For:\r\n\r\n✔ Solar home systems\r\n✔ Small shops and offices\r\n✔ CCTV installations\r\n✔ Rural electrification\r\n✔ Backup power systems\r\n✔ Battery charging setups\r\n\r\n\r\n\r\nWhat You Get:\r\n\r\n* Consistent daily power generation\r\n* Lower electricity costs\r\n* Reduced dependence on grid power\r\n* Clean, renewable energy\r\n* Long-term energy savings\r\n\r\n\r\nIf you\'re building or upgrading your solar system, the Sunshine 100W / 12V Mono Solar Panel is a smart, efficient, and durable choice.\r\n\r\n', '2026-02-28 16:17:58', 'uploads/image_1_69958004c2a6d2.23410753.jpeg', 'uploads/image_2_69958004c2b927.47500255.jpeg', NULL, 0, 'Other', 'Solar, 100w, mono, sunshine, panel, power, sunlight, durable ', '[{\"title\":\"100W Power Output\",\"detail\":\"Provides strong and stable energy for 12V battery systems.\"},{\"title\":\"High-Efficiency Mono Cells\",\"detail\":\"Improved energy conversion for better performance throughout the day.\"},{\"title\":\"Durable Aluminum Frame\",\"detail\":\"Rust-resistant and built to withstand harsh weather conditions.\"},{\"title\":\"Tempered Glass Surface\",\"detail\":\"Strong, impact-resistant protection for long-term outdoor use.\"},{\"title\":\"Weather Resistant Design\",\"detail\":\"Built to handle rain, heat, and dust \\u2014 ideal for Nigerian climate conditions.\"},{\"title\":\"Long Service Life\",\"detail\":\"Designed for 20\\u201325+ years of reliable performance.\"}]', NULL),
(113, 'Sunshine 200W  Mono Solar Panels', 'Monocrystaline', 115, 60000.00, 'uploads/image_main_69958fd0399897.69966788.jpeg', 'Sunshine 200W Mono Solar Panels\r\n\r\nReliable Power. Maximum Efficiency. Built to Last.\r\n\r\nThe Sunshine 200W / 12V Monocrystalline Solar Panel is designed to deliver strong, consistent power output for homes, businesses, and off-grid systems. Built with high-efficiency monocrystalline cells, this panel captures more sunlight and converts it into usable electricity — even in low-light conditions.\r\n\r\nWhether you\'re powering lights, TVs, fans, CCTV systems, or charging batteries, this panel gives you dependable energy every day.\r\n\r\n\r\nWhy Choose Monocrystalline?\r\n\r\nMonocrystalline panels are known for:\r\n\r\n* Higher efficiency rates\r\n* Better performance in cloudy weather\r\n* Longer lifespan\r\n* Sleek, modern appearance\r\n\r\nThat means more power from less space — and better value for your investment.\r\n\r\n\r\nIdeal For:\r\n\r\n✔ Solar home systems\r\n✔ Small shops and offices\r\n✔ CCTV installations\r\n✔ Rural electrification\r\n✔ Backup power systems\r\n✔ Battery charging setups\r\n\r\n\r\n\r\nWhat You Get:\r\n\r\n* Consistent daily power generation\r\n* Lower electricity costs\r\n* Reduced dependence on grid power\r\n* Clean, renewable energy\r\n* Long-term energy savings\r\n\r\n\r\nIf you\'re building or upgrading your solar system, the Sunshine 200W / 12V Mono Solar Panel is a smart, efficient, and durable choice.\r\n', '2026-02-28 16:17:40', NULL, 'uploads/image_2_69958fd039b0d1.62903182.jpeg', NULL, 0, 'Other', '200w, solar, panel, power, high efficiency ', '[{\"title\":\"200W Power Output\",\"detail\":\"Provides strong and stable energy for 12V battery systems.\"},{\"title\":\"High-Efficiency Mono Cells\",\"detail\":\"Improved energy conversion for better performance throughout the day.\"},{\"title\":\"Durable Aluminum Frame\",\"detail\":\"Rust-resistant and built to withstand harsh weather conditions.\"},{\"title\":\"Tempered Glass Surface\",\"detail\":\"Strong, impact-resistant protection for long-term outdoor use.\"},{\"title\":\"Weather Resistant Design\",\"detail\":\"Built to handle rain, heat, and dust \\u2014 ideal for Nigerian climate conditions.\"},{\"title\":\"Long Service Life\",\"detail\":\"Designed for 20\\u201325+ years of reliable performance.\"}]', NULL),
(114, '300W Mono Solar Panels', 'Monocrystaline', 115, 75000.00, 'uploads/image_main_699594a5b61772.99472649.jpeg', '300W Mono Solar Panels\r\n\r\nReliable Power. Maximum Efficiency. Built to Last.\r\n\r\nThe Sunshine 300W / 24V Monocrystalline Solar Panel is designed to deliver strong, consistent power output for homes, businesses, and off-grid systems. Built with high-efficiency monocrystalline cells, this panel captures more sunlight and converts it into usable electricity — even in low-light conditions.\r\n\r\nSpecifications:\r\nType: Monocrystalline\r\nVoltage: Suitable for 12V, 24V, 36V, or 48V systems\r\nCells: Typically 60 or 72 cells. \r\n\r\nCommon Applications: \r\n\r\nResidential: Powering home appliances in small setups or supplementing larger systems.\r\n\r\nOff-Grid/Portable: Ideal for RVs, campervans, boats, and remote farms.\r\n\r\nCommercial: Suitable for solar traffic signs and monitoring equipment. \r\n\r\n\r\n', '2026-02-28 16:07:25', NULL, 'uploads/image_2_699594a5b630d9.68387419.jpeg', NULL, 0, 'Other', '12, Solar, Durable, 300w, mono', '[{\"title\":\"Specifications Type: Monocrystalline Voltage: Suitable for 12V, 24V, 36V, or 48V systems Cells: Typically 60 or 72 cells Brands: Common brands include Canadian Solar, Jinko, Trina, and others available on Jiji Nigeria and Kara.com.ng.  Common Applications Residential: Powering home appliances in small setups or supplementing larger systems. Off-Grid\\/Portable: Ideal for RVs, campervans, boats, and remote farms. Commercial: Suitable for solar traffic signs and monitoring equipment. \",\"detail\":\"Improved energy conversion for better performance throughout the day.\"},{\"title\":\"Durable Aluminum Frame\",\"detail\":\"Rust-resistant and built to withstand harsh weather conditions.\"},{\"title\":\"Tempered Glass Surface\",\"detail\":\"Strong, impact-resistant protection for long-term outdoor use.\"},{\"title\":\"Weather Resistant Design\",\"detail\":\"Built to handle rain, heat, and dust \\u2014 ideal for Nigerian climate conditions.\"},{\"title\":\"Long Service Life\",\"detail\":\"Designed for 20\\u201325+ years of reliable performance.\"}]', NULL),
