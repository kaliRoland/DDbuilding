INSERT INTO `gallery_items` (`id`, `title`, `description`, `created_at`, `image_path_1`, `image_path_2`, `image_path_3`, `image_path_4`, `image_path_5`, `youtube_url`) VALUES
(1, 'Solar Street Light Installation', 'We have successfully installed solar street lights for various clients, including homeowners, construction sites, and commercial properties. Our solutions ensure 24/7 illumination, enhancing security and visibility in dark areas.', '2025-12-08 12:10:26', 'uploads/gallery_6936c0328c207.jpg', 'uploads/gallery_6936c03290980.jpg', 'uploads/gallery_6936c03291e13.jpg', 'uploads/gallery_6936c03292df9.jpg', '', ''),
(3, 'Solar Power borehole', 'Barrister Chike approached us to upgrade his water pumping system. We replaced his traditional Sumo pump with a 1HP DC solar pump powered by six 250W solar panels. The new system eliminated the need for fuel-powered generators, providing a clean, cost-effective water solution.', '2025-12-08 12:20:37', 'uploads/gallery_6936c295e3a52.jpg', 'uploads/gallery_6936c295e8a8a.jpg', 'uploads/gallery_6936c295ee24f.jpg', '', '', ''),
(4, 'Single Lens Solar Camera Installation', '', '2026-02-28 09:36:59', 'uploads/gallery_69a2b73b86242.jpg', 'uploads/gallery_69a2c21521a6f.jpg', 'uploads/gallery_69a2c21522524.jpg', '', '', 'https://youtu.be/VtXETQsGt9U?si=RVUUB2bk8DM3KT8R'),
(5, 's10', '', '2026-02-28 09:38:21', 'uploads/gallery_69a2b78dbff94.jpg', 'uploads/gallery_69a2b78dc1545.jpg', '', '', '', 'https://youtu.be/VtXETQsGt9U?si=RVUUB2bk8DM3KT8R'),
(8, 'Single Lens Solar Camera Installation', 'Project Overview: Installation of a 4G Ubox Single Lens PTZ Solar Camera\r\n\r\nWhat We Installed:\r\nWe installed a 4G Ubox Single Lens PTZ Solar Camera system designed for remote surveillance and flexible monitoring.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4G SIM Card (for internet connectivity)\r\n* 64GB Memory Card (for video storage)\r\n* Mounting Pole\r\n* Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nConstruction Site (Location not specified)\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enable the client remotely monitor activities at his construction site in real time. With 4G connectivity and PTZ (Pan-Tilt-Zoom) functionality, the client can conveniently view, control, and track everything happening on-site from anywhere, ensuring improved security, supervision of workers, and protection of building materials.', '2026-02-28 10:32:41', 'uploads/gallery_69a2c44908232.jpg', 'uploads/gallery_69a2c4db0051b.jpg', '', '', '', 'https://youtu.be/VtXETQsGt9U?si=RVUUB2bk8DM3KT8R'),
(9, 'Dual Lens Solar Camera', 'Here is your gallery description properly arranged using your format (What was installed, accessories used, location if available, and aim of installation):\r\n\r\n---\r\n\r\n**Project Overview:** Installation of a 4G Ubox Single Lens PTZ Solar Camera\r\n\r\nWhat We Installed:\r\nWe installed a 4G V380 Dual Lens PTZ Solar Camera system designed for remote surveillance and flexible monitoring.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4G SIM Card (for internet connectivity)\r\n* 64GB Memory Card (for video storage)\r\n* Mounting Pole\r\n* Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nConstruction Site \r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enable the client remotely monitor activities at his construction site in real time. With 4G connectivity and PTZ (Pan-Tilt-Zoom) functionality, the client can conveniently view, control, and track everything happening on-site from anywhere, ensuring improved security, supervision of workers, and protection of building materials.', '2026-02-28 10:47:21', 'uploads/gallery_69a2c7b9b5bd4.jpg', 'uploads/gallery_69a2c7b9b75fc.jpg', '', '', '', ''),
(10, '4G Ubox Dual Lens PTZ Solar Camera Installation', 'Project Overview: Installation of a 4G Ubox Dual Lens PTZ Solar Camera\r\n\r\nWhat We Installed:\r\nWe installed a 4G Ubox Dual Lens PTZ Solar Camera system designed to provide advanced and reliable home surveillance.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4G SIM Card (for remote internet connectivity)\r\n* 64GB Memory Card (for video storage and playback)\r\n* Mounting Pole\r\n* Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation for Mr. Chidi (Home)\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enhance the security of Mr. Chidi’s home by enabling him to monitor his surroundings conveniently from anywhere. The dual-lens and PTZ (Pan-Tilt-Zoom) features provide wider coverage and clearer visibility, ensuring that every activity around the property can be viewed in real time. This solution gives the client peace of mind, improved safety, and complete control over his home security.', '2026-02-28 11:04:40', 'uploads/gallery_69a2cbc821f57.jpg', 'uploads/gallery_69a2cbc822f5e.jpg', 'uploads/gallery_69a2cbc823932.jpg', '', '', ''),
(11, 'Solar Street Light & 4G V380 Dual Lens PTZ Solar Camera (DS-20)', 'Project Overview: Installation of Solar Street Light & 4G V380 Dual Lens PTZ Solar Camera (DS-20)\r\n\r\nWhat We Installed:\r\nWe installed a Solar Street Light alongside a 4G V380 Dual Lens PTZ Solar Camera (DS-20) to provide both illumination and advanced surveillance coverage for the client’s site.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4G SIM Card (for remote connectivity and live monitoring)\r\n* 64GB Memory Card (for video storage and playback)\r\n* Mounting Pole\r\n* Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nConstruction Site (Location not specified)\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was designed to enable the client effectively monitor activities at his construction site while also improving nighttime visibility. The solar street light ensures the environment is brightly illuminated after dark, while the dual-lens PTZ camera provides wide-angle coverage and real-time remote viewing. With this setup, the client can clearly see everything happening on-site, day or night, ensuring better supervision, enhanced security, and protection of materials and equipment.', '2026-02-28 11:36:36', 'uploads/gallery_69a2d34406170.jpg', 'uploads/gallery_69a2d34406345.jpg', 'uploads/gallery_69a2d3440645a.jpg', '', '', ''),
(12, '2MP Outdoor Analog CCTV Camera System Installation', 'Project Overview: Installation of 2MP Outdoor Analog CCTV Camera System\r\n\r\nWhat We Installed:\r\nWe installed a 2MP Indoor/Outdoor Analog CCTV Camera system designed to provide reliable surveillance coverage for business premises.\r\n\r\nAccessories & Components Used:\r\n\r\n* 8-Channel DVR (Digital Video Recorder)\r\n* CCTV Monitor (for live viewing and playback)\r\n* Quality Surveillance Wiring and installation accessories\r\n\r\nLocation:\r\nJiva Restaurant\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enhance security and operational transparency at Jiva Restaurant. The CCTV system enables the client to conveniently monitor daily activities involving both staff and customers in real time. With clear video coverage and recorded footage available for review, the business owner can ensure improved safety, accountability, and smooth operations, ultimately keeping the restaurant secure and well-managed.', '2026-02-28 12:07:02', 'uploads/gallery_69a2da66589ad.jpg', 'uploads/gallery_69a2da6658d91.jpg', '', '', '', 'https://youtu.be/jD3UbyRkKZk'),
(14, 'Installation of 2MP Indoor & Outdoor Analog CCTV Camera System', 'Project Overview: Installation of 2MP Indoor & Outdoor Analog CCTV Camera System\r\n\r\nWhat We Installed:\r\nWe installed a 2MP Indoor and Outdoor Analog CCTV Camera system to provide comprehensive surveillance coverage around the client’s property.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4-Channel DVR (Digital Video Recorder)\r\n* CCTV Monitor (for live viewing and playback)\r\n* Quality Surveillance Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation for Mr. Uche\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enhance the security of Mr. Uche’s home by providing clear monitoring of both indoor and outdoor areas. With real-time viewing and recorded footage available for review, the client can conveniently monitor activities within and around his property at any time. This solution ensures improved safety, better awareness, and greater peace of mind, keeping his home secure and well-protected.', '2026-02-28 12:26:14', 'uploads/gallery_69a2dee68ea96.jpg', 'uploads/gallery_69a2dee68f862.jpg', 'uploads/gallery_69a2dee69016f.jpg', 'uploads/gallery_69a2dee690baf.jpg', '', ''),
(15, '2KVA Solar Power System Installation', 'Project Overview: Installation of a 2KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 2KVA Solar Power System designed to provide reliable and uninterrupted electricity for business operations.\r\n\r\nAccessories & Components Used:\r\n\r\n* 3 Solar Panels\r\n* 2.5KVA Inverter\r\n* 2 Tubular Batteries\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nAmy Nighties\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure consistent and dependable power supply for Amy Nighties, especially during public power outages. With this solar system in place, the business can continue operating smoothly even when grid electricity fails. Essential appliances such as fans and lighting now run steadily, creating a comfortable environment for both staff and customers while supporting uninterrupted daily operations.', '2026-02-28 12:45:48', 'uploads/gallery_69a2e37ce96e8.jpg', 'uploads/gallery_69a2e37cea277.jpg', 'uploads/gallery_69a2e37cea91f.jpg', '', '', ''),
(16, '3KVA Solar Power System Installation', 'Project Overview: Installation of a 3KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 3KVA Solar Power System designed to provide stable and efficient electricity for Apex business operations.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4 Units of 600W Solar Panels\r\n* 3KVA Inverter\r\n* 2 Gel Batteries\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nApex Business Premises (Location not specified)\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to provide the client with a constant and reliable power supply, ensuring smooth business operations even during public power outages. With this system in place, essential appliances such as fans, lighting, and office systems run steadily without interruption. The result is improved comfort, enhanced productivity, and greater operational efficiency for the business.', '2026-02-28 13:19:00', 'uploads/gallery_69a2eb438bc2a.jpg', 'uploads/gallery_69a2eb438e563.jpg', 'uploads/gallery_69a2eb444af16.jpg', '', '', ''),
(17, '5KVA Solar Power System Installation', 'Project Overview: Installation of a 5KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 5KVA Solar Power System engineered to provide high-capacity and reliable electricity for residential use.\r\n\r\nAccessories & Components Used:\r\n\r\n* 6 Units of 600W Solar Panels\r\n* 6.2KVA Inverter\r\n* 5KWh Lithium Battery\r\n* Kill Switch (for added safety control)\r\n* Breaker Protection System\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation – Anambra State\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to provide the client with a constant, stable, and efficient power supply for his home in Anambra. With this robust 5KVA system in place, the household continues to operate smoothly even during public power outages. Essential appliances such as fans, lighting, television, and mobile devices now run steadily without interruption. The system not only enhances comfort but also boosts productivity by ensuring uninterrupted daily activities and energy independence.', '2026-03-02 09:13:25', 'uploads/gallery_69a554b54d39e.jpg', 'uploads/gallery_69a554b54e602.jpg', 'uploads/gallery_69a554b54f67d.jpg', '', '', 'https://youtu.be/qH32KEV4Sqo?si=vY9_H3lUEmW8ayK8'),
(18, '5KVA Solar Power System Installation for Remote Worker', 'Project Overview: Installation of a 5KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 5KVA Solar Power System designed to provide reliable, high-capacity power for residential use, especially suited for a remote working environment.\r\n\r\nAccessories & Components Used:\r\n\r\n* 6 Units of 600W Solar Panels\r\n* Felicity 5KVA Inverter\r\n* Felicity 5KWh Lithium Battery\r\n* Kill Switch (for enhanced safety and control)\r\n* Breaker Box\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation (Client is a Remote Worker)\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure the client enjoys constant and uninterrupted power supply at home, particularly as a remote worker who depends heavily on stable electricity. Even during public power outages, the home continues to run smoothly with steady power. Essential appliances such as fans, lights, television, phones, and work devices operate without interruption, ensuring comfort, maximum productivity, and complete peace of mind.', '2026-03-02 09:47:50', 'uploads/gallery_69a55cc651910.jpg', 'uploads/gallery_69a55cc6528a1.jpg', 'uploads/gallery_69a55cc653ac1.jpg', '', '', 'https://youtu.be/x-I5MlRC_M0?si=5ppdJvP0xfJBgzBx'),
(19, '4-Eye Solar Street Light Installation', 'Project Overview: Installation of a 4-Eye Solar Street Light\r\n\r\nWhat We Installed:\r\nWe installed a 4-Eye Solar Street Light designed to provide powerful, wide-angle outdoor illumination for large spaces.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4-Eye Solar Street Light Unit\r\n* Two-Way Pole\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nClient’s Project Site\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to provide bright, energy-efficient lighting across the client’s project site. The 4-Eye Solar Street Light delivers enhanced visibility at night, improving security, safety, and overall site accessibility. With this solar-powered solution, the client now benefits from reliable illumination without depending on grid electricity, reducing energy costs while ensuring the site remains well-lit and protected after dark.', '2026-03-02 10:04:41', 'uploads/gallery_69a560b96fd42.jpg', 'uploads/gallery_69a560b96feea.jpg', 'uploads/gallery_69a560b970d21.jpg', '', '', ''),
(20, '100W Solar Flood Light Installation', 'Project Overview: Installation of a 100W Solar Flood Light\r\n\r\nWhat We Installed:\r\nWe installed a 100W Solar Flood Light designed to provide bright and energy-efficient outdoor illumination.\r\n\r\nAccessories & Components Used:\r\n\r\n* 100W Solar Flood Light Unit\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Home & Pharmacy Store\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enhance nighttime visibility and security around both the client’s home and pharmacy store. The 100W Solar Flood Light provides powerful illumination, helping to deter intruders, improve safety, and ensure clear visibility of the surroundings after dark. With this solar-powered solution, the client enjoys reliable lighting without relying on grid electricity, reducing energy costs while keeping the premises secure and well-lit at all times.', '2026-03-02 10:10:57', 'uploads/gallery_69a5623193e35.jpg', 'uploads/gallery_69a5623193fdc.jpg', '', '', '', ''),
(21, '100W Solar Flood Light & DS-20 Dual Lens Solar PTZ Security Camera Installation', 'Project Overview: Installation of a 100W Solar Flood Light & DS-20 Dual Lens Solar PTZ Security Camera\r\n\r\nWhat We Installed:\r\nWe installed a 100W Solar Flood Light alongside a DS-20 Dual Lens Solar PTZ Security Camera (CCTV System). This combined solution was designed to provide both powerful nighttime illumination and advanced remote surveillance for the client’s property.\r\n\r\nAccessories & Components Used:\r\n\r\n* 100W Solar Flood Light Unit\r\n* DS-20 Dual Lens Solar PTZ Security Camera\r\n* Mounting Accessories\r\n* Quality Electrical Wiring and installation materials\r\n* 64gb Memory Card\r\n* MTN Sim Card\r\n\r\nLocation:\r\nClient’s Farm at Awka\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to enhance security, visibility, and monitoring across the client’s farm. The 100W Solar Flood Light provides bright and energy-efficient illumination at night, ensuring the property remains well-lit and safe after dark. Complementing this, the DS-20 Dual Lens Solar PTZ Security Camera delivers real-time surveillance with wide coverage, allowing the client to remotely monitor activities on the farm from anywhere.\r\n\r\nWith this integrated lighting and CCTV solution, the client now enjoys improved security, better visibility, protection of farm assets, and complete peace of mind—without relying on grid electricity.', '2026-03-02 10:31:37', 'uploads/gallery_69a567096f28f.jpg', 'uploads/gallery_69a567097052c.jpg', 'uploads/gallery_69a5670971f3e.jpg', 'uploads/gallery_69a570c3840ea.jpg', 'uploads/gallery_69a570c38577a.jpg', ''),
(22, 'Solar Borehole System Installation', 'Project Overview: Installation of a Solar Borehole System\r\n\r\nWhat We Installed:\r\nWe installed a Solar-Powered Borehole System designed to provide a reliable and independent water supply for construction activities.\r\n\r\nAccessories & Components Used:\r\n\r\n* Solar Panels\r\n* Water Pump and Piping System\r\n* Breaker Box\r\n* Control Switch\r\n* Quality Electrical Wiring and installation materials\r\n\r\nLocation:\r\nClient’s Construction Site\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure a steady and cost-effective water supply at the client’s construction site. The solar-powered borehole system eliminates dependence on fuel-powered generators or irregular grid electricity, providing a sustainable and efficient solution for water pumping.\r\n\r\nWith this system in place, the client now has consistent access to water for construction work such as mixing concrete, site cleaning, and other essential activities. The result is improved productivity, reduced operational costs, and uninterrupted workflow throughout the project.', '2026-03-02 10:57:32', 'uploads/gallery_69a56d1c0b97a.jpg', 'uploads/gallery_69a56d1c0d313.jpg', 'uploads/gallery_69a56d1c44c81.jpg', 'uploads/gallery_69a56d1c968c4.jpg', '', ''),
(23, '11KVA Solar Power System Installation', 'Project Overview: Installation of a 11KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 11KVA Solar Power System designed to provide reliable, high-capacity power for residential use.\r\n\r\nAccessories & Components Used:\r\n\r\n* 6 Units of 600W Solar Panels\r\n* 11KVA Africell Inverter\r\n* 11KWh Lithium Battery\r\n* Kill Switch (for enhanced safety and control)\r\n* Enclosure Box\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation \r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure the client enjoys constant and uninterrupted power supply at home. Even during public power outages, the home continues to run smoothly with steady power. Essential appliances such as fans, lights, television, phones, AC, Freezer, Fridge, and work devices operate without interruption, ensuring comfort, maximum productivity, and complete peace of mind.', '2026-03-02 11:36:24', 'uploads/gallery_69a576384458e.jpeg', '', '', '', '', 'https://youtu.be/VD_qFs-Bkjw?si=OZItvE4IB7WD8k4R'),
(24, '2.5KVA Solar Power System Installation', 'Project Overview: Installation of a 2.5KVA Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 2.5KVA Solar Power System designed to provide reliable and efficient backup power for residential use.\r\n\r\nAccessories & Components Used:\r\n\r\n* 4 Units of 450W Solar Panels\r\n* Glow Energy 2.5KVA Inverter\r\n* Vitra Gel Battery\r\n* SMS MPPT Charge Controller\r\n* Breaker Protection System\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation for Mr. Cyprian\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure Mr. Cyprian enjoys a constant and dependable power supply in his home, even during public power outages. With this system in place, essential household appliances such as fans, lights, television, and mobile phones run smoothly and consistently. The solution provides enhanced comfort, uninterrupted daily living, and improved energy independence for the homeowner.', '2026-03-02 12:43:24', 'uploads/gallery_69a585ec2ea81.jpg', 'uploads/gallery_69a585ec2f521.jpg', 'uploads/gallery_69a585ec2fdef.jpg', 'uploads/gallery_69a585ec30617.jpg', '', ''),
(25, '6.2KW Hybrid Solar Power System Installation', 'Project Overview: Installation of a 6.2KW Hybrid Solar Power System\r\n\r\nWhat We Installed:\r\nWe installed a 6.2KW Hybrid Solar Power System designed to provide reliable, high-capacity power for residential use, especially suited for a remote working environment.\r\n\r\nAccessories & Components Used:\r\n\r\n* 6 Units of 600W Solar Panels\r\n* SMS 6.2KW Hybrid Inverter\r\n* SMS Tubular Battery x2\r\n* Glow Battery x2\r\n* Battery Rack\r\n* Kill Switch (for enhanced safety and control)\r\n* Breaker Box\r\n* Quality Electrical Wiring and installation accessories\r\n\r\nLocation:\r\nResidential Installation for Mr. James at Aba\r\n\r\nPurpose / Aim of Installation:\r\nThis installation was carried out to ensure Mr. James enjoys constant and uninterrupted power supply at home, particularly as a remote worker who depends heavily on stable electricity. Even during public power outages, the home continues to run smoothly with steady power. Essential appliances such as fans, lights, television, phones, and work devices operate without interruption, ensuring comfort, maximum productivity, and complete peace of mind.', '2026-03-02 13:47:18', 'uploads/gallery_69a594e5f362e.jpg', 'uploads/gallery_69a594e5f39c3.jpg', 'uploads/gallery_69a594e5f3bec.jpg', '', '', '');

